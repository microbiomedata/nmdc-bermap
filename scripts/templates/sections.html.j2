{# ============================================================================
   Macros for rendering collapsible sections (studies, publications, etc.)
   ============================================================================ #}

{% from 'macros.html.j2' import doi_link, nmdc_link, url_link, chip_list,
    keywords, data_types, modalities, field, priority_badge, status_badge,
    person_card, pride_link, massive_link, ontology_term_link %}

{# ---- Variable / Study Design Helpers ---- #}
{% macro study_design_panel(design) %}
{% if design %}
<details class="subsection study-design" open>
    <summary>Study Design</summary>
    <div class="subsection-content">
        {% if design.description %}
        <p class="compact-description">{{ design.description }}</p>
        {% endif %}
        {% if design.design_types %}
        <div class="field">
            <span class="field-label">Design type:</span>
            <span class="field-value">
            {% for term in design.design_types %}
                {{ ontology_term_link(term) }}{% if not loop.last %}, {% endif %}
            {% endfor %}
            </span>
        </div>
        {% endif %}
        {{ field('Experimental units', design.experimental_units) }}
        {{ field('Observational units', design.observational_units) }}
        {{ field('Sampling strategy', design.sampling_strategy) }}
        {{ field('Replication', design.replication) }}
        {{ field('Randomization', design.randomization) }}
        {{ field('Blocking', design.blocking) }}
        {{ field('Controls', design.controls) }}
        {{ field('Notes', design.notes) }}
    </div>
</details>
{% endif %}
{% endmacro %}

{% macro variable_roles(roles) %}
{% if roles %}
<div class="chip-list">
{% for role in roles %}
    <span class="chip variable-role">{{ role | replace('_', ' ') | title }}</span>
{% endfor %}
</div>
{% endif %}
{% endmacro %}

{% macro variable_ontology_terms(variable) %}
{% if variable.bervo_term or variable.mixs_terms or variable.unit_term or variable.ontology_mappings %}
<div class="ontology-list">
    {% if variable.bervo_term %}
    <div><span class="mini-label">BERVO</span> {{ ontology_term_link(variable.bervo_term) }}</div>
    {% endif %}
    {% if variable.mixs_terms %}
    {% for term in variable.mixs_terms %}
    <div><span class="mini-label">MIxS</span> {{ ontology_term_link(term) }}</div>
    {% endfor %}
    {% endif %}
    {% if variable.unit_term %}
    <div><span class="mini-label">Unit</span> {{ ontology_term_link(variable.unit_term) }}</div>
    {% endif %}
    {% if variable.ontology_mappings %}
    {% for term in variable.ontology_mappings %}
    <div><span class="mini-label">Map</span> {{ ontology_term_link(term) }}</div>
    {% endfor %}
    {% endif %}
</div>
{% endif %}
{% endmacro %}

{% macro variables_section(variables, title='Variables') %}
{% if variables %}
<details class="subsection variables-section" open>
    <summary>
        {{ title }}
        <span class="section-count">{{ variables | length }}</span>
    </summary>
    <div class="variable-table-wrap">
        <table class="variables-table">
            <thead>
                <tr>
                    <th>Variable</th>
                    <th>Roles</th>
                    <th>Value</th>
                    <th>Context</th>
                    <th>Mappings</th>
                </tr>
            </thead>
            <tbody>
            {% for variable in variables %}
                <tr>
                    <td>
                        <div class="variable-name">{{ variable.name }}</div>
                        {% if variable.description %}
                        <div class="variable-description">{{ variable.description }}</div>
                        {% endif %}
                    </td>
                    <td>
                        {{ variable_roles(variable.roles) }}
                    </td>
                    <td>
                        {% if variable.value_type %}
                        <span class="chip value-type">{{ variable.value_type | replace('_', ' ') | title }}</span>
                        {% endif %}
                        {% if variable.units %}
                        <div class="variable-meta"><span class="mini-label">Units</span> {{ variable.units }}</div>
                        {% endif %}
                        {% if variable.levels %}
                        <div class="variable-meta"><span class="mini-label">Levels</span> {{ variable.levels | join(', ') }}</div>
                        {% endif %}
                    </td>
                    <td>
                        {% if variable.measured_entity %}
                        <div class="variable-meta"><span class="mini-label">Entity</span> {{ variable.measured_entity }}</div>
                        {% endif %}
                        {% if variable.material_or_matrix %}
                        <div class="variable-meta"><span class="mini-label">Matrix</span> {{ variable.material_or_matrix }}</div>
                        {% endif %}
                        {% if variable.method %}
                        <div class="variable-meta"><span class="mini-label">Method</span> {{ variable.method }}</div>
                        {% endif %}
                        {% if variable.time_series %}
                        <div class="variable-meta"><span class="mini-label">Time series</span> yes{% if variable.temporal_resolution %}; {{ variable.temporal_resolution }}{% endif %}</div>
                        {% elif variable.temporal_resolution %}
                        <div class="variable-meta"><span class="mini-label">Temporal</span> {{ variable.temporal_resolution }}</div>
                        {% endif %}
                        {% if variable.spatial_resolution %}
                        <div class="variable-meta"><span class="mini-label">Spatial</span> {{ variable.spatial_resolution }}</div>
                        {% endif %}
                        {% if variable.source_field_names %}
                        <div class="variable-meta"><span class="mini-label">Fields</span> {{ variable.source_field_names | join(', ') }}</div>
                        {% endif %}
                        {% if variable.notes %}
                        <div class="variable-meta"><span class="mini-label">Notes</span> {{ variable.notes }}</div>
                        {% endif %}
                    </td>
                    <td>{{ variable_ontology_terms(variable) }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</details>
{% endif %}
{% endmacro %}

{# ---- Studies Section ---- #}
{% macro studies_section(studies) %}
{% if studies %}
<details class="section studies">
    <summary>
        Studies
        <span class="section-count">{{ studies | length }}</span>
    </summary>
    <div class="section-content">
    {% for study in studies %}
        {{ study_item(study) }}
    {% endfor %}
    </div>
</details>
{% endif %}
{% endmacro %}

{% macro study_item(study) %}
<details class="item study" {% if study.anchor_id %}id="{{ study.anchor_id }}"{% endif %}>
    <summary>
        {% if study.nmdc_ingest_priority %}
            {{ priority_badge(study.nmdc_ingest_priority) }}
        {% elif study.nmdc_ingest_target %}
            {{ priority_badge('TARGET') }}
        {% endif %}
        {% if study.nmdc_study_id %}
            {{ nmdc_link(study.nmdc_study_id) }} -
        {% endif %}
        <span class="item-title">{{ study.name }}</span>
        {% if study.pi %}<span class="pi-info">({{ study.pi }})</span>{% endif %}
    </summary>
    <div class="item-content">
        {% if study.description %}
        <p class="description">{{ study.description }}</p>
        {% endif %}
        {% if study.organism %}
        {{ field('Organism', study.organism) }}
        {% endif %}
        {% if study.data_modalities %}
        <div class="field">
            <span class="field-label">Data modalities:</span>
            <span class="field-value">{{ data_types(study.data_modalities) }}</span>
        </div>
        {% endif %}
        {% if study.keywords %}
        <div class="field">
            <span class="field-label">Keywords:</span>
            <span class="field-value">{{ keywords(study.keywords) }}</span>
        </div>
        {% endif %}
        {% if study.sample_count %}
        {{ field('Samples', study.sample_count) }}
        {% endif %}
        {% if study.resolved_field_sites %}
        <div class="field">
            <span class="field-label">Sites:</span>
            <span class="field-value">
            {% for site in study.resolved_field_sites %}
                <a href="#{{ site.anchor_id }}">{{ site.name }}</a>{% if not loop.last %}, {% endif %}
            {% endfor %}
            </span>
        </div>
        {% endif %}
        {% if study.bioproject_ids %}
        <div class="field">
            <span class="field-label">BioProjects:</span>
            <span class="field-value">
            {% for bp in study.bioproject_ids %}
                <a href="https://www.ncbi.nlm.nih.gov/bioproject/{{ bp }}" target="_blank">{{ bp }}</a>{% if not loop.last %}, {% endif %}
            {% endfor %}
            </span>
        </div>
        {% endif %}
        {% if study.brc_dataset_ids %}
        {{ field('BRC Dataset IDs', study.brc_dataset_ids | join(', ')) }}
        {% endif %}
        {% if study.primary_reference_info %}
        <div class="field">
            <span class="field-label">Primary reference:</span>
            <span class="field-value">{{ doi_link(study.primary_reference_info.reference.id) }}{% if study.primary_reference_info.reference.title %} - {{ study.primary_reference_info.reference.title }}{% endif %}</span>
        </div>
        {% endif %}
        {% if study.source_reference %}
        <div class="field">
            <span class="field-label">Source:</span>
            <span class="field-value">
                <a href="{{ study.source_reference.url }}" target="_blank">{{ study.source_reference.title }}</a>
                {% if study.source_reference.summary %}<br><span style="color: #666; font-size: 0.9em;">{{ study.source_reference.summary }}</span>{% endif %}
            </span>
        </div>
        {% endif %}
        {{ study_design_panel(study.study_design) }}
        {{ variables_section(study.variables, 'Study Variables') }}
    </div>
</details>
{% endmacro %}

{# ---- Publications Section ---- #}
{% macro publications_section(publications) %}
{% if publications %}
<details class="section publications">
    <summary>
        Key Publications
        <span class="section-count">{{ publications | length }}</span>
    </summary>
    <div class="section-content">
    {% for pub in publications %}
        {{ publication_item(pub) }}
    {% endfor %}
    </div>
</details>
{% endif %}
{% endmacro %}

{% macro publication_item(pub) %}
<details class="item publication">
    <summary>
        {{ doi_link(pub.id) }}
        <span class="item-title">{{ pub.title }}</span>
    </summary>
    <div class="item-content">
        {% if pub.findings %}
        <ul class="findings">
        {% for finding in pub.findings %}
            <li>{{ finding.statement }}</li>
        {% endfor %}
        </ul>
        {% endif %}
    </div>
</details>
{% endmacro %}

{# ---- Datasets Section ---- #}
{% macro datasets_section(datasets) %}
{% if datasets %}
<details class="section datasets">
    <summary>
        Datasets
        <span class="section-count">{{ datasets | length }}</span>
    </summary>
    <div class="section-content">
    {% for ds in datasets %}
        {{ dataset_item(ds) }}
    {% endfor %}
    </div>
</details>
{% endif %}
{% endmacro %}

{% macro dataset_item(ds) %}
<details class="item dataset" {% if ds.anchor_id %}id="{{ ds.anchor_id }}"{% endif %}>
    <summary>
        <span class="item-title">{{ ds.name }}</span>
    </summary>
    <div class="item-content">
        {% if ds.description %}
        <p class="description">{{ ds.description }}</p>
        {% endif %}
        {% if ds.repository %}
        {{ field('Repository', ds.repository) }}
        {% endif %}
        {% if ds.url %}
        <div class="field">
            <span class="field-label">URL:</span>
            <span class="field-value"><a href="{{ ds.url }}" target="_blank">{{ ds.url }}</a></span>
        </div>
        {% endif %}
        {% if ds.doi %}
        <div class="field">
            <span class="field-label">DOI:</span>
            <span class="field-value">{{ doi_link(ds.doi) }}</span>
        </div>
        {% endif %}
        {% if ds.pride_id %}
        <div class="field">
            <span class="field-label">PRIDE:</span>
            <span class="field-value">{{ pride_link(ds.pride_id) }}</span>
        </div>
        {% endif %}
        {% if ds.massive_id %}
        <div class="field">
            <span class="field-label">MassIVE:</span>
            <span class="field-value">{{ massive_link(ds.massive_id) }}</span>
        </div>
        {% endif %}
        {% if ds.data_type %}
        {{ field('Data type', ds.data_type) }}
        {% endif %}
        {% if ds.size %}
        {{ field('Size', ds.size) }}
        {% endif %}
        {% if ds.primary_reference_info %}
        <div class="field">
            <span class="field-label">Reference:</span>
            <span class="field-value">{{ doi_link(ds.primary_reference_info.reference.id) }}{% if ds.primary_reference_info.reference.title %} - {{ ds.primary_reference_info.reference.title }}{% endif %}</span>
        </div>
        {% endif %}
        {{ variables_section(ds.variables, 'Dataset Variables') }}
    </div>
</details>
{% endmacro %}

{# ---- Analyses / KBase Narratives Section ---- #}
{% macro analyses_section(analyses) %}
{% if analyses %}
<details class="section analyses">
    <summary>
        Analyses & KBase Narratives
        <span class="section-count">{{ analyses | length }}</span>
    </summary>
    <div class="section-content">
    {% for analysis in analyses %}
        {{ analysis_item(analysis) }}
    {% endfor %}
    </div>
</details>
{% endif %}
{% endmacro %}

{% macro analysis_item(analysis) %}
<details class="item analysis">
    <summary>
        {% if analysis.kbase_narrative_url %}
        <a href="{{ analysis.kbase_narrative_url }}" target="_blank" class="item-title">{{ analysis.name }}</a>
        {% else %}
        <span class="item-title">{{ analysis.name }}</span>
        {% endif %}
    </summary>
    <div class="item-content">
        {% if analysis.description %}
        <p class="description">{{ analysis.description }}</p>
        {% endif %}
        {% if analysis.analysis_type %}
        {{ field('Type', analysis.analysis_type | replace('_', ' ') | title) }}
        {% endif %}
        {% if analysis.genome_count %}
        {{ field('Genomes', analysis.genome_count) }}
        {% endif %}
        {% if analysis.sample_count %}
        {{ field('Samples', analysis.sample_count) }}
        {% endif %}
        {% if analysis.output_data_types %}
        <div class="field">
            <span class="field-label">Output types:</span>
            <span class="field-value">{{ data_types(analysis.output_data_types) }}</span>
        </div>
        {% endif %}
        {% if analysis.primary_reference_info %}
        <div class="field">
            <span class="field-label">Reference:</span>
            <span class="field-value">{{ doi_link(analysis.primary_reference_info.reference.id) }}{% if analysis.primary_reference_info.reference.title %} - {{ analysis.primary_reference_info.reference.title }}{% endif %}</span>
        </div>
        {% endif %}
    </div>
</details>
{% endmacro %}

{# ---- Capabilities Section ---- #}
{% macro capabilities_section(capabilities) %}
{% if capabilities %}
<details class="section capabilities">
    <summary>
        Capabilities
        <span class="section-count">{{ capabilities | length }}</span>
    </summary>
    <div class="section-content">
    {% for cap in capabilities %}
        {{ capability_item(cap) }}
    {% endfor %}
    </div>
</details>
{% endif %}
{% endmacro %}

{% macro capability_item(cap) %}
<details class="item capability">
    <summary>
        {{ status_badge(cap.status) }}
        {% if cap.url %}
        <a href="{{ cap.url }}" target="_blank" class="item-title">{{ cap.name }}</a>
        {% else %}
        <span class="item-title">{{ cap.name }}</span>
        {% endif %}
    </summary>
    <div class="item-content">
        {% if cap.description %}
        <p class="description">{{ cap.description }}</p>
        {% endif %}
        {% if cap.capability_type %}
        {{ field('Type', cap.capability_type | replace('_', ' ') | title) }}
        {% endif %}
        {% if cap.throughput %}
        {{ field('Throughput', cap.throughput) }}
        {% endif %}
        {% if cap.instruments %}
        <div class="field">
            <span class="field-label">Instruments:</span>
            <span class="field-value">
            <ul style="margin: 5px 0; padding-left: 20px;">
            {% for inst in cap.instruments %}
                <li>
                    <strong>{{ inst.name }}</strong>
                    {% if inst.count %} ({{ inst.count }}){% endif %}
                    {% if inst.description %} - {{ inst.description }}{% endif %}
                </li>
            {% endfor %}
            </ul>
            </span>
        </div>
        {% endif %}
        {% if cap.applications %}
        <div class="field">
            <span class="field-label">Applications:</span>
            <span class="field-value">{{ chip_list(cap.applications, 'service') }}</span>
        </div>
        {% endif %}
        {% if cap.data_products %}
        <div class="field">
            <span class="field-label">Data products:</span>
            <span class="field-value">{{ chip_list(cap.data_products, 'data-type') }}</span>
        </div>
        {% endif %}
    </div>
</details>
{% endmacro %}

{# ---- Field Sites Section ---- #}
{% macro field_sites_section(sites) %}
{% if sites %}
<details class="section field-sites">
    <summary>
        Field Sites
        <span class="section-count">{{ sites | length }}</span>
    </summary>
    <div class="section-content">
    {% for site in sites %}
        {{ field_site_item(site) }}
    {% endfor %}
    </div>
</details>
{% endif %}
{% endmacro %}

{% macro field_site_item(site) %}
<details class="item field-site" {% if site.anchor_id %}id="{{ site.anchor_id }}"{% endif %}>
    <summary>
        <span class="item-title">{{ site.name }}</span>
        {% if site.location %}<span class="pi-info">({{ site.location }})</span>{% endif %}
    </summary>
    <div class="item-content">
        {% if site.description %}
        <p class="description">{{ site.description }}</p>
        {% endif %}
        {% if site.site_type %}
        {{ field('Type', site.site_type | replace('_', ' ') | title) }}
        {% endif %}
        {% if site.pi %}
        {{ field('PI', site.pi) }}
        {% endif %}
        {% if site.institution %}
        {{ field('Institution', site.institution) }}
        {% endif %}
        {% if site.relevance %}
        <div class="field">
            <span class="field-label">Relevance:</span>
            <span class="field-value">{{ chip_list(site.relevance, 'keyword') }}</span>
        </div>
        {% endif %}
        {% if site.contaminants %}
        <div class="field">
            <span class="field-label">Contaminants:</span>
            <span class="field-value">{{ chip_list(site.contaminants, 'keyword') }}</span>
        </div>
        {% endif %}
        {% if site.contamination_source %}
        {{ field('Contamination source', site.contamination_source) }}
        {% endif %}
        {% if site.elevation_m %}
        {{ field('Elevation (m)', site.elevation_m) }}
        {% endif %}
        {% if site.mean_annual_temp_c %}
        {{ field('Mean annual temp (C)', site.mean_annual_temp_c) }}
        {% endif %}
        {% if site.mean_annual_precip_cm %}
        {{ field('Mean annual precip (cm)', site.mean_annual_precip_cm) }}
        {% endif %}
        {% if site.program_refs %}
        <div class="field">
            <span class="field-label">Programs:</span>
            <span class="field-value">
            {% for program in site.program_refs %}
                <a href="#{{ program.id }}">{{ program.name }}</a>{% if not loop.last %}, {% endif %}
            {% endfor %}
            </span>
        </div>
        {% endif %}
    </div>
</details>
{% endmacro %}

