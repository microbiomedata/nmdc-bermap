function expandAll() {
    document.querySelectorAll('details').forEach(d => d.open = true);
}

function collapseAll() {
    document.querySelectorAll('details').forEach(d => d.open = false);
}

function expandLevel(level) {
    collapseAll();
    if (level >= 1) {
        document.querySelectorAll('.category').forEach(d => d.open = true);
    }
    if (level >= 2) {
        document.querySelectorAll('.program').forEach(d => d.open = true);
    }
}

// Search functionality
const searchBox = document.getElementById('searchBox');
let debounceTimer;

searchBox.addEventListener('input', function(e) {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
        const query = e.target.value.toLowerCase().trim();

        const targets = document.querySelectorAll('.program, .variable-index-item, .bervo-group');

        if (query.length < 2) {
            targets.forEach(p => {
                p.classList.remove('hidden');
            });
            return;
        }

        // Search and filter
        targets.forEach(target => {
            const text = target.textContent.toLowerCase();
            if (text.includes(query)) {
                target.classList.remove('hidden');
                let parent = target.closest('.category');
                if (parent) parent.open = true;
                target.querySelectorAll('details').forEach(d => d.open = true);
                let detailsParent = target.parentElement;
                while (detailsParent) {
                    if (detailsParent.tagName === 'DETAILS') detailsParent.open = true;
                    detailsParent = detailsParent.parentElement;
                }
            } else {
                target.classList.add('hidden');
            }
        });
    }, 150);
});

// Keyboard shortcuts
document.addEventListener('keydown', function(e) {
    // Focus search on Ctrl/Cmd + K
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        searchBox.focus();
        searchBox.select();
    }
    // Escape to clear search
    if (e.key === 'Escape' && document.activeElement === searchBox) {
        searchBox.value = '';
        searchBox.dispatchEvent(new Event('input'));
        searchBox.blur();
    }
});
