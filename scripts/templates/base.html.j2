<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page_title | default('DOE BER Research Programs Browser') }}</title>
    <style>
        {% include 'styles.css.j2' %}
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>{{ page_title | default('DOE BER Research Programs') }}</h1>
            <p class="subtitle">{{ page_subtitle | default('Bioenergy Research Centers, Scientific Focus Areas, AI Projects, and User Facilities') }}</p>
            <nav class="page-nav" aria-label="Generated browser pages">
                <a href="browser.html">Programs</a>
                <a href="variables.html">Variables</a>
                <a href="variable-index.yaml">Variable index YAML</a>
            </nav>
        </header>

        <div class="controls">
            <input type="text" class="search-box" placeholder="{{ search_placeholder | default('Search programs...') }}" id="searchBox">
            <button onclick="expandAll()">Expand All</button>
            <button onclick="collapseAll()">Collapse All</button>
            <button onclick="expandLevel(1)">Categories Only</button>
        </div>

        <main>
            {% block content %}{% endblock %}
        </main>

        <footer>
            <p class="metadata">
                Compiled: {{ metadata.compiled_date | default('Unknown') }} |
                <a href="https://github.com/nmdc/nmdc-sfas-brcs">Source</a>
            </p>
        </footer>
    </div>

    <script>
        {% include 'scripts.js.j2' %}
    </script>
</body>
</html>
