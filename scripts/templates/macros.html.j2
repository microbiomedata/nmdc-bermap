{# ============================================================================
   Reusable macros for rendering different data types
   ============================================================================ #}

{# Render a DOI as a link #}
{% macro doi_link(doi) %}
{% if doi %}
{% if doi.startswith('doi:') %}
<a href="https://doi.org/{{ doi[4:] }}" target="_blank" class="link-doi">{{ doi }}</a>
{% else %}
<a href="https://doi.org/{{ doi }}" target="_blank" class="link-doi">{{ doi }}</a>
{% endif %}
{% endif %}
{% endmacro %}

{# Render an NMDC ID as a link - uses the generic API endpoint that redirects appropriately #}
{% macro nmdc_link(nmdc_id) %}
{% if nmdc_id %}
{% set bare_id = nmdc_id[5:] if nmdc_id.startswith('nmdc:') else nmdc_id %}
<a href="https://api.microbiomedata.org/objects/{{ bare_id }}" target="_blank" class="link-nmdc">{{ nmdc_id }}</a>
{% endif %}
{% endmacro %}

{# Render a PRIDE/ProteomeXchange ID as a link #}
{% macro pride_link(pride_id) %}
{% if pride_id %}
<a href="https://www.ebi.ac.uk/pride/archive/projects/{{ pride_id }}" target="_blank" class="link-pride">{{ pride_id }}</a>
{% endif %}
{% endmacro %}

{# Render a MassIVE ID as a link #}
{% macro massive_link(massive_id) %}
{% if massive_id %}
<a href="https://massive.ucsd.edu/ProteoSAFe/dataset.jsp?task={{ massive_id }}" target="_blank" class="link-massive">{{ massive_id }}</a>
{% endif %}
{% endmacro %}

{# Render a URL as a link #}
{% macro url_link(url, label=None) %}
{% if url %}
<a href="{{ url }}" target="_blank">{{ label or url }}</a>
{% endif %}
{% endmacro %}

{# Render an ontology term id/label tuple as a link when the prefix is known #}
{% macro ontology_term_link(term) %}
{% if term %}
{% set term_id = term.id if term is mapping else term %}
{% set term_label = term.label if term is mapping and term.label else term_id %}
{% set mapping_relation = term.mapping_relation if term is mapping and term.mapping_relation else none %}
{% set mapping_note = term.mapping_note if term is mapping and term.mapping_note else none %}
{% if term_id %}
{% set prefix = term_id.split(':')[0] if ':' in term_id else '' %}
{% set local_id = term_id.split(':')[1] if ':' in term_id else term_id %}
{% if prefix == 'BERVO' %}
<a href="https://w3id.org/bervo/BERVO_{{ local_id }}" target="_blank" class="ontology-term">{{ term_label }} <span>{{ term_id }}</span></a>
{% elif prefix == 'MIXS' %}
<a href="https://w3id.org/mixs/{{ local_id }}" target="_blank" class="ontology-term">{{ term_label }} <span>{{ term_id }}</span></a>
{% elif prefix in ['OBI', 'STATO', 'EFO', 'ENVO', 'UO', 'NCBITaxon', 'PO', 'PATO'] %}
<a href="http://purl.obolibrary.org/obo/{{ prefix }}_{{ local_id }}" target="_blank" class="ontology-term">{{ term_label }} <span>{{ term_id }}</span></a>
{% else %}
<span class="ontology-term">{{ term_label }} <span>{{ term_id }}</span></span>
{% endif %}
{% if mapping_relation %}
<span class="mapping-relation">{{ mapping_relation | replace('_', ' ') | lower }}</span>
{% endif %}
{% if mapping_note %}
<span class="mapping-note">{{ mapping_note }}</span>
{% endif %}
{% endif %}
{% endif %}
{% endmacro %}

{# Render a list of chips/tags #}
{% macro chip_list(items, chip_class='') %}
{% if items %}
<div class="chip-list">
{% for item in items %}
<span class="chip {{ chip_class }}">{{ item | replace('_', ' ') | title }}</span>
{% endfor %}
</div>
{% endif %}
{% endmacro %}

{# Render keywords as chips #}
{% macro keywords(items) %}
{{ chip_list(items, 'keyword') }}
{% endmacro %}

{# Render data types as chips #}
{% macro data_types(items) %}
{{ chip_list(items, 'data-type') }}
{% endmacro %}

{# Render modalities as chips #}
{% macro modalities(items) %}
{{ chip_list(items, 'modality') }}
{% endmacro %}

{# Render institutions as chips #}
{% macro institutions(items) %}
{{ chip_list(items, 'institution') }}
{% endmacro %}

{# Render a badge #}
{% macro badge(text, badge_class='') %}
<span class="badge {{ badge_class }}">{{ text }}</span>
{% endmacro %}

{# Render priority badge #}
{% macro priority_badge(priority) %}
{% if priority %}
{{ badge(priority, 'priority-' ~ priority|lower) }}
{% endif %}
{% endmacro %}

{# Render status badge #}
{% macro status_badge(status) %}
{% if status %}
{{ badge(status | replace('_', ' '), 'status-' ~ status|lower) }}
{% endif %}
{% endmacro %}

{# Render a field with label and value #}
{% macro field(label, value, render_func=None) %}
{% if value %}
<div class="field">
    <span class="field-label">{{ label | replace('_', ' ') }}:</span>
    <span class="field-value">
        {% if render_func %}
            {{ render_func(value) }}
        {% elif value is string %}
            {{ value }}
        {% elif value is iterable and value is not mapping %}
            {{ value | join(', ') }}
        {% else %}
            {{ value }}
        {% endif %}
    </span>
</div>
{% endif %}
{% endmacro %}

{# Render a person #}
{% macro person_card(person) %}
<div class="person-card">
    <div class="person-name">{{ person.name }}</div>
    {% if person.role %}<div class="person-role">{{ person.role }}</div>{% endif %}
    {% if person.affiliation %}<div class="person-affiliation">{{ person.affiliation }}</div>{% endif %}
</div>
{% endmacro %}

{# Render a list of people #}
{% macro person_list(people) %}
{% if people %}
<div class="person-list">
{% for person in people %}
{{ person_card(person) }}
{% endfor %}
</div>
{% endif %}
{% endmacro %}

{# Render web resources #}
{% macro web_resources(websites) %}
{% if websites %}
<div class="web-links">
{% for key, url in websites.items() if url %}
<a href="{{ url }}" target="_blank" class="web-link">
    {{ key | replace('_', ' ') | title }}
</a>
{% endfor %}
</div>
{% endif %}
{% endmacro %}

{# Render location #}
{% macro location(loc) %}
{% if loc %}
<span class="location-text">
{% if loc.city %}{{ loc.city }}{% endif %}
{% if loc.state %}, {{ loc.state }}{% endif %}
{% if loc.country and loc.country != 'USA' %}, {{ loc.country }}{% endif %}
</span>
{% endif %}
{% endmacro %}

{# Render funding info #}
{% macro funding_info(funding) %}
{% if funding %}
<span>
{{ funding.agency or '' }}
{% if funding.program %} / {{ funding.program }}{% endif %}
{% if funding.current_period %} ({{ funding.current_period }}){% endif %}
{% if funding.total_funding %} - {{ funding.total_funding }}{% endif %}
</span>
{% endif %}
{% endmacro %}
