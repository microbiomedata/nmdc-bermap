nmdc_sfas_brcs:emsl a nmdc_sfas_brcs:UserFacility ;
    schema1:alternateName "EMSL" ;
    schema1:description """EMSL provides advanced analytical capabilities for environmental and biological research, including mass spectrometry, NMR, electron microscopy, and high-performance computing.
""" ;
    schema1:name "Environmental Molecular Sciences Laboratory" ;
    nmdc_sfas_brcs:capabilities [ a nmdc_sfas_brcs:Capability ;
            schema1:description "World's largest autonomous-capable science system for anaerobic microbial experimentation. Commissioned December 2024 by DOE Secretary Chris Wright. 18 instruments housed in 1,800 sq ft across seven anaerobic pods connected by robotic track system. Enables complete design-build-test-learn cycles with minimal operator intervention. Generates AI/ML-ready datasets in publicly available databases hosted on EMSL Science Central. Built in partnership with Ginkgo Bioworks under $4.66M contract." ;
            schema1:name "Anaerobic Microbial Phenotyping Platform (AMP2)" ;
            nmdc_sfas_brcs:applications "Anaerobic microbe characterization",
                "Biofuel and biomaterial development",
                "Chemical and energy production from microbes",
                "Design-build-test-learn cycles for microbial phenotyping",
                "Genotype-phenotype mapping",
                "High-throughput screening under variable conditions" ;
            nmdc_sfas_brcs:capability_type "ANAEROBIC_PHENOTYPING" ;
            nmdc_sfas_brcs:commissioned_date "2024-12-04"^^xsd:date ;
            nmdc_sfas_brcs:data_products "AI/ML-ready phenotype datasets",
                "Flow cytometry data",
                "Growth curves",
                "Metabolite profiles" ;
            nmdc_sfas_brcs:future_expansion "AMP2 is a prototype for M2PC (Microbial Molecular Phenotyping Capability), a $47M 32,000 sq ft facility with 100+ instruments expected to open by 2030." ;
            nmdc_sfas_brcs:instruments [ a nmdc_sfas_brcs:Instrument ;
                    schema1:description "Optical density, fluorescence, and luminescence measurements" ;
                    schema1:name "Fluorescence/Absorbance Readers" ;
                    nmdc_sfas_brcs:instrument_type "PLATE_READER" ],
                [ a nmdc_sfas_brcs:Instrument ;
                    schema1:description "Cell transformation capabilities" ;
                    schema1:name "Electroporator" ;
                    nmdc_sfas_brcs:instrument_type "ELECTROPORATOR" ],
                [ a nmdc_sfas_brcs:Instrument ;
                    schema1:description "Automated sample preparation, dispensing, and cherry-picking" ;
                    schema1:name "Liquid Handlers" ;
                    nmdc_sfas_brcs:instrument_type "LIQUID_HANDLER" ],
                [ a nmdc_sfas_brcs:Instrument ;
                    schema1:description "Supports up to 14 deep well plates for microbial growth" ;
                    schema1:name "Cultivation Systems" ;
                    nmdc_sfas_brcs:instrument_type "INCUBATOR" ],
                [ a nmdc_sfas_brcs:Instrument ;
                    schema1:description "Liquid chromatography for metabolite analysis" ;
                    schema1:name "HPLC Systems" ;
                    nmdc_sfas_brcs:instrument_type "HPLC" ],
                [ a nmdc_sfas_brcs:Instrument ;
                    schema1:description "Interconnected pods maintaining anaerobic environment" ;
                    schema1:name "Anaerobic Chambers" ;
                    nmdc_sfas_brcs:count 7 ;
                    nmdc_sfas_brcs:instrument_type "ANAEROBIC_CHAMBER" ],
                [ a nmdc_sfas_brcs:Instrument ;
                    schema1:description "Cell counting and characterization" ;
                    schema1:name "Flow Cytometers" ;
                    nmdc_sfas_brcs:instrument_type "FLOW_CYTOMETER" ] ;
            nmdc_sfas_brcs:leader "Scott Baker" ;
            nmdc_sfas_brcs:status "OPERATIONAL" ;
            nmdc_sfas_brcs:url "https://www.emsl.pnnl.gov/science/instruments-resources/anaerobic-microbial-phenotyping-platform-amp2"^^xsd:anyURI ;
            nmdc_sfas_brcs:year_established 2025 ],
        [ a nmdc_sfas_brcs:Capability ;
            schema1:description "Robust solid- and liquid-state NMR capabilities for structural biology, metabolomics, natural products, and organic matter characterization. Non-destructive with minimal sample preparation." ;
            schema1:name "NMR Spectroscopy" ;
            nmdc_sfas_brcs:applications "Metabolomics",
                "Natural products",
                "Organic matter characterization",
                "Structural biology" ;
            nmdc_sfas_brcs:capability_type "NMR" ;
            nmdc_sfas_brcs:data_products "Molecular structure data",
                "NMR spectra" ;
            nmdc_sfas_brcs:instruments [ a nmdc_sfas_brcs:Instrument ;
                    schema1:description "For structural biology and materials" ;
                    schema1:name "Solid-State NMR" ;
                    nmdc_sfas_brcs:instrument_type "NMR_SPECTROMETER" ],
                [ a nmdc_sfas_brcs:Instrument ;
                    schema1:description "For metabolomics and natural products" ;
                    schema1:name "Liquid-State NMR" ;
                    nmdc_sfas_brcs:instrument_type "NMR_SPECTROMETER" ] ;
            nmdc_sfas_brcs:status "OPERATIONAL" ;
            nmdc_sfas_brcs:url "https://www.emsl.pnnl.gov/science/instruments-resources/liquid-state-nmr-metabolomics"^^xsd:anyURI ],
        [ a nmdc_sfas_brcs:Capability ;
            schema1:description "Cryo-TEM suite including Krios G3i cryogenic TEM and Aquilos 2 cryo-FIB-SEM for de novo structure determination, high-resolution cellular imaging, and tomography. Supports samples from 50 kDa proteins to whole cells." ;
            schema1:name "Cryogenic Electron Microscopy" ;
            nmdc_sfas_brcs:applications "Biofilm morphology",
                "Cellular architecture imaging",
                "Cryo-electron tomography",
                "De novo protein structure determination",
                "Plant-microbe interaction studies" ;
            nmdc_sfas_brcs:capability_type "CRYO_EM" ;
            nmdc_sfas_brcs:data_products "3D structures",
                "Cellular ultrastructure images",
                "Tomographic reconstructions" ;
            nmdc_sfas_brcs:instruments [ a nmdc_sfas_brcs:Instrument ;
                    schema1:description "Cryogenic transmission electron microscope for high-resolution imaging" ;
                    schema1:name "Krios G3i" ;
                    nmdc_sfas_brcs:instrument_type "CRYO_TEM" ;
                    nmdc_sfas_brcs:manufacturer "Thermo Scientific" ],
                [ a nmdc_sfas_brcs:Instrument ;
                    schema1:description "Sample preparation via lamella generation with ~10 nm resolution" ;
                    schema1:name "Aquilos 2 Cryo-FIB-SEM" ;
                    nmdc_sfas_brcs:instrument_type "FIB_SEM" ;
                    nmdc_sfas_brcs:manufacturer "Thermo Scientific" ] ;
            nmdc_sfas_brcs:status "OPERATIONAL" ;
            nmdc_sfas_brcs:url "https://www.emsl.pnnl.gov/science/instruments-resources/cryogenic-transmission-electron-microscopy-structural-biology"^^xsd:anyURI ],
        [ a nmdc_sfas_brcs:Capability ;
            schema1:description """Open science network building a continental-scale database of standardized molecular and microstructural soil data. Integrates FTICR-MS for organic matter composition, X-ray CT for 3D pore structure, and metagenomics via JGI partnership. Data available on Science Central without embargo. See nmdc_sfas_brcs:monet for full program details.
""" ;
            schema1:name "Molecular Observation Network (MONet)" ;
            nmdc_sfas_brcs:applications "Continental-scale soil characterization",
                "Earth system model integration",
                "Soil carbon cycling research",
                "Soil organic matter molecular analysis" ;
            nmdc_sfas_brcs:capability_type "FTICR_MS" ;
            nmdc_sfas_brcs:data_products "FTICR-MS organic matter profiles",
                "Metagenome sequences and annotations",
                "Soil biogeochemistry measurements",
                "X-ray CT pore network metrics" ;
            nmdc_sfas_brcs:leader "John Bargar" ;
            nmdc_sfas_brcs:status "OPERATIONAL" ;
            nmdc_sfas_brcs:url "https://www.emsl.pnnl.gov/monet"^^xsd:anyURI ;
            nmdc_sfas_brcs:year_established 2023 ],
        [ a nmdc_sfas_brcs:Capability ;
            schema1:description "Comprehensive metabolomics workflow with 24 instruments for unbiased metabolite and lipid measurement including GC-MS, Orbitrap, and FTICR-MS platforms. Includes a 21 Tesla FTICR (one of two in the world)." ;
            schema1:name "Metabolomics Mass Spectrometry Suite" ;
            nmdc_sfas_brcs:applications "Lipidomics",
                "Metabolic flux analysis",
                "Targeted metabolite quantification",
                "Untargeted metabolomics" ;
            nmdc_sfas_brcs:capability_type "METABOLOMICS_MS" ;
            nmdc_sfas_brcs:data_products "Lipid profiles",
                "Metabolite identifications",
                "Metabolite profiles" ;
            nmdc_sfas_brcs:instruments [ a nmdc_sfas_brcs:Instrument ;
                    schema1:description "Diverse Orbitrap instruments including hybrid quadrupole and Tribrid" ;
                    schema1:name "Orbitrap Mass Spectrometers" ;
                    nmdc_sfas_brcs:count 16 ;
                    nmdc_sfas_brcs:instrument_type "ORBITRAP" ],
                [ a nmdc_sfas_brcs:Instrument ;
                    schema1:description "Gas chromatography-mass spectrometry" ;
                    schema1:name "GC-MS Instruments" ;
                    nmdc_sfas_brcs:count 4 ;
                    nmdc_sfas_brcs:instrument_type "GC" ],
                [ a nmdc_sfas_brcs:Instrument ;
                    schema1:description "Dedicated to mass spectrometry imaging" ;
                    schema1:name "Imaging Mass Spectrometers" ;
                    nmdc_sfas_brcs:count 4 ;
                    nmdc_sfas_brcs:instrument_type "ORBITRAP" ],
                [ a nmdc_sfas_brcs:Instrument ;
                    schema1:description "For sensitive targeted quantification and metabolic flux measurements" ;
                    schema1:name "Triple Quadrupole MS" ;
                    nmdc_sfas_brcs:count 9 ;
                    nmdc_sfas_brcs:instrument_type "TRIPLE_QUADRUPOLE" ],
                [ a nmdc_sfas_brcs:Instrument ;
                    schema1:name "FTICR Mass Spectrometers" ;
                    nmdc_sfas_brcs:count 4 ;
                    nmdc_sfas_brcs:instrument_type "FTICR" ;
                    nmdc_sfas_brcs:specifications "Including 21 Tesla FTICR (one of two worldwide)" ] ;
            nmdc_sfas_brcs:status "OPERATIONAL" ;
            nmdc_sfas_brcs:url "https://www.emsl.pnnl.gov/science/instruments-resources/metabolomics"^^xsd:anyURI ],
        [ a nmdc_sfas_brcs:Capability ;
            schema1:description "Nanoscale secondary ion mass spectrometry for subcellular-resolution chemical imaging and isotope ratio analysis in biological samples." ;
            schema1:name "NanoSIMS Imaging" ;
            nmdc_sfas_brcs:applications "Element mapping",
                "Isotope probing",
                "Subcellular metabolic imaging" ;
            nmdc_sfas_brcs:capability_type "NANOSIMS_IMAGING" ;
            nmdc_sfas_brcs:status "OPERATIONAL" ] ;
