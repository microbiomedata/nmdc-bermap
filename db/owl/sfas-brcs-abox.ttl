nmdc_sfas_brcs:river_corridor a nmdc_sfas_brcs:ScientificFocusArea ;
    schema1:alternateName "RC-SFA" ;
    schema1:description """The RC-SFA delivers predictive understanding of how perturbations impact watershed hydro-biogeochemistry across the hillslope-to-stream continuum. Focus on wildfire and stream drying as interacting perturbations with uncertain impacts.
""" ;
    schema1:keywords "HYDROLOGIC_CONNECTIVITY",
        "RIVER_CORRIDORS",
        "STREAM_DRYING",
        "WHONDRS",
        "WILDFIRE",
        "YAKIMA_RIVER_BASIN" ;
    schema1:name "River Corridor Hydrobiogeochemistry Science Focus Area" ;
    nmdc_sfas_brcs:analyses nmdc_sfas_brcs:growdb_mags,
        nmdc_sfas_brcs:growdb_metabolic_models,
        nmdc_sfas_brcs:growdb_samples ;
    nmdc_sfas_brcs:data_types "BIOGEOCHEMICAL_DATA",
        "ENVIRONMENTAL_SENSOR_DATA",
        "GEOSPATIAL",
        "WATER_CHEMISTRY" ;
    nmdc_sfas_brcs:datasets [ a nmdc_sfas_brcs:Dataset ;
            schema1:description "Community-contributed data packages from WHONDRS (Worldwide Hydrobiogeochemistry Observation Network for Dynamic River Systems)." ;
            schema1:name "WHONDRS Community Data Packages" ;
            nmdc_sfas_brcs:count "58 open datasets (as of 2024)" ;
            nmdc_sfas_brcs:repository "ESS-DIVE" ] ;
    nmdc_sfas_brcs:field_sites [ a nmdc_sfas_brcs:FieldSite ;
            schema1:description "Single-basin testbed with varied environmental features" ;
            schema1:name "Yakima River Basin" ;
            nmdc_sfas_brcs:location "Washington State" ] ;
    nmdc_sfas_brcs:funding [ a nmdc_sfas_brcs:FundingInfo ;
            nmdc_sfas_brcs:agency "DOE BER" ;
            nmdc_sfas_brcs:current_period "FY 2025-2028" ;
            nmdc_sfas_brcs:program "Environmental System Science (ESS)" ] ;
    nmdc_sfas_brcs:kbase_genome_collection "GROW" ;
    nmdc_sfas_brcs:key_publications <https://doi.org/10.1016/j.soilbio.2024.109364>,
        <https://doi.org/10.1021/acs.est.3c10826>,
        <https://doi.org/10.1029/2023WR036023>,
        <https://doi.org/10.1029/2023gl106220>,
        <https://doi.org/10.1038/s41586-024-08240-z>,
        <https://doi.org/10.3390/w16010171> ;
    nmdc_sfas_brcs:lead_institution "Pacific Northwest National Laboratory" ;
    nmdc_sfas_brcs:nmdc_umbrella_study "nmdc:sty-11-x4aawf73"^^xsd:anyURI ;
    nmdc_sfas_brcs:program_type "SCIENTIFIC_FOCUS_AREA" ;
    nmdc_sfas_brcs:scientific_questions "How do precipitation and temperature control hydrologic connectivity?",
        "How does stream drying affect biogeochemical processes?",
        "What are impacts of wildfires on watershed hydro-biogeochemistry?",
        "What controls carbon and nutrient transport in river corridors?" ;
    nmdc_sfas_brcs:sfa_type "ENVIRONMENTAL_SYSTEM_SCIENCE_SFA" ;
    nmdc_sfas_brcs:studies [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Molecular-scale processes governing biogeochemical function of subsurface groundwater-surface water mixing zones (hyporheic zone). Columbia River samples from areas with varied vegetation density for studying biogeochemical hotspots." ;
            schema1:name "Riverbed Sediment Microbial Communities from the Columbia River" ;
            nmdc_sfas_brcs:data_modalities OBI:0000366,
                OBI:0000615,
                OBI:0002623 ;
