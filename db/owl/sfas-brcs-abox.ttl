                    nmdc_sfas_brcs:reference <https://doi.org/10.1371/journal.pone.0228165> ] ],
        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Catalog of 2,000+ microbial genomes from ~100 rivers across North America. Over 1,000 metagenomes sequenced through JGI from WHONDRS water samples. Landmark study published in Nature 2024." ;
            schema1:name "Functional Microbiome Catalogue from North American Rivers" ;
            nmdc_sfas_brcs:data_modalities OBI:0002623,
                "METATRANSCRIPTOMICS" ;
            nmdc_sfas_brcs:nmdc_ingest_priority "HIGH" ;
