            nmdc_sfas_brcs:sample_count 552 ],
        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Characterization and interpretation of plant-microbe interfaces using poplar and its microbial community in the context of favorable plant microbe interactions." ;
            schema1:name "Defining the functional diversity of the Populus root microbiome" ;
