nmdc_sfas_brcs:enigma a nmdc_sfas_brcs:ScientificFocusArea ;
    schema1:alternateName "ENIGMA" ;
    schema1:description """ENIGMA emphasizes achieving a multiscale, causal, and predictive understanding of microbial biology and the reciprocal impact of microbial communities on their ecosystems. Focus on processes affecting denitrification and metal reduction in contaminated subsurface environments.
""" ;
    schema1:keywords "DENITRIFICATION",
        "METAGENOMICS",
        "METAL_REDUCTION",
        "MICROBIAL_ECOSYSTEMS",
        "NITRATE",
        "SUBSURFACE_MICROBIOLOGY",
        "SYSTEMS_BIOLOGY",
        "URANIUM" ;
    schema1:name "ENIGMA: Ecosystems and Networks Integrated with Genes and Molecular Assemblies" ;
    nmdc_sfas_brcs:analyses nmdc_sfas_brcs:enigma_kothari_data,
        nmdc_sfas_brcs:enigma_kothari_isolates ;
    nmdc_sfas_brcs:data_collection_modalities "COMPUTATIONAL_MODELING",
        "HIGH_THROUGHPUT_SEQUENCING",
        "IMAGING",
        "MASS_SPECTROMETRY",
        "SYNCHROTRON_METHODS" ;
    nmdc_sfas_brcs:data_types OBI:0000366,
        OBI:0000424,
        OBI:0000615,
        OBI:0002623,
        "ENVIRONMENTAL_SENSOR_DATA",
        "STRUCTURAL_BIOLOGY" ;
    nmdc_sfas_brcs:datasets [ a nmdc_sfas_brcs:Dataset ;
            schema1:description "Multi-omics data from Oak Ridge Reservation subsurface" ;
            schema1:name "ENIGMA Environmental Data" ;
            nmdc_sfas_brcs:data_type "metagenomics/environmental" ;
            nmdc_sfas_brcs:repository "KBase" ] ;
    nmdc_sfas_brcs:field_sites [ a nmdc_sfas_brcs:FieldSite ;
            schema1:description "Bear Creek aquifer with complex contaminant gradients" ;
            schema1:name "Oak Ridge Reservation (ORR)" ;
            nmdc_sfas_brcs:contaminants "nitrates",
                "uranium",
                "volatile organic carbon species" ;
            nmdc_sfas_brcs:location "East Tennessee" ] ;
    nmdc_sfas_brcs:funding [ a nmdc_sfas_brcs:FundingInfo ;
            nmdc_sfas_brcs:agency "DOE BER" ;
            nmdc_sfas_brcs:division "Biological Systems Science Division" ;
            nmdc_sfas_brcs:program "Genomic Science Program" ] ;
    nmdc_sfas_brcs:isolate_collections [ a nmdc_sfas_brcs:IsolateCollection ;
            schema1:description "Bacterial and archaeal isolates from Oak Ridge Reservation subsurface environments including contaminated groundwater and sediments. Characterized for stress tolerance and denitrification/metal reduction capabilities." ;
            schema1:name "ENIGMA Subsurface Isolates" ;
            nmdc_sfas_brcs:genome_catalog_url "https://kbase.us/n/63776/35/"^^xsd:anyURI ;
            nmdc_sfas_brcs:genome_count 261 ;
            nmdc_sfas_brcs:isolate_count 261 ;
            nmdc_sfas_brcs:isolation_methods "Aerobic plating",
                "Anaerobic enrichment" ;
            nmdc_sfas_brcs:kbase_narrative_id "63776" ;
            nmdc_sfas_brcs:organism_types NCBITaxon:2,
                NCBITaxon:2157 ;
            nmdc_sfas_brcs:primary_reference_info [ a nmdc_sfas_brcs:PrimaryReferenceInfo ;
                    nmdc_sfas_brcs:reference <https://doi.org/10.1128/msystems.00537-21> ;
                    nmdc_sfas_brcs:relationship_note "Describes the 261 ENIGMA bacterial isolates used for phage host prediction" ] ;
            nmdc_sfas_brcs:source_environments "Aquifer sediments",
                "Contaminated groundwater",
                "Oak Ridge subsurface" ] ;
    nmdc_sfas_brcs:kbase_genome_collection "ENIGMA" ;
    nmdc_sfas_brcs:key_publications <https://doi.org/10.1038/s41564-023-01573-x>,
        <https://doi.org/10.2172/1963932> ;
    nmdc_sfas_brcs:lead_institution "Lawrence Berkeley National Laboratory" ;
    nmdc_sfas_brcs:phenotype_assays "ANAEROBIC_GROWTH",
        "COCULTURE_INTERACTIONS",
        "GROWTH_CURVES",
        "RBTSEQ_FITNESS",
        "STRESS_TOLERANCE",
        "SUBSTRATE_UTILIZATION" ;
    nmdc_sfas_brcs:principal_investigators [ a schema1:Person ;
            schema1:name "Paul D. Adams" ;
            nmdc_sfas_brcs:affiliation "Lawrence Berkeley National Laboratory" ;
            nmdc_sfas_brcs:role "Project Manager" ],
        [ a schema1:Person ;
            schema1:name "Adam P. Arkin" ;
            nmdc_sfas_brcs:affiliation "Lawrence Berkeley National Laboratory" ;
            nmdc_sfas_brcs:role "Technical Co-manager" ] ;
    nmdc_sfas_brcs:program_type "SCIENTIFIC_FOCUS_AREA" ;
    nmdc_sfas_brcs:scientific_questions "How do microbial communities respond to contamination?",
        "How do microbial networks drive macroscopic biogeochemical processes?",
        "What controls denitrification and metal reduction in subsurface?",
        "What mechanisms drive subcellular, cellular, and intercellular networks?" ;
    nmdc_sfas_brcs:sfa_type "GENOMIC_SCIENCE_SFA" ;
    nmdc_sfas_brcs:studies [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "26 subsurface sediment and 9 groundwater metagenomes from the Oak Ridge Reservation studying subsurface microbiome from centimeter to field scale." ;
            schema1:name "Oak Ridge Sediment and Groundwater Metagenomes" ;
            nmdc_sfas_brcs:bioproject_ids "PRJNA1001011" ;
            nmdc_sfas_brcs:data_modalities OBI:0002623 ;
            nmdc_sfas_brcs:nmdc_ingest_priority "MEDIUM" ;
            nmdc_sfas_brcs:nmdc_ingest_target true ;
            nmdc_sfas_brcs:organism "groundwater metagenome" ;
            nmdc_sfas_brcs:pi "Lauren M. Lui" ;
            nmdc_sfas_brcs:primary_reference_info [ a nmdc_sfas_brcs:PrimaryReferenceInfo ;
                    nmdc_sfas_brcs:reference <https://doi.org/10.1128/mra.00014-25> ] ],
        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Genome-resolved metagenomic analysis of archaeal diversity in subsurface environments. Identified two new phyla (DPANN superphylum) from aquifer adjacent to Colorado River." ;
            schema1:name "ENIGMA Groundwater Archaeal Diversity" ;
            nmdc_sfas_brcs:bioproject_ids "PRJNA268032" ;
            nmdc_sfas_brcs:data_modalities OBI:0002623 ;
            nmdc_sfas_brcs:nmdc_ingest_priority "MEDIUM" ;
            nmdc_sfas_brcs:nmdc_ingest_target true ;
            nmdc_sfas_brcs:organism "groundwater metagenome" ;
            nmdc_sfas_brcs:pi "Jillian F. Banfield" ],
        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Comprehensive metagenomic survey of groundwater microbial communities from 100 wells at the Oak Ridge Field Research Center. Examines community assembly processes under environmental stress from contamination gradients." ;
            schema1:name "Oak Ridge Groundwater 100-Well Survey Metagenomes" ;
            nmdc_sfas_brcs:bioproject_ids "PRJNA1001011" ;
            nmdc_sfas_brcs:data_modalities OBI:0002623 ;
            nmdc_sfas_brcs:nmdc_ingest_priority "HIGH" ;
            nmdc_sfas_brcs:nmdc_ingest_target true ;
            nmdc_sfas_brcs:organism "groundwater metagenome" ;
            nmdc_sfas_brcs:pi "Jizhong Zhou" ;
            nmdc_sfas_brcs:primary_reference_info [ a nmdc_sfas_brcs:PrimaryReferenceInfo ;
                    nmdc_sfas_brcs:reference <https://doi.org/10.1038/s41564-023-01573-x> ] ] ;
    nmdc_sfas_brcs:websites [ a nmdc_sfas_brcs:WebResources ;
            nmdc_sfas_brcs:doe_page "https://www.genomicscience.energy.gov/lbnl/"^^xsd:anyURI ;
            nmdc_sfas_brcs:kbase "https://www.kbase.us/research/adams-sfa/"^^xsd:anyURI ;
            nmdc_sfas_brcs:main "https://enigma.lbl.gov"^^xsd:anyURI ] .

