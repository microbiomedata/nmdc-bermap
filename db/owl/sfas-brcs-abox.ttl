<https://doi.org/10.1016/j.csbj.2021.03.034> a nmdc_sfas_brcs:Reference ;
    dcterms:title "CommScores metabolic modeling for microbial community interactions",
        "Formation, characterization and modeling of emergent synthetic microbial communities" ;
    nmdc_sfas_brcs:findings [ a nmdc_sfas_brcs:Finding ;
            nmdc_sfas_brcs:statement "Genome-scale metabolic modeling enables prediction of microbial interactions" ] .

<https://doi.org/10.1038/s41467-023-37164-x> a nmdc_sfas_brcs:Reference ;
    dcterms:title "Core metabolome and root exudation dynamics of three phylogenetically distinct plant species",
        "The core metabolome and root exudation dynamics of three phylogenetically distinct plant species" ;
    nmdc_sfas_brcs:findings [ a nmdc_sfas_brcs:Finding ;
            nmdc_sfas_brcs:statement "Identified core metabolome shared across phylogenetically distinct plant species" ] .

<https://doi.org/10.1038/s41467-023-42967-z> a nmdc_sfas_brcs:Reference ;
    dcterms:title "Hi-C Metagenome Sequencing Reveals Soil Moisture Impacts on Phage-Host Interactions",
        "Hi-C metagenome sequencing reveals soil phage–host interactions" ;
    nmdc_sfas_brcs:findings [ a nmdc_sfas_brcs:Finding ;
            nmdc_sfas_brcs:statement "High-throughput chromosomal conformation capture reveals soil moisture controls phage-host dynamics" ] .

<https://doi.org/10.1038/s41564-018-0129-3> a nmdc_sfas_brcs:Reference ;
    dcterms:title "Dynamic root exudate chemistry and microbial substrate preferences drive patterns in rhizosphere microbial community assembly" ;
    nmdc_sfas_brcs:findings [ a nmdc_sfas_brcs:Finding ;
            nmdc_sfas_brcs:statement "Root exudate chemistry dynamically changes over plant development" ],
        [ a nmdc_sfas_brcs:Finding ;
            nmdc_sfas_brcs:statement "Microbial substrate preferences drive rhizosphere community assembly patterns" ] .

<https://doi.org/10.1038/s41564-023-01573-x> a nmdc_sfas_brcs:Reference ;
    dcterms:title "Environmental stress mediates groundwater microbial community assembly" ;
    nmdc_sfas_brcs:findings [ a nmdc_sfas_brcs:Finding ;
            nmdc_sfas_brcs:statement "Selection processes leading to dissimilar communities increased with stresses, primarily related to pH, cobalt and molybdenum." ],
        [ a nmdc_sfas_brcs:Finding ;
            nmdc_sfas_brcs:statement "Stochastic assembly processes are critical (>60% on average) in shaping groundwater community structure, but decrease in importance as environmental stress increases." ] .

