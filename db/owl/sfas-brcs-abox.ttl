nmdc_sfas_brcs:seed a nmdc_sfas_brcs:ScientificFocusArea ;
    schema1:alternateName "SEED" ;
    schema1:description "SEED develops predictive understanding of how microorganisms establish, spread, and influence ecosystems critical to DOE missions. Combines expertise in microbiology, plant biology, ecology, genetic engineering, and computational sciences. Currently deploying biodesign tools in the plant growth-promoting bacteria Bacillus velezensis to improve Populus resistance to the pathogenic fungus Sphaerulina musiva." ;
    schema1:keywords "BIODEFENSE",
        "BIOSECURITY",
        "BIOSYSTEMS_DESIGN",
        "CRISPR",
        "ECOSYSTEM_ENGINEERING",
        "FUNGAL_PATHOGENS",
        "MICROBIAL_INVASION",
        "RHIZOSPHERE" ;
    schema1:name "SEED: Secure Ecosystem Engineering and Design" ;
