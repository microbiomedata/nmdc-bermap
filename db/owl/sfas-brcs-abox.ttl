    nmdc_sfas_brcs:program_type "BIOENERGY_RESEARCH_CENTER" ;
    nmdc_sfas_brcs:scientific_questions "How can we engineer crops to produce oils and specialty chemicals?",
        "How do land use changes affect carbon and ecosystem services?",
        "How do we optimize lipid accumulation in vegetative tissues?",
        "What are sustainable approaches to bioenergy crop production?",
        "What conversion technologies maximize bioproduct yields?" ;
    nmdc_sfas_brcs:studies [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Survey of the native Miscanthus rhizosphere and endophytic microbiome in Taiwan, with particular attention to the diazotrophic community across strong biogeographical and ecological gradients in Miscanthus sinensis and M. floridulus." ;
            schema1:name "Native Miscanthus Rhizosphere and Endophytic Microbiome" ;
