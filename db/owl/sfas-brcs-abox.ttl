        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "SSU rRNA RNA library of soil microbiome at LAMPS. Complements DNA-based study examining total vs metabolically active microbial communities under nitrogen fertilization." ;
            schema1:name "Soil Microbiome of Miscanthus × giganteus at LAMPS Study Site" ;
            nmdc_sfas_brcs:bioproject_ids "PRJNA745191" ;
