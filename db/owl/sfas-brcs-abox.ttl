nmdc_sfas_brcs:microbes_persist a nmdc_sfas_brcs:ScientificFocusArea ;
    schema1:alternateName "Microbes Persist" ;
    schema1:description """The Microbes Persist SFA aims to understand how microbes shape soil carbon persistence. Using stable isotope-informed approaches, the team characterizes the "active" microbiome and virome, scaling from metagenomes to computational models integrating traits at system scale.
""" ;
    schema1:keywords "CARBON_PERSISTENCE",
        "MOISTURE_REGIMES",
        "NANOSIMS",
        "QSIP",
        "SOIL_CARBON",
        "SOIL_MICROBIOME",
        "SOIL_ORGANIC_MATTER",
        "STABLE_ISOTOPES",
        "VIROME" ;
    schema1:name "Microbes Persist: Systems Biology of the Soil Microbiome" ;
    nmdc_sfas_brcs:data_collection_modalities "IMAGING",
        "MULTI_OMICS",
        "RADIOISOTOPE_APPROACHES",
        "STABLE_ISOTOPE_PROBING" ;
    nmdc_sfas_brcs:data_types OBI:0002623,
        "IMAGING_DATA",
        "METATRANSCRIPTOMICS",
        "RADIOCARBON_DATA",
        "STABLE_ISOTOPE_DATA" ;
    nmdc_sfas_brcs:datasets [ a nmdc_sfas_brcs:Dataset ;
            schema1:description "Microbial genome bins and annotations from qSIP metagenomics" ;
            schema1:name "Microbes Persist qSIP Metagenome Bins" ;
            schema1:url "https://ggkbase.berkeley.edu/wsip-metawrap-drep-bins/organisms"^^xsd:anyURI ;
            nmdc_sfas_brcs:repository "ggKbase" ] ;
    nmdc_sfas_brcs:established 2017 ;
    nmdc_sfas_brcs:funding [ a nmdc_sfas_brcs:FundingInfo ;
            nmdc_sfas_brcs:agency "DOE BER" ;
            nmdc_sfas_brcs:division "Biological Systems Science Division" ;
            nmdc_sfas_brcs:program "Genomic Science Program" ] ;
    nmdc_sfas_brcs:key_publications <https://doi.org/10.1038/s41564-023-01582-w>,
        <https://doi.org/10.1073/pnas.2413032122>,
        <https://doi.org/10.1128/msystems.00417-22> ;
    nmdc_sfas_brcs:lead_institution "Lawrence Livermore National Laboratory" ;
    nmdc_sfas_brcs:nmdc_umbrella_study "nmdc:sty-11-msexsy29"^^xsd:anyURI ;
    nmdc_sfas_brcs:partner_institutions "Lawrence Berkeley National Laboratory",
        "Northern Arizona University",
        "Pacific Northwest National Laboratory",
        "University of California, Berkeley",
        "University of California, Davis",
        "University of Minnesota" ;
    nmdc_sfas_brcs:phenotype_assays "GROWTH_CURVES",
        "NANOSIMS_ACTIVITY",
        "QSIP_ACTIVITY",
        "RESPIRATION",
        "SOIL_INCUBATION" ;
    nmdc_sfas_brcs:principal_investigators [ a schema1:Person ;
            schema1:name "Jennifer Pett-Ridge" ;
            nmdc_sfas_brcs:affiliation "Lawrence Livermore National Laboratory" ;
            nmdc_sfas_brcs:role "Principal Investigator" ] ;
    nmdc_sfas_brcs:program_type "SCIENTIFIC_FOCUS_AREA" ;
    nmdc_sfas_brcs:scientific_questions "How do microbial cellular chemistry and ecophysiology shape soil C persistence?",
        "How do moisture regimes affect microbial transformations?",
        "What mechanisms regulate soil organic matter stabilization?",
        "What role do viruses play in soil carbon cycling?" ;
    nmdc_sfas_brcs:sfa_type "GENOMIC_SCIENCE_SFA" ;
    nmdc_sfas_brcs:studies [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Novel method for radiocarbon analysis of soil microbial biomass via direct chloroform extraction. Enables measurement of microbial C turnover." ;
            schema1:name "Radiocarbon Analysis of Soil Microbial Biomass" ;
            nmdc_sfas_brcs:data_modalities "RADIOCARBON_DATA",
                "STABLE_ISOTOPE_DATA" ;
            nmdc_sfas_brcs:nmdc_ingest_target true ;
            nmdc_sfas_brcs:pi "Jennifer Pett-Ridge" ;
            nmdc_sfas_brcs:primary_reference_info [ a nmdc_sfas_brcs:PrimaryReferenceInfo ;
                    nmdc_sfas_brcs:reference <https://doi.org/10.1017/RDC.2023.80> ] ],
        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Quantitative stable isotope probing with metagenomics linking microbial physiology and activity to soil moisture in Mediterranean-climate grassland ecosystems." ;
            schema1:name "California Grassland qSIP Metagenomes" ;
            nmdc_sfas_brcs:bioproject_ids "PRJNA718849" ;
            nmdc_sfas_brcs:data_modalities OBI:0002623,
