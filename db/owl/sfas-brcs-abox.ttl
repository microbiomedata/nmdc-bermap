nmdc_sfas_brcs:pnnl_soil_microbiome a nmdc_sfas_brcs:ScientificFocusArea ;
    schema1:alternateName "Soil Microbiome SFA" ;
    schema1:description """PNNL's Soil Microbiome SFA focuses on understanding how interactions among soil microbial community members lead to emergence of community functions. Research identifies molecular-level metabolic interactions governing decomposition and moisture effects on microbial phenotypes.
""" ;
    schema1:keywords "CARBON_USE_EFFICIENCY",
        "DECOMPOSITION",
        "METAPHENOME",
        "MICROBIAL_INTERACTIONS",
        "MOISTURE_EFFECTS",
        "SOIL_MICROBIOME",
        "TALL_WHEATGRASS" ;
    schema1:name "Phenotypic Response of the Soil Microbiome to Environmental Perturbations" ;
    nmdc_sfas_brcs:data_collection_modalities "IMAGING",
        "LABORATORY_EXPERIMENTS",
        "METAGENOMICS" ;
    nmdc_sfas_brcs:data_types OBI:0000366,
        OBI:0002623,
        "IMAGING_DATA" ;
    nmdc_sfas_brcs:datasets [ a nmdc_sfas_brcs:Dataset ;
            schema1:name "PNNL Soil Microbiome SFA Data" ;
            schema1:url "https://data.pnnl.gov/Soil_SFA"^^xsd:anyURI ;
            nmdc_sfas_brcs:doi "10.25584/PRJ.SFA/1780765"^^xsd:anyURI ;
            nmdc_sfas_brcs:repository "PNNL DataHub" ] ;
    nmdc_sfas_brcs:field_sites [ a nmdc_sfas_brcs:FieldSite ;
            schema1:description "Testing discoveries in bioenergy feedstock system" ;
            schema1:name "Tall Wheatgrass Irrigation Trial" ] ;
    nmdc_sfas_brcs:funding [ a nmdc_sfas_brcs:FundingInfo ;
            nmdc_sfas_brcs:agency "DOE BER" ;
            nmdc_sfas_brcs:area "Environmental Microbiome Science" ;
            nmdc_sfas_brcs:program "Genomic Science Program" ] ;
    nmdc_sfas_brcs:key_publications <https://doi.org/10.1038/s41467-023-42967-z>,
        <https://doi.org/10.1038/s41564-024-01686-x>,
        <https://doi.org/10.1128/mbio.01758-23>,
        <https://doi.org/10.1186/s40168-022-01427-4>,
        <https://doi.org/10.3390/microorganisms11112630> ;
    nmdc_sfas_brcs:lead_institution "Pacific Northwest National Laboratory" ;
    nmdc_sfas_brcs:phenotype_assays "EXOMETABOLOMICS",
        "RESPIRATION",
        "SOIL_INCUBATION",
        "SUBSTRATE_UTILIZATION" ;
    nmdc_sfas_brcs:principal_investigators [ a schema1:Person ;
            schema1:name "Kirsten Hofmockel" ;
            nmdc_sfas_brcs:affiliation "Pacific Northwest National Laboratory" ;
            nmdc_sfas_brcs:role "Principal Investigator" ] ;
    nmdc_sfas_brcs:program_type "SCIENTIFIC_FOCUS_AREA" ;
    nmdc_sfas_brcs:scientific_questions "How do microbial interactions lead to emergent community functions?",
        "How does soil desiccation affect metabolic processes?",
        "What controls carbon use efficiency in soils?",
        "What predictable reaction modules exist based on resource availability?" ;
    nmdc_sfas_brcs:sfa_type "GENOMIC_SCIENCE_SFA" ;
    nmdc_sfas_brcs:studies [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Estimating the importance of viral contributions to soil carbon dynamics through metagenomics. Published in Global Change Biology 2024." ;
            schema1:name "Viral Contributions to Soil Carbon Dynamics" ;
            nmdc_sfas_brcs:data_modalities OBI:0002623 ;
            nmdc_sfas_brcs:nmdc_ingest_target true ;
            nmdc_sfas_brcs:pi "Kirsten Hofmockel" ;
            nmdc_sfas_brcs:primary_reference_info [ a nmdc_sfas_brcs:PrimaryReferenceInfo ;
                    nmdc_sfas_brcs:reference <https://doi.org/10.1111/gcb.17524> ] ],
        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Influence of soil depth, irrigation, and plant genotype on the soil microbiome, metaphenome, and carbon chemistry. Multi-omics study published in mBio 2023." ;
            schema1:name "Soil Microbiome Response to Depth, Irrigation and Plant Genotype" ;
            nmdc_sfas_brcs:data_modalities OBI:0000366,
                OBI:0000615,
                OBI:0002623 ;
            nmdc_sfas_brcs:nmdc_ingest_target true ;
            nmdc_sfas_brcs:pi "Kirsten Hofmockel" ;
            nmdc_sfas_brcs:primary_reference_info [ a nmdc_sfas_brcs:PrimaryReferenceInfo ;
                    nmdc_sfas_brcs:reference <https://doi.org/10.1128/mbio.01758-23> ] ],
        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "High-throughput chromosomal conformation capture (Hi-C) metagenome sequencing revealing soil moisture impacts on phage-host interactions. Published in Nature Comm 2023." ;
            schema1:name "Hi-C Metagenome Sequencing of Soil Moisture Impacts on Phage-Host Interactions" ;
            nmdc_sfas_brcs:data_modalities OBI:0002623 ;
            nmdc_sfas_brcs:nmdc_ingest_target true ;
            nmdc_sfas_brcs:pi "Kirsten Hofmockel" ;
            nmdc_sfas_brcs:primary_reference_info [ a nmdc_sfas_brcs:PrimaryReferenceInfo ;
