        "How do plant-microbe interactions affect feedstock quality?",
        "How do we accelerate domestication of perennial bioenergy crops?",
        "What genetic factors control biomass recalcitrance?",
        "What processes enable sustainable aviation fuel production?" ;
    nmdc_sfas_brcs:studies [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Characterization of fungal and bacterial community assembly from root to shoot axis in poplar (P. tremula x tremuloides) over 30 days of growth, tracking changes in rhizosphere, root and shoot by DNA metabarcoding alongside metabolomics." ;
            schema1:name "Poplar Rhizosphere Microbiota Assembly Dynamics" ;
