nmdc_sfas_brcs:cbi a OBI:0000835 ;
    schema1:alternateName "CBI" ;
    schema1:description """CBI focuses on accelerating the domestication of bioenergy-relevant non-model plants and microbes to enable high-impact innovation across the sustainable aviation fuel supply chain. The center develops high-yielding, process-advantaged feedstock plants using advanced genetic technologies.
""" ;
    schema1:keywords "BIOMASS_RECALCITRANCE",
        "GENOMIC_SELECTION",
        "LIGNIN",
        "MICROBIAL_CONVERSION",
        "PERENNIAL_CROPS",
        "POPLAR",
        "POPULUS",
        "SUSTAINABLE_AVIATION_FUEL",
        "SWITCHGRASS" ;
    schema1:name "Center for Bioenergy Innovation" ;
    nmdc_sfas_brcs:data_collection_modalities "COMMON_GARDEN_EXPERIMENTS",
        "FERMENTATION_STUDIES",
        "FIELD_TRIALS",
        "GENOME_WIDE_ASSOCIATION",
        "HIGH_THROUGHPUT_PHENOTYPING" ;
