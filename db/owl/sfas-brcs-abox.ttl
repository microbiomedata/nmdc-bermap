            nmdc_sfas_brcs:main "https://ess-dive.lbl.gov"^^xsd:anyURI ] .

nmdc_sfas_brcs:floodplain_sfa a nmdc_sfas_brcs:ScientificFocusArea ;
    schema1:description """The Floodplain Hydro-Biogeochemistry SFA investigates how subsurface interfaces mediate molecular-scale biogeochemical processes and groundwater quality. Research focuses on microbial and geochemical responses to hydrological processes in floodplain systems.
""" ;
    schema1:keywords "CAPILLARY_FRINGE",
        "COLLOID_TRANSPORT",
        "FLOODPLAIN",
        "GROUNDWATER_QUALITY",
        "REDOX_CYCLING",
        "SUBSURFACE_INTERFACES" ;
    schema1:name "Floodplain Hydro-Biogeochemistry Science Focus Area" ;
    nmdc_sfas_brcs:data_types "BIOGEOCHEMICAL_DATA",
        "ECONOMIC_MODELING_DATA",
        "GROUNDWATER_CHEMISTRY",
        "STRUCTURAL_BIOLOGY" ;
    nmdc_sfas_brcs:field_sites [ a nmdc_sfas_brcs:FieldSite ;
            schema1:name "Riverton Floodplain" ;
            nmdc_sfas_brcs:location "Wyoming" ],
        [ a nmdc_sfas_brcs:FieldSite ;
            schema1:description """Alluvial aquifer underlying Slate River with fine-grained soil overlying cobble/gravel alluvium (3600 m² interface)
""" ;
            schema1:name "Crested Butte Floodplain" ;
            nmdc_sfas_brcs:location "Colorado" ] ;
    nmdc_sfas_brcs:funding [ a nmdc_sfas_brcs:FundingInfo ;
            nmdc_sfas_brcs:agency "DOE BER" ;
            nmdc_sfas_brcs:program "Environmental System Science (ESS)" ] ;
    nmdc_sfas_brcs:key_publications <https://doi.org/10.1038/ngeo2940> ;
    nmdc_sfas_brcs:lead_institution "SLAC National Accelerator Laboratory" ;
    nmdc_sfas_brcs:principal_investigators [ a schema1:Person ;
            schema1:name "Scott Fendorf" ;
            nmdc_sfas_brcs:affiliation "Stanford University / SLAC" ] ;
    nmdc_sfas_brcs:program_type "SCIENTIFIC_FOCUS_AREA" ;
    nmdc_sfas_brcs:scientific_questions "How do subsurface interfaces mediate biogeochemical processes?",
        "How do wet-dry cycles affect redox processes and carbon mobilization?",
        "What controls groundwater quality in floodplain systems?",
        "What mechanisms control colloid generation and transport?" ;
    nmdc_sfas_brcs:sfa_type "ENVIRONMENTAL_SYSTEM_SCIENCE_SFA" ;
    nmdc_sfas_brcs:websites [ a nmdc_sfas_brcs:WebResources ;
            nmdc_sfas_brcs:doe_page "https://ess.science.energy.gov/slac-floodplain-sfa/"^^xsd:anyURI ;
            nmdc_sfas_brcs:main "https://web.slac.stanford.edu/sfagroup/"^^xsd:anyURI ;
            nmdc_sfas_brcs:ssrl_page "https://www-ssrl.slac.stanford.edu/sfa/floodplain-hydro-biogeochemistry-sfa-research-program"^^xsd:anyURI ] .

nmdc_sfas_brcs:glbrc a OBI:0000835 ;
    schema1:alternateName "GLBRC" ;
    schema1:description """GLBRC is a cross-disciplinary research center developing sustainable biofuels and bioproducts from dedicated energy crops grown on marginal, nonagricultural lands. Research spans three crosscutting themes: sustainable bioenergy cropping systems, sustainable biomass conversion, and sustainable field-to-product optimization.
""" ;
    schema1:keywords "BIOENERGY",
        "BIOFUELS",
        "CELLULOSIC_BIOMASS",
        "ENERGY_SORGHUM",
        "LIGNOCELLULOSE",
        "MARGINAL_LANDS",
        "MICROBIAL_CONVERSION",
        "MISCANTHUS",
        "POPLAR",
        "SUSTAINABILITY",
        "SWITCHGRASS" ;
