        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Investigation of soil microorganisms along 1 meter soil profiles in Miscanthus × giganteus, examining distinct mechanisms driving plant-nitrifier interactions at different depths." ;
            schema1:name "Plant-Nitrifier Interactions in Topsoil and Subsoil" ;
            nmdc_sfas_brcs:bioproject_ids "PRJNA1080623" ;
            nmdc_sfas_brcs:data_modalities OBI:0002763 ;
            nmdc_sfas_brcs:nmdc_ingest_priority "MEDIUM" ;
            nmdc_sfas_brcs:organism "Miscanthus × giganteus" ;
            nmdc_sfas_brcs:pi "Wendy Yang" ;
