        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Real-time and rapid respiratory response (90 seconds to 90 minutes) of the soil microbiome to moisture shifts. Published in Microorganisms 2023." ;
            schema1:name "Birch Effect Respiratory Response of Soil Microbiome" ;
            nmdc_sfas_brcs:data_modalities OBI:0000366 ;
            nmdc_sfas_brcs:nmdc_ingest_target true ;
            nmdc_sfas_brcs:pi "Kirsten Hofmockel" ;
