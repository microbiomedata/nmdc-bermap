nmdc_sfas_brcs:brave_sorghum_anthracnose a nmdc_sfas_brcs:OtherProgram ;
    schema1:alternateName "SABI" ;
    schema1:description "BRaVE project investigating molecular interactions between sorghum (a bioenergy crop), its anthracnose-disease causative fungal pathogen Colletotrichum sublineola (Cs), and antifungal biocontrol bacteria to create disease-resilient bioenergy crops. Uses computational and experimental approaches to study plant-pathosystem interactions." ;
    schema1:keywords "BIODEFENSE",
        "BIOENERGY_CROPS",
        "BIOSECURITY",
        "FUNGAL_PATHOGENS",
        "PLANT_MICROBE_INTERACTIONS",
        "SORGHUM" ;
    schema1:name "Sorghum-Anthracnose-Biocontrol Interactions" ;
    nmdc_sfas_brcs:data_types OBI:0000366,
        OBI:0000424,
        OBI:0002623 ;
    nmdc_sfas_brcs:funding [ a nmdc_sfas_brcs:FundingInfo ;
            nmdc_sfas_brcs:agency "DOE BER" ;
            nmdc_sfas_brcs:program "Biopreparedness Research Virtual Environment (BRaVE)" ] ;
    nmdc_sfas_brcs:funding_period "2023-2026" ;
    nmdc_sfas_brcs:initiative_name "BRaVE" ;
    nmdc_sfas_brcs:isolate_collections [ a nmdc_sfas_brcs:IsolateCollection ;
            schema1:description "Colletotrichum sublineola isolates causing anthracnose disease in sorghum." ;
            schema1:name "Colletotrichum Pathogen Collection" ;
            nmdc_sfas_brcs:organism_types NCBITaxon:4751 ;
            nmdc_sfas_brcs:source_environments "Infected sorghum tissue" ],
        [ a nmdc_sfas_brcs:IsolateCollection ;
            schema1:description "Bacterial isolates with biocontrol activity against Colletotrichum sublineola, collected from sorghum rhizosphere and phyllosphere." ;
            schema1:name "Sorghum-Associated Bacterial Collection" ;
            nmdc_sfas_brcs:host_organisms "Sorghum bicolor" ;
            nmdc_sfas_brcs:organism_types NCBITaxon:2 ;
            nmdc_sfas_brcs:source_environments "Sorghum phyllosphere",
                "Sorghum rhizosphere" ] ;
    nmdc_sfas_brcs:lead_institution "Lawrence Berkeley National Laboratory" ;
    nmdc_sfas_brcs:participating_offices "ASCR",
        "BER" ;
    nmdc_sfas_brcs:phenotype_assays "BACTERIAL_FUNGAL_INTERACTION_ASSAY",
        "COMPETITION_ASSAYS",
        "GROWTH_CURVES",
        "PLANT_COLONIZATION" ;
    nmdc_sfas_brcs:principal_investigators [ a schema1:Person ;
            schema1:name "Trent Northen" ;
