            nmdc_sfas_brcs:main "https://microbiomedata.org"^^xsd:anyURI ] .

nmdc_sfas_brcs:pmi a nmdc_sfas_brcs:ScientificFocusArea ;
    schema1:alternateName "PMI" ;
    schema1:description """PMI reveals mechanistic bases underpinning selection of symbiotic plant-microbe partnerships and how environment structures the host plant's microbiome. Various Populus species (eastern cottonwood, black cottonwood, aspen) serve as model hosts for bioenergy research.
""" ;
    schema1:keywords "BIOENERGY_CROPS",
        "ENDOPHYTES",
        "MYCORRHIZAE",
