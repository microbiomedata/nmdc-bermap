nmdc_sfas_brcs:jbei a OBI:0000835 ;
    schema1:alternateName "JBEI" ;
    schema1:description """JBEI is dedicated to developing advanced biofuels—liquid fuels derived from solar energy stored in plant biomass—that can replace gasoline, diesel, and jet fuels. JBEI takes an interdisciplinary approach combining expertise in synthetic biology, plant biology, and chemical engineering.
""" ;
