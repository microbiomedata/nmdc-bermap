            nmdc_sfas_brcs:agency "DOE BER" ;
            nmdc_sfas_brcs:area "Secure Biosystems Design" ;
            nmdc_sfas_brcs:program "Genomic Science Program" ] ;
    nmdc_sfas_brcs:key_publications <https://doi.org/10.1016/j.copbio.2020.10.007>,
