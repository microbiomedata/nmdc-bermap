        [ a schema1:Person ;
            schema1:name "Edward O'Loughlin" ;
            nmdc_sfas_brcs:affiliation "Argonne National Laboratory" ;
            nmdc_sfas_brcs:expertise "Biogeochemistry, Environmental Chemistry/Microbiology" ;
            nmdc_sfas_brcs:role "Co-PI" ],
        [ a schema1:Person ;
            schema1:name "John Seaman" ;
            nmdc_sfas_brcs:affiliation "Savannah River Ecology Laboratory, University of Georgia" ],
        [ a schema1:Person ;
            schema1:name "Dan Kaplan" ;
            nmdc_sfas_brcs:affiliation "Savannah River National Laboratory" ;
            nmdc_sfas_brcs:expertise "Soil Science" ] ;
    nmdc_sfas_brcs:field_sites [ a nmdc_sfas_brcs:FieldSite ;
            schema1:description """Riparian wetland representative of many in humid regions of the Southeast US
""" ;
            schema1:name "Savannah River Site Riparian Wetland" ;
            nmdc_sfas_brcs:location "Aiken, South Carolina" ] ;
    nmdc_sfas_brcs:funding [ a nmdc_sfas_brcs:FundingInfo ;
            nmdc_sfas_brcs:agency "DOE BER" ;
            nmdc_sfas_brcs:program "Environmental System Science (ESS)" ;
            nmdc_sfas_brcs:subprogram "Subsurface Biogeochemical Research" ] ;
    nmdc_sfas_brcs:lead_institution "Argonne National Laboratory" ;
    nmdc_sfas_brcs:partner_institutions "Bulgarian Academy of Science",
        "Illinois Institute of Technology",
        "Savannah River National Laboratory",
        "University of Georgia (Savannah River Ecology Laboratory)" ;
    nmdc_sfas_brcs:principal_investigators [ a schema1:Person ;
            schema1:name "Ken Kemner" ;
