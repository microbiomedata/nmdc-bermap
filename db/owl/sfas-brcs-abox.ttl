nmdc_sfas_brcs:imagine_biosecurity a nmdc_sfas_brcs:ScientificFocusArea ;
    schema1:alternateName "IMAGINE" ;
    schema1:description """IMAGINE develops an integrative biocontainment platform to build, characterize, and predictively design biocontainment in microbial systems. The SFA integrates synthetic biology, computational modeling, and plant-soil microbiology for secure biosystems design.
""" ;
    schema1:keywords "BIOCONTAINMENT",
        "BIOSECURITY",
        "COMBIGEM",
        "DNA_BARCODING",
        "GENOME_ENGINEERING",
        "MICROBIAL_CHASSIS",
        "SYNTHETIC_BIOLOGY" ;
    schema1:name "IMAGINE BioSecurity: Integrative Modeling and Genome-Scale Engineering for Biosystems Security" ;
    nmdc_sfas_brcs:data_collection_modalities "GENOME_SCALE_ENGINEERING",
        "HIGH_THROUGHPUT_SCREENING",
        "HIGH_THROUGHPUT_SEQUENCING" ;
    nmdc_sfas_brcs:data_types OBI:0000626,
        "CONTAINMENT_EFFICACY_DATA",
        "FITNESS_DATA" ;
    nmdc_sfas_brcs:funding [ a nmdc_sfas_brcs:FundingInfo ;
            nmdc_sfas_brcs:agency "DOE BER" ;
            nmdc_sfas_brcs:area "Secure Biosystems Design" ;
            nmdc_sfas_brcs:contract "DE-AC36-08GO28308" ;
            nmdc_sfas_brcs:program "Genomic Science Program" ] ;
    nmdc_sfas_brcs:key_publications <https://doi.org/10.1007/s00248-023-02305-2>,
        <https://doi.org/10.1016/j.copbio.2021.05.004>,
        <https://doi.org/10.1021/acssynbio.3c00175>,
        <https://doi.org/10.3389/fpls.2022.839446> ;
    nmdc_sfas_brcs:lead_institution "National Renewable Energy Laboratory" ;
    nmdc_sfas_brcs:partner_institutions "J. Craig Venter Institute",
        "University of California, San Diego" ;
    nmdc_sfas_brcs:program_type "SCIENTIFIC_FOCUS_AREA" ;
    nmdc_sfas_brcs:scientific_questions "How can genome-scale engineering enable secure deployment?",
        "How do we achieve predictive control of engineered biosystems?",
        "What biocontainment strategies maintain fitness and productivity?",
        "What tracking mechanisms ensure biosecurity?" ;
    nmdc_sfas_brcs:sfa_type "GENOMIC_SCIENCE_SFA" ;
    nmdc_sfas_brcs:websites [ a nmdc_sfas_brcs:WebResources ;
            nmdc_sfas_brcs:doe_page "https://www.genomicscience.energy.gov/nrel-imagine/"^^xsd:anyURI ] .

