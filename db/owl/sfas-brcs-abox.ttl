            schema1:description "High-quality reference genome assembly for switchgrass (Panicum virgatum), the preeminent American perennial C4 bioenergy crop for cellulosic ethanol. Genome assembly based on 732 resequenced genotypes grown across 10 common gardens spanning 1,800 km of latitude." ;
            schema1:name "Switchgrass Reference Genome" ;
            schema1:url "https://phytozome.jgi.doe.gov/"^^xsd:anyURI ;
