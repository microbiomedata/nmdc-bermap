            nmdc_sfas_brcs:role "Principal Investigator" ] ;
    nmdc_sfas_brcs:program_type "BIOPREPAREDNESS_INITIATIVE" ;
    nmdc_sfas_brcs:scientific_questions "How can we engineer disease-resilient bioenergy crops?",
        "How do biocontrol bacteria protect sorghum from anthracnose disease?",
        "What molecular mechanisms underlie sorghum-Colletotrichum pathogenic interactions?" ;
    nmdc_sfas_brcs:websites [ a nmdc_sfas_brcs:WebResources ;
            nmdc_sfas_brcs:doe_page "https://www.genomicscience.energy.gov/brave-awards23/"^^xsd:anyURI ] .

nmdc_sfas_brcs:cabbi a OBI:0000835 ;
    schema1:alternateName "CABBI" ;
    schema1:description """CABBI develops fuels and products by integrating feedstock development, conversion science, and sustainability research. Using a "plants as factories" approach, CABBI researchers engineer crops to accumulate lipids and specialty chemicals while developing novel conversion technologies.
""" ;
