nmdc_sfas_brcs:monet a nmdc_sfas_brcs:OtherProgram ;
    schema1:alternateName "MONet" ;
    schema1:description """MONet (Molecular Observation Network) is an open science network developed by EMSL to build a continental-scale database of standardized molecular and microstructural soil data. The initiative aims to advance understanding and prediction of microbially and root-driven inputs in soil ecosystems and terrestrial aerosol processes. MONet collects thousands of soil samples across US ecoregions to develop a comprehensive FAIR database of molecular and microscale information on soil composition, structure, water characteristics, microbial communities, and biogenic emissions. Data is publicly available on EMSL Science Central without embargo. First capability launched February 2023 with the Soil Function soil core solicitation.
""" ;
    schema1:keywords "CARBON_CYCLING",
        "DECOMPOSITION",
        "METAGENOMICS",
        "SOIL_CARBON",
        "SOIL_MICROBIOME",
        "SOIL_ORGANIC_MATTER" ;
    schema1:name "Molecular Observation Network" ;
    nmdc_sfas_brcs:collaborators """Joint Genome Institute (sequencing and metagenome analysis), National Ecological Observatory Network (field sites and continuous sensing), National Microbiome Data Collaborative (microbiome metadata standards)
""" ;
    nmdc_sfas_brcs:data_collection_modalities "FIELD_EXPERIMENTS",
        "IMAGING",
        "LABORATORY_EXPERIMENTS",
        "MASS_SPECTROMETRY",
        "METAGENOMICS" ;
    nmdc_sfas_brcs:data_types OBI:0000366,
        OBI:0002623,
        "BIOGEOCHEMICAL_DATA",
        "IMAGING_DATA",
        "SOIL_MICROBIOME_DATA" ;
    nmdc_sfas_brcs:datasets [ a nmdc_sfas_brcs:Dataset ;
            schema1:description """Comprehensive dataset from MONet 1000 Soils Pilot including geochemistry, texture, respiration, enzyme activities, FTICR-MS organic matter chemistry, microbial biomass C and N, water-extractable organic matter TOC/TDN, X-ray computed tomography metrics, metagenomes, and soil hydraulic properties. Interactive visualization at https://shinyproxy.emsl.pnnl.gov/app/1000soils
""" ;
            schema1:name "1000 Soils Pilot Dataset" ;
            schema1:url "https://zenodo.org/records/15328215"^^xsd:anyURI ;
            nmdc_sfas_brcs:data_type "multi-omics" ;
            nmdc_sfas_brcs:doi "10.5281/zenodo.15328215"^^xsd:anyURI ;
            nmdc_sfas_brcs:repository "Zenodo" ;
            nmdc_sfas_brcs:version "v9" ] ;
    nmdc_sfas_brcs:established 2023 ;
    nmdc_sfas_brcs:field_sites [ a nmdc_sfas_brcs:FieldSite ;
            schema1:description """MONet leverages NEON's 47 terrestrial field sites across 20 ecoclimatic domains spanning the continental United States, Alaska, Hawaii, and Puerto Rico. Sites represent diverse ecosystems including forests, grasslands, shrublands, and wetlands. Each domain has 1-3 terrestrial sites with standardized sampling protocols.
""" ;
            schema1:name "NEON Terrestrial Sites Network" ;
            nmdc_sfas_brcs:location "Continental United States and territories" ],
        [ a nmdc_sfas_brcs:FieldSite ;
            schema1:description "NEON Domain 06 - Prairie grassland site in the Great Plains" ;
            schema1:name "Konza Prairie (KONZ)" ;
            nmdc_sfas_brcs:location "Kansas" ],
        [ a nmdc_sfas_brcs:FieldSite ;
            schema1:description "NEON Domain 03 - Southeast longleaf pine and oak scrub ecosystem" ;
            schema1:name "Ordway-Swisher Biological Station (OSBS)" ;
            nmdc_sfas_brcs:location "Florida" ],
        [ a nmdc_sfas_brcs:FieldSite ;
            schema1:description "NEON Domain 01 - Northeast temperate forest site with archived soil cores" ;
            schema1:name "Harvard Forest (HARV)" ;
            nmdc_sfas_brcs:location "Massachusetts" ] ;
    nmdc_sfas_brcs:funding [ a nmdc_sfas_brcs:FundingInfo ;
            nmdc_sfas_brcs:agency "DOE BER" ;
            nmdc_sfas_brcs:program "Environmental Molecular Sciences Laboratory" ] ;
    nmdc_sfas_brcs:initiative_name "MONet" ;
    nmdc_sfas_brcs:key_publications <https://doi.org/10.1029/2024GL113091>,
        <https://doi.org/10.3389/fsoil.2023.1120425> ;
    nmdc_sfas_brcs:lead_institution "Pacific Northwest National Laboratory" ;
    nmdc_sfas_brcs:principal_investigators [ a schema1:Person ;
            schema1:name "Emily B. Graham" ;
            nmdc_sfas_brcs:affiliation "Pacific Northwest National Laboratory" ;
            nmdc_sfas_brcs:role "Co-Investigator" ],
        [ a schema1:Person ;
            schema1:name "Odeta Qafoku" ;
            nmdc_sfas_brcs:affiliation "Pacific Northwest National Laboratory" ;
            nmdc_sfas_brcs:role "Co-Investigator" ],
        [ a schema1:Person ;
            schema1:name "John Bargar" ;
            nmdc_sfas_brcs:affiliation "Pacific Northwest National Laboratory" ;
            nmdc_sfas_brcs:role "Principal Investigator" ] ;
    nmdc_sfas_brcs:program_type "OTHER_INITIATIVE" ;
    nmdc_sfas_brcs:scientific_questions "How can molecular-scale soil data be integrated into Earth system models?",
        "How do molecular and microscale processes determine whether soil carbon enters the atmosphere or remains sequestered?",
        "What drives microbially and root-driven carbon inputs in soil ecosystems?" ;
    nmdc_sfas_brcs:studies [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description """Advanced soil physical, chemical and biological characterization of soil cores from all ecoregions within the United States through partnership with National Ecological Observatory Network (NEON). Observational sampling September 2023 to July 2024.
""" ;
            schema1:keywords "SOIL_CARBON",
                "SOIL_MICROBIOME" ;
            schema1:name "MONet-NEON First Collection" ;
            nmdc_sfas_brcs:data_modalities OBI:0000366,
                OBI:0002623,
                "BIOGEOCHEMICAL_DATA" ;
            nmdc_sfas_brcs:pi "Sarah Leichty" ;
            nmdc_sfas_brcs:source_reference [ a nmdc_sfas_brcs:WebReference ;
                    nmdc_sfas_brcs:title "Molecular Observation Network (MONet) – First Collection | NSF NEON" ;
                    nmdc_sfas_brcs:url "https://www.neonscience.org/nrss-project/molecular-observation-network-monet-first-collection"^^xsd:anyURI ] ],
        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description """Soil Organic Indicators at Large Scale for Artificial Intelligence campaign targeting ten underrepresented soil orders to strengthen AI models for soil carbon dynamics. Applies pedotransfer functions to upscale measurements to continental scales.
""" ;
            schema1:keywords "CARBON_CYCLING",
                "MACHINE_LEARNING",
                "SOIL_CARBON" ;
            schema1:name "SOILS-AI Campaign" ;
            nmdc_sfas_brcs:data_modalities OBI:0000366,
                OBI:0002623,
                "BIOGEOCHEMICAL_DATA",
                "IMAGING_DATA" ;
            nmdc_sfas_brcs:pi "Sakthi Kumaran" ;
            nmdc_sfas_brcs:source_reference [ a nmdc_sfas_brcs:WebReference ;
                    nmdc_sfas_brcs:title "SOILS-AI Campaign | EMSL" ;
                    nmdc_sfas_brcs:url "https://www.emsl.pnnl.gov/proposals/soil-organic-indicators-large-scale-artificial-intelligence-soils-ai-campaign"^^xsd:anyURI ] ],
        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description """Pilot study collecting standardized soil samples across US ecoregions to develop continental-scale molecular and microstructural soil database. Samples analyzed using FTICR-MS for organic matter composition, X-ray computed tomography for 3D pore structure, and metagenomics via JGI partnership. Includes geochemistry, texture, respiration, enzyme activities, and microbial biomass measurements.
""" ;
            schema1:keywords "CARBON_CYCLING",
                "SOIL_CARBON",
                "SOIL_ORGANIC_MATTER" ;
            schema1:name "1000 Soils Pilot" ;
            nmdc_sfas_brcs:data_modalities OBI:0000366,
                OBI:0002623,
                "BIOGEOCHEMICAL_DATA",
                "IMAGING_DATA" ;
            nmdc_sfas_brcs:pi "Emily B. Graham" ;
            nmdc_sfas_brcs:primary_reference_info [ a nmdc_sfas_brcs:PrimaryReferenceInfo ;
                    nmdc_sfas_brcs:reference <https://doi.org/10.3389/fsoil.2023.1120425> ] ],
        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description """Five selected projects: Douglas-fir forest function (Lutz, Utah State), potato cropland management (Griffin-LaHue, WSU), vegetable cropping nitrogen (Jackson, Stanford), snowpack decline effects (Carbone, NAU), sage scrub recovery (Keller, Claremont McKenna).
""" ;
            schema1:keywords "CARBON_CYCLING",
                "SOIL_CARBON" ;
            schema1:name "MONet Winter Soil Sampling 2024" ;
            nmdc_sfas_brcs:data_modalities OBI:0002623,
                "BIOGEOCHEMICAL_DATA" ;
            nmdc_sfas_brcs:source_reference [ a nmdc_sfas_brcs:WebReference ;
                    nmdc_sfas_brcs:title "EMSL Selects Five Projects for MONet Winter Soil Sampling" ;
                    nmdc_sfas_brcs:url "https://www.emsl.pnnl.gov/news/emsl-selects-five-projects-monet-winter-soil-sampling"^^xsd:anyURI ] ],
        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description """First major MONet capability launched February 2023. Community soil core solicitation with standardized analysis workflows. JGI proposal 510110 for metagenome sequencing.
""" ;
            schema1:keywords "SOIL_CARBON",
                "SOIL_ORGANIC_MATTER" ;
            schema1:name "MONet Soil Function Call" ;
            nmdc_sfas_brcs:data_modalities OBI:0000366,
                OBI:0002623,
                "IMAGING_DATA" ;
            nmdc_sfas_brcs:jgi_proposal_id "510110" ;
            nmdc_sfas_brcs:pi "John Bargar" ;
            nmdc_sfas_brcs:source_reference [ a nmdc_sfas_brcs:WebReference ;
                    nmdc_sfas_brcs:title "MONet Soil Function Call at EMSL DOE User Facility | JGI" ;
                    nmdc_sfas_brcs:url "https://genome.jgi.doe.gov/portal/MONSoiUsFacility/MONSoiUsFacility.info.html"^^xsd:anyURI ] ] ;
    nmdc_sfas_brcs:websites [ a nmdc_sfas_brcs:WebResources ;
            nmdc_sfas_brcs:data_portal "https://sc-data.emsl.pnnl.gov/"^^xsd:anyURI ;
            nmdc_sfas_brcs:main "https://www.emsl.pnnl.gov/monet"^^xsd:anyURI ] .

nmdc_sfas_brcs:nmdc a nmdc_sfas_brcs:UserFacility ;
    schema1:alternateName "NMDC" ;
    schema1:description """NMDC is a pilot initiative to advance microbiome science by building community-driven standards and infrastructure for microbiome data sharing, integration, and analysis.
""" ;
