    nmdc_sfas_brcs:lead_institution "Los Alamos National Laboratory" ;
    nmdc_sfas_brcs:phenotype_assays "BACTERIAL_FUNGAL_INTERACTION_ASSAY",
        "COCULTURE_INTERACTIONS",
        "COMPETITION_ASSAYS",
        "EXOMETABOLOMICS",
        "GROWTH_CURVES",
        "LIVE_CELL_IMAGING" ;
    nmdc_sfas_brcs:principal_investigators [ a schema1:Person ;
