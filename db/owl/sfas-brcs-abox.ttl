            schema1:name "Susan Hubbard" ;
            nmdc_sfas_brcs:affiliation "Lawrence Berkeley National Laboratory" ;
            nmdc_sfas_brcs:role "Lead Research Manager / ESD Director" ] ;
    nmdc_sfas_brcs:program_type "SCIENTIFIC_FOCUS_AREA" ;
    nmdc_sfas_brcs:scientific_questions "How do droughts and early snowmelt impact water availability?",
        "How do hydrological, ecological, and biogeochemical processes interact?",
        "What are the consequences of climate change for headwater systems?",
        "What controls biogeochemical cycling in mountain watersheds?" ;
