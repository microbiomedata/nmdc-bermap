nmdc_sfas_brcs:kbase a nmdc_sfas_brcs:UserFacility ;
    schema1:alternateName "KBase" ;
    schema1:description """KBase is an open-source software and data platform enabling data sharing, integration, and analysis of microbes, plants, and their communities. Provides genomic, metabolic modeling, and multi-omics analysis capabilities.
""" ;
    schema1:name "DOE Systems Biology Knowledgebase" ;
    nmdc_sfas_brcs:capabilities [ a nmdc_sfas_brcs:Capability ;
            schema1:description "Metagenome assembly, binning, and annotation workflows. Applied to build models for over 2,000 MAGs from the GROW (Genome Resolved Open Watersheds) project." ;
            schema1:name "Metagenome Analysis" ;
            nmdc_sfas_brcs:applications "Community metabolic modeling",
                "Genome binning",
                "Metagenome assembly" ;
            nmdc_sfas_brcs:capability_type "METAGENOME_ANALYSIS" ;
            nmdc_sfas_brcs:data_products "Assembled metagenomes",
                "Community models",
                "MAGs" ;
            nmdc_sfas_brcs:status "OPERATIONAL" ],
        [ a nmdc_sfas_brcs:Capability ;
            schema1:description "Suite of apps for genome-scale metabolic model reconstruction, analysis, and prediction. Uses OMEGGA for omics-enabled global gapfilling. Over 500 media formulations available. Recent improvements achieve 72% model accuracy." ;
            schema1:name "Metabolic Modeling Pipeline" ;
            nmdc_sfas_brcs:applications "Essential gene prediction",
                "Flux balance analysis",
                "Genome-scale model reconstruction",
                "Growth media optimization",
                "Pathway analysis" ;
            nmdc_sfas_brcs:capability_type "METABOLIC_MODELING" ;
            nmdc_sfas_brcs:data_products "FBA solutions",
                "Growth predictions",
                "Metabolic models" ;
            nmdc_sfas_brcs:status "OPERATIONAL" ;
            nmdc_sfas_brcs:url "https://docs.kbase.us/apps/analysis/metabolic-modeling"^^xsd:anyURI ],
        [ a nmdc_sfas_brcs:Capability ;
            schema1:description "Functional annotation tools including RAST and KEGG-based annotation, plus DRAM for metabolic profiling. Machine learning classifiers predict growth phenotypes from functional annotations." ;
            schema1:name "Genome Annotation Services" ;
            nmdc_sfas_brcs:applications "Genome functional annotation",
                "MAG annotation",
                "Phenotype prediction",
                "Viral genome annotation (DRAM-v)" ;
            nmdc_sfas_brcs:capability_type "GENOME_ANNOTATION" ;
            nmdc_sfas_brcs:data_products "Annotated genomes",
                "Functional summaries",
                "KEGG mappings" ;
            nmdc_sfas_brcs:status "OPERATIONAL" ;
            nmdc_sfas_brcs:url "https://docs.kbase.us/apps/analysis"^^xsd:anyURI ] ;
    nmdc_sfas_brcs:funding [ a nmdc_sfas_brcs:FundingInfo ;
            nmdc_sfas_brcs:agency "DOE BER" ;
            nmdc_sfas_brcs:program "Genomic Science Program" ] ;
    nmdc_sfas_brcs:lead_institutions "Argonne National Laboratory",
        "Brookhaven National Laboratory",
        "Lawrence Berkeley National Laboratory",
        "Oak Ridge National Laboratory" ;
    nmdc_sfas_brcs:program_type "USER_FACILITY" ;
    nmdc_sfas_brcs:reference_data [ a nmdc_sfas_brcs:ReferenceData ;
            nmdc_sfas_brcs:biolog_media ">300 formulations" ;
            nmdc_sfas_brcs:microbial_genomes ">90,000 from RefSeq" ;
            nmdc_sfas_brcs:plant_genomes ">50 from Phytozome" ;
            nmdc_sfas_brcs:reactions_compounds ">30,000 from KEGG, BIGG, MetaCyc" ] ;
    nmdc_sfas_brcs:supported_data_types "RNA-seq",
        "contigs",
        "expression data",
        "flux balance analysis solutions",
        "genomes",
        "growth media",
        "growth phenotype data",
        "metabolic models",
        "reads" ;
    nmdc_sfas_brcs:websites [ a nmdc_sfas_brcs:WebResources ;
            nmdc_sfas_brcs:documentation "https://docs.kbase.us"^^xsd:anyURI ;
            nmdc_sfas_brcs:doe_page "https://www.genomicscience.energy.gov/kbase/"^^xsd:anyURI ;
            nmdc_sfas_brcs:main "https://www.kbase.us"^^xsd:anyURI ] .

nmdc_sfas_brcs:llnl_secure_biosystems a nmdc_sfas_brcs:ScientificFocusArea ;
    schema1:description "This SFA engineers plant-benefiting microbes for safe and effective deployment in the rhizosphere as plant-promoting probiotics. Develops multilayered containment strategies including kill-switches and gene overlap for circuit stability. Leverages LLNL Soil Microbiome SFA expertise to test containment designs in soil and rhizosphere environments." ;
    schema1:keywords "BIOCONTAINMENT",
        "MACHINE_LEARNING",
        "PLANT_GROWTH_PROMOTING_BACTERIA",
        "RHIZOSPHERE",
        "SHEWANELLA",
        "SYNTHETIC_BIOLOGY" ;
    schema1:name "Secure Biosystems Design Scientific Focus Area" ;
    nmdc_sfas_brcs:co_investigators [ a schema1:Person ;
            schema1:name "Jonathan Allen" ;
            nmdc_sfas_brcs:expertise "machine learning for sequence design" ],
        [ a schema1:Person ;
            schema1:name "Jeffrey Gralnick" ;
            nmdc_sfas_brcs:expertise "Shewanella oneidensis recombineering and CRISPR-Cas" ],
        [ a schema1:Person ;
            schema1:name "Dan Park" ;
            nmdc_sfas_brcs:expertise "fitness considerations in biocontainment" ],
        [ a schema1:Person ;
            schema1:name "Gregory Payne" ;
            nmdc_sfas_brcs:affiliation "University of Maryland" ;
            nmdc_sfas_brcs:expertise "microfluidic platforms" ],
        [ a schema1:Person ;
            schema1:name "Jennifer Chlebek" ;
            nmdc_sfas_brcs:expertise "gene overlap for circuit stability" ],
        [ a schema1:Person ;
            schema1:name "William Bentley" ;
            nmdc_sfas_brcs:affiliation "University of Maryland" ;
            nmdc_sfas_brcs:expertise "microfluidic platforms" ],
        [ a schema1:Person ;
            schema1:name "Mimi Yung" ;
            nmdc_sfas_brcs:expertise "population coordination for containment" ] ;
    nmdc_sfas_brcs:data_types OBI:0000424,
        OBI:0000615,
        OBI:0000626 ;
    nmdc_sfas_brcs:funding [ a nmdc_sfas_brcs:FundingInfo ;
            nmdc_sfas_brcs:agency "DOE BER" ;
            nmdc_sfas_brcs:amount "$9 million" ;
            nmdc_sfas_brcs:area "Secure Biosystems Design" ;
            nmdc_sfas_brcs:program "Genomic Science Program" ] ;
    nmdc_sfas_brcs:lead_institution "Lawrence Livermore National Laboratory" ;
    nmdc_sfas_brcs:partner_institutions "Columbia University",
        "University of California, Berkeley",
        "University of Maryland",
        "University of Minnesota" ;
    nmdc_sfas_brcs:principal_investigators [ a schema1:Person ;
            schema1:name "Yongqin Jiao" ;
            nmdc_sfas_brcs:affiliation "Lawrence Livermore National Laboratory" ;
            nmdc_sfas_brcs:role "Lead Principal Investigator" ] ;
    nmdc_sfas_brcs:program_type "SCIENTIFIC_FOCUS_AREA" ;
    nmdc_sfas_brcs:scientific_questions "How can machine learning improve sequence design for containment?",
        "How do we deploy beneficial microbes safely in the rhizosphere?",
        "How do we prevent potential negative ecological consequences of GEM persistence?",
        "What biocontainment mechanisms are evolutionarily stable?",
        "What population coordination strategies enhance containment?" ;
    nmdc_sfas_brcs:sfa_type "GENOMIC_SCIENCE_SFA" ;
    nmdc_sfas_brcs:studies [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Developing and testing multilayered containment strategies for engineered microbes including kill-switches stabilized through gene overlap (sequence entanglement)." ;
            schema1:name "Multilayered Biocontainment for Rhizosphere Deployment" ;
            nmdc_sfas_brcs:data_modalities OBI:0000424,
                OBI:0000626 ;
            nmdc_sfas_brcs:nmdc_ingest_priority "LOW" ;
            nmdc_sfas_brcs:organism "Shewanella oneidensis" ;
            nmdc_sfas_brcs:pi "Yongqin Jiao" ] ;
    nmdc_sfas_brcs:websites [ a nmdc_sfas_brcs:WebResources ;
            nmdc_sfas_brcs:llnl_page "https://sc-programs.llnl.gov/biological-and-environmental-research-at-llnl/secure-biosystems-design"^^xsd:anyURI ] .

nmdc_sfas_brcs:mcafes a nmdc_sfas_brcs:ScientificFocusArea ;
    schema1:alternateName "m-CAFEs" ;
    schema1:description """m-CAFEs develops and deploys unique laboratory capabilities to capture key aspects of grass rhizosphere communities and identify causal mechanisms governing microbial interactions within the rhizosphere. Uses advanced fabricated ecosystems with gene editing technologies for interrogating gene and microbial functions in situ.
""" ;
    schema1:keywords "BRACHYPODIUM",
        "CARBON_CYCLING",
        "CRISPR",
        "ECOFAB",
        "FABRICATED_ECOSYSTEMS",
        "PHAGE",
        "RHIZOSPHERE",
        "SOIL_MICROBIOME" ;
    schema1:name "m-CAFEs: Microbial Community Analysis and Functional Evaluation in Soils" ;
    nmdc_sfas_brcs:data_collection_modalities "CRISPR_GENE_EDITING",
        "FABRICATED_ECOSYSTEMS",
        "HIGH_THROUGHPUT_SEQUENCING",
        "LIVE_CELL_IMAGING" ;
    nmdc_sfas_brcs:data_types OBI:0000366,
        OBI:0000424,
        OBI:0002623,
        "EXOMETABOLOMICS",
        "IMAGING_DATA" ;
    nmdc_sfas_brcs:funding [ a nmdc_sfas_brcs:FundingInfo ;
            nmdc_sfas_brcs:agency "DOE BER" ;
            nmdc_sfas_brcs:division "Biological Systems Science Division" ;
            nmdc_sfas_brcs:program "Genomic Science Program" ] ;
    nmdc_sfas_brcs:isolate_collections [ a nmdc_sfas_brcs:IsolateCollection ;
            schema1:description "Bacterial isolates from Brachypodium and grass rhizospheres used for synthetic community studies in EcoFAB devices. Includes reduced complexity consortia (RCC) strains representing core rhizosphere microbiome." ;
            schema1:name "m-CAFEs Rhizosphere Bacterial Collection" ;
            nmdc_sfas_brcs:host_organisms "Avena barbata",
                "Brachypodium distachyon" ;
            nmdc_sfas_brcs:isolation_methods "Aerobic plating",
                "Dilution-to-extinction" ;
            nmdc_sfas_brcs:organism_types NCBITaxon:2 ;
            nmdc_sfas_brcs:source_environments "Angelo Coast Range Reserve soil",
                "Brachypodium rhizosphere",
                "Grass rhizosphere" ],
        [ a nmdc_sfas_brcs:IsolateCollection ;
            schema1:description "Bacteriophages isolated from soil for phage-based genome editing and microbial community manipulation studies." ;
            schema1:name "m-CAFEs Phage Collection" ;
            nmdc_sfas_brcs:organism_types "PHAGE" ;
            nmdc_sfas_brcs:source_environments "Rhizosphere",
                "Soil" ] ;
    nmdc_sfas_brcs:key_publications <https://doi.org/10.1038/s41467-023-37164-x>,
        <https://doi.org/10.1038/s41564-018-0129-3>,
        <https://doi.org/10.1126/sciadv.adg7888> ;
    nmdc_sfas_brcs:lead_institution "Lawrence Berkeley National Laboratory" ;
    nmdc_sfas_brcs:nmdc_umbrella_study "nmdc:sty-11-abkzcd11"^^xsd:anyURI ;
    nmdc_sfas_brcs:partner_institutions "Boston University",
        "North Carolina State University",
        "Sandia National Laboratories",
        "University of California, Berkeley" ;
    nmdc_sfas_brcs:phenotype_assays "ECOFAB_PHENOTYPING",
        "EXOMETABOLOMICS",
        "GROWTH_CURVES",
        "LIVE_CELL_IMAGING",
        "PLANT_COLONIZATION",
        "SUBSTRATE_UTILIZATION",
        "SYNTHETIC_COMMUNITY" ;
    nmdc_sfas_brcs:principal_investigators [ a schema1:Person ;
            schema1:name "Trent R. Northen" ;
            nmdc_sfas_brcs:affiliation "Lawrence Berkeley National Laboratory" ;
            nmdc_sfas_brcs:role "Principal Investigator" ] ;
    nmdc_sfas_brcs:program_type "SCIENTIFIC_FOCUS_AREA" ;
    nmdc_sfas_brcs:scientific_questions "How can we predict and manipulate rhizosphere communities?",
        "How do microbiomes respond to perturbations?",
        "What controls carbon cycling in plant-microbe-soil systems?",
        "What mechanisms govern microbial interactions in the rhizosphere?" ;
    nmdc_sfas_brcs:sfa_type "GENOMIC_SCIENCE_SFA" ;
    nmdc_sfas_brcs:studies [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Landmark study showing dynamic root exudate chemistry and microbial substrate preferences drive patterns in rhizosphere microbial community assembly. Avena barbata in natural soil." ;
            schema1:name "Dynamic Root Exudate Chemistry and Microbial Assembly" ;
            nmdc_sfas_brcs:data_modalities OBI:0000366,
                OBI:0002763,
                "EXOMETABOLOMICS" ;
            nmdc_sfas_brcs:nmdc_ingest_target true ;
            nmdc_sfas_brcs:organism "Avena barbata" ;
            nmdc_sfas_brcs:pi "Trent R. Northen" ;
            nmdc_sfas_brcs:primary_reference_info [ a nmdc_sfas_brcs:PrimaryReferenceInfo ;
                    nmdc_sfas_brcs:reference <https://doi.org/10.1038/s41564-018-0129-3> ] ],
        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Assembled metagenomes for 60 soil samples across multiple soil plots from a meadow in the Angelo Coastal Range Reserve, CA, part of a climate change experiment." ;
            schema1:name "Meadow Soil Metagenomes from the Angelo Coast Range Reserve" ;
            nmdc_sfas_brcs:gold_study_id "gold:Gs0110119" ;
            nmdc_sfas_brcs:nmdc_study_id "nmdc:sty-11-zs2syx06"^^xsd:anyURI ;
            nmdc_sfas_brcs:pi "Jillian F. Banfield" ],
        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Core metabolome and root exudation dynamics of three phylogenetically distinct plant species (Brachypodium, Avena, Microbotryum). Multi-omics dataset from EcoFABs." ;
            schema1:name "Core Metabolome and Root Exudation Dynamics" ;
            nmdc_sfas_brcs:data_modalities OBI:0000366,
                "EXOMETABOLOMICS" ;
            nmdc_sfas_brcs:nmdc_ingest_target true ;
            nmdc_sfas_brcs:organism "Brachypodium distachyon" ;
            nmdc_sfas_brcs:pi "Trent R. Northen" ;
            nmdc_sfas_brcs:primary_reference_info [ a nmdc_sfas_brcs:PrimaryReferenceInfo ;
                    nmdc_sfas_brcs:reference <https://doi.org/10.1038/s41467-023-37164-x> ] ],
        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Multilab study demonstrating highly reproducible plant physiology and soil metabolite depletion patterns using EcoFAB standardized fabricated ecosystems across 4 labs." ;
            schema1:name "Multilab EcoFAB Reproducibility Study" ;
            nmdc_sfas_brcs:data_modalities OBI:0000366,
                "PHENOTYPIC_DATA" ;
            nmdc_sfas_brcs:nmdc_ingest_target true ;
            nmdc_sfas_brcs:organism "Brachypodium distachyon" ;
            nmdc_sfas_brcs:pi "Trent R. Northen" ;
            nmdc_sfas_brcs:primary_reference_info [ a nmdc_sfas_brcs:PrimaryReferenceInfo ;
                    nmdc_sfas_brcs:reference <https://doi.org/10.1111/nph.15662> ] ],
        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Systematic framework to generate Reduced Complexity Consortia (RCC) representing Brachypodium rhizosphere microbiome for sustainable agriculture applications. Inoculum from Angelo Coast Range Reserve soil." ;
            schema1:name "Reduced Complexity Consortia from Brachypodium Rhizosphere" ;
            nmdc_sfas_brcs:data_modalities OBI:0002623,
                OBI:0002763 ;
            nmdc_sfas_brcs:nmdc_ingest_target true ;
            nmdc_sfas_brcs:organism "Brachypodium distachyon" ;
            nmdc_sfas_brcs:pi "Trent R. Northen" ;
            nmdc_sfas_brcs:primary_reference_info [ a nmdc_sfas_brcs:PrimaryReferenceInfo ;
                    nmdc_sfas_brcs:reference <https://doi.org/10.3389/fmicb.2024.1401794> ] ],
        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Multi-laboratory ring trial using EcoFAB 2.0 devices with synthetic bacterial communities and Brachypodium distachyon to test reproducibility and standardization." ;
            schema1:name "EcoFAB 2.0 Root Microbiome Ring Trial" ;
            nmdc_sfas_brcs:nmdc_study_id "nmdc:sty-11-ev70y104"^^xsd:anyURI ;
            nmdc_sfas_brcs:pi "Trent R. Northen" ],
        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "16S rRNA amplicon sequencing defining core root microbiome of Brachypodium distachyon grown in four distinct soils. Identified overlooked taxa via metabarcoding vs culture." ;
            schema1:name "Brachypodium Core Root Microbiome Metabarcoding" ;
            nmdc_sfas_brcs:bioproject_ids "PRJNA1120948" ;
            nmdc_sfas_brcs:data_modalities OBI:0002763 ;
            nmdc_sfas_brcs:nmdc_ingest_target true ;
            nmdc_sfas_brcs:organism "Brachypodium distachyon" ;
            nmdc_sfas_brcs:pi "Trent R. Northen" ;
            nmdc_sfas_brcs:primary_reference_info [ a nmdc_sfas_brcs:PrimaryReferenceInfo ;
                    nmdc_sfas_brcs:reference <https://doi.org/10.1007/s10725-024-01221-2> ] ;
            nmdc_sfas_brcs:sample_count 71 ],
        [ a nmdc_sfas_brcs:NMDCStudyReference ;
            schema1:description "Fine scale sampling reveals spatial heterogeneity of rhizosphere microbiome in young Brachypodium plant roots using EcoFABs. Strong rhizosphere effect with Actinobacteria, Bacteroidetes, Firmicutes and Proteobacteria enrichment." ;
            schema1:name "Fine Scale Rhizosphere Spatial Heterogeneity" ;
            nmdc_sfas_brcs:data_modalities OBI:0002763 ;
            nmdc_sfas_brcs:nmdc_ingest_target true ;
            nmdc_sfas_brcs:organism "Brachypodium distachyon" ;
            nmdc_sfas_brcs:pi "Trent R. Northen" ;
            nmdc_sfas_brcs:primary_reference_info [ a nmdc_sfas_brcs:PrimaryReferenceInfo ;
                    nmdc_sfas_brcs:reference <https://doi.org/10.1038/s43705-023-00265-1> ] ] ;
    nmdc_sfas_brcs:technologies_developed [ a nmdc_sfas_brcs:Technology ;
            schema1:description """DNA-editing All-in-one RNA-guided CRISPR-Cas Transposase system for locus-specific DNA insertion
""" ;
            schema1:name "DART" ],
        [ a nmdc_sfas_brcs:Technology ;
            schema1:description """Fabricated ecosystem serving as standardized reproducible platform for plant-microbiome research
""" ;
            schema1:name "EcoFAB" ],
        [ a nmdc_sfas_brcs:Technology ;
            schema1:description """Environmental Transformation Sequencing for assessing DNA uptake in microbial communities
""" ;
            schema1:name "ET-Seq" ],
        [ a nmdc_sfas_brcs:Technology ;
            schema1:description "Meter-scale contained controlled ecosystems" ;
            schema1:name "EcoPOD" ] ;
    nmdc_sfas_brcs:websites [ a nmdc_sfas_brcs:WebResources ;
            nmdc_sfas_brcs:doe_page "https://www.genomicscience.energy.gov/lbnlmcafes/"^^xsd:anyURI ;
