            nmdc_sfas_brcs:country "USA" ;
            nmdc_sfas_brcs:state "Tennessee" ] ;
    nmdc_sfas_brcs:nmdc_umbrella_study "nmdc:sty-11-cssvjy19"^^xsd:anyURI ;
