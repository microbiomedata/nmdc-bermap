###  https://w3id.org/nmdc/sfas-brcs/enigma
nmdc_sfas_brcs:enigma rdf:type owl:NamedIndividual ,
                               nmdc_sfas_brcs:ScientificFocusArea ;
                      schema1:alternateName "ENIGMA" ;
                      schema1:description """ENIGMA emphasizes achieving a multiscale, causal, and predictive understanding of microbial biology and the reciprocal impact of microbial communities on their ecosystems. Focus on processes affecting denitrification and metal reduction in contaminated subsurface environments.
""" ;
                      schema1:keywords "DENITRIFICATION" ,
                                       "METAGENOMICS" ,
                                       "METAL_REDUCTION" ,
                                       "MICROBIAL_ECOSYSTEMS" ,
                                       "NITRATE" ,
                                       "SUBSURFACE_MICROBIOLOGY" ,
                                       "SYSTEMS_BIOLOGY" ,
                                       "URANIUM" ;
                      schema1:name "ENIGMA: Ecosystems and Networks Integrated with Genes and Molecular Assemblies" ;
                      nmdc_sfas_brcs:data_collection_modalities "COMPUTATIONAL_MODELING" ,
                                                                "HIGH_THROUGHPUT_SEQUENCING" ,
                                                                "IMAGING" ,
                                                                "MASS_SPECTROMETRY" ,
                                                                "SYNCHROTRON_METHODS" ;
                      nmdc_sfas_brcs:data_types <http://purl.obolibrary.org/obo/OBI_0000366> ,
                                                <http://purl.obolibrary.org/obo/OBI_0000424> ,
                                                <http://purl.obolibrary.org/obo/OBI_0000615> ,
                                                <http://purl.obolibrary.org/obo/OBI_0002623> ,
                                                "ENVIRONMENTAL_SENSOR_DATA" ,
                                                "STRUCTURAL_BIOLOGY" ;
                      nmdc_sfas_brcs:datasets [ rdf:type nmdc_sfas_brcs:Dataset ;
                                                schema1:description "Multi-omics data from Oak Ridge Reservation subsurface" ;
                                                schema1:name "ENIGMA Environmental Data" ;
                                                nmdc_sfas_brcs:data_type "metagenomics/environmental" ;
                                                nmdc_sfas_brcs:repository "KBase"
                                              ] ;
                      nmdc_sfas_brcs:field_sites [ rdf:type nmdc_sfas_brcs:FieldSite ;
                                                   schema1:description "Bear Creek aquifer with complex contaminant gradients" ;
                                                   schema1:name "Oak Ridge Reservation (ORR)" ;
                                                   nmdc_sfas_brcs:contaminants "nitrates" ,
                                                                               "uranium" ,
                                                                               "volatile organic carbon species" ;
                                                   nmdc_sfas_brcs:location "East Tennessee"
                                                 ] ;
                      nmdc_sfas_brcs:funding [ rdf:type nmdc_sfas_brcs:FundingInfo ;
                                               nmdc_sfas_brcs:agency "DOE BER" ;
                                               nmdc_sfas_brcs:division "Biological Systems Science Division" ;
                                               nmdc_sfas_brcs:program "Genomic Science Program"
                                             ] ;
                      nmdc_sfas_brcs:key_publications [ rdf:type nmdc_sfas_brcs:Publication ;
                                                        dcterms:title "Ecosystems and Networks Integrated with Genes and Molecular Assemblies: Integrating Metabolomics into Environmental Systems Biology" ;
                                                        nmdc_sfas_brcs:osti_id "1963932" ;
                                                        nmdc_sfas_brcs:repository "OSTI" ;
                                                        nmdc_sfas_brcs:type "Technical Report"
                                                      ] ;
                      nmdc_sfas_brcs:lead_institution "Lawrence Berkeley National Laboratory" ;
                      nmdc_sfas_brcs:principal_investigators [ rdf:type schema1:Person ;
                                                               schema1:name "Adam P. Arkin" ;
                                                               nmdc_sfas_brcs:affiliation "Lawrence Berkeley National Laboratory" ;
                                                               nmdc_sfas_brcs:role "Technical Co-manager"
                                                             ] ,
                                                             [ rdf:type schema1:Person ;
                                                               schema1:name "Paul D. Adams" ;
                                                               nmdc_sfas_brcs:affiliation "Lawrence Berkeley National Laboratory" ;
                                                               nmdc_sfas_brcs:role "Project Manager"
                                                             ] ;
                      nmdc_sfas_brcs:program_type "SCIENTIFIC_FOCUS_AREA" ;
                      nmdc_sfas_brcs:scientific_questions "How do microbial communities respond to contamination?" ,
                                                          "How do microbial networks drive macroscopic biogeochemical processes?" ,
                                                          "What controls denitrification and metal reduction in subsurface?" ,
                                                          "What mechanisms drive subcellular, cellular, and intercellular networks?" ;
                      nmdc_sfas_brcs:sfa_type "GENOMIC_SCIENCE_SFA" ;
                      nmdc_sfas_brcs:websites [ rdf:type nmdc_sfas_brcs:WebResources ;
                                                nmdc_sfas_brcs:doe_page "https://www.genomicscience.energy.gov/lbnl/"^^xsd:anyURI ;
                                                nmdc_sfas_brcs:kbase "https://www.kbase.us/research/adams-sfa/"^^xsd:anyURI ;
                                                nmdc_sfas_brcs:main "https://enigma.lbl.gov"^^xsd:anyURI
                                              ] .


