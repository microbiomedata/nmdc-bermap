                                                    owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty nmdc_sfas_brcs:notes ;
                                                    owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty nmdc_sfas_brcs:sources ;
                                                    owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
