###  https://w3id.org/nmdc/sfas-brcs/jgi
nmdc_sfas_brcs:jgi rdf:type owl:NamedIndividual ,
                            nmdc_sfas_brcs:UserFacility ;
                   schema1:alternateName "JGI" ;
                   schema1:description """JGI provides integrated high-throughput sequencing, DNA design and synthesis, metabolomics, and computational analysis enabling systems-based scientific approaches. JGI sequences and analyzes genomes for DOE-relevant research in bioenergy, carbon cycling, and environmental microbiome science.
""" ;
                   schema1:name "DOE Joint Genome Institute" ;
                   nmdc_sfas_brcs:capabilities [ rdf:type nmdc_sfas_brcs:Capability ;
                                                 schema1:description "Functional annotation of genomes through metabolomics, providing improved understanding of the role of small molecules in diverse biological systems. Minimum 22 samples required." ;
                                                 schema1:name "Metabolomics Program" ;
                                                 nmdc_sfas_brcs:applications "Biosynthetic gene cluster characterization" ,
                                                                             "Pathway validation" ,
                                                                             "Secondary metabolite identification" ;
                                                 nmdc_sfas_brcs:capability_type "METABOLOMICS_MS" ;
                                                 nmdc_sfas_brcs:data_products "Mass spectra (submitted to MassIVE)" ,
                                                                              "Metabolite profiles" ;
                                                 nmdc_sfas_brcs:status "OPERATIONAL" ;
                                                 nmdc_sfas_brcs:url "https://jgi.doe.gov/science-programs/secmet"^^xsd:anyURI
                                               ] ,
                                               [ rdf:type nmdc_sfas_brcs:Capability ;
                                                 schema1:description "Short- and long-read sequencing platforms producing billions of reads for genomic assembly, resequencing, RNAseq annotation, and metagenomics. Total output in 2024 was 870 Tb." ;
                                                 schema1:name "High-Throughput Sequencing" ;
                                                 nmdc_sfas_brcs:applications "Genome assembly" ,
                                                                             "Metagenome sequencing" ,
                                                                             "RNA-seq" ,
                                                                             "Single-cell genomics" ;
                                                 nmdc_sfas_brcs:capability_type "SEQUENCING" ;
                                                 nmdc_sfas_brcs:data_products "Annotated transcripts" ,
                                                                              "Assembled genomes" ,
                                                                              "Raw sequence reads" ;
                                                 nmdc_sfas_brcs:instruments [ rdf:type nmdc_sfas_brcs:Instrument ;
                                                                              schema1:description "Short-read sequencing producing paired-end 150bp reads" ;
                                                                              schema1:name "Illumina NovaSeq" ;
                                                                              nmdc_sfas_brcs:instrument_type "ILLUMINA_SEQUENCER"
                                                                            ] ,
                                                                            [ rdf:type nmdc_sfas_brcs:Instrument ;
                                                                              schema1:description "Long-read sequencing averaging 60-70 kbp reads" ;
                                                                              schema1:name "PacBio Revio" ;
                                                                              nmdc_sfas_brcs:instrument_type "PACBIO_SEQUENCER"
                                                                            ] ;
                                                 nmdc_sfas_brcs:status "OPERATIONAL" ;
                                                 nmdc_sfas_brcs:throughput "870 Tb annually" ;
                                                 nmdc_sfas_brcs:url "https://jgi.doe.gov/work-with-us/offerings-capabilities"^^xsd:anyURI
                                               ] ,
                                               [ rdf:type nmdc_sfas_brcs:Capability ;
                                                 schema1:description "DNA design and synthesis capabilities supporting researchers exploring conversion of sequence into functional assessments. Minimum request is 100 kb." ;
                                                 schema1:name "DNA Synthesis Platform" ;
                                                 nmdc_sfas_brcs:applications "Biosynthetic pathway refactoring" ,
                                                                             "Construct assembly" ,
                                                                             "Gene synthesis" ;
                                                 nmdc_sfas_brcs:capability_type "DNA_SYNTHESIS" ;
                                                 nmdc_sfas_brcs:data_products "Synthesized DNA constructs" ,
                                                                              "Verified plasmids" ;
                                                 nmdc_sfas_brcs:status "OPERATIONAL" ;
                                                 nmdc_sfas_brcs:url "https://jgi.doe.gov/work-with-us/offerings-capabilities"^^xsd:anyURI
                                               ] ,
                                               [ rdf:type nmdc_sfas_brcs:Capability ;
                                                 schema1:description "AI/ML-based computational analysis including protein family discovery, biosynthetic gene cluster prediction, and genome annotation. Doubled known protein families using AI clustering algorithms." ;
                                                 schema1:name "AI-Centric Analysis" ;
                                                 nmdc_sfas_brcs:applications "BGC prediction" ,
                                                                             "Metagenome analysis" ,
                                                                             "Protein family discovery" ;
                                                 nmdc_sfas_brcs:capability_type "AI_ML_ANALYSIS" ;
                                                 nmdc_sfas_brcs:status "OPERATIONAL"
                                               ] ;
                   nmdc_sfas_brcs:flagship_genomes [ rdf:type nmdc_sfas_brcs:FlagshipGenome ;
