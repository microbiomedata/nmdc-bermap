                    nmdc_sfas_brcs:studies [ rdf:type nmdc_sfas_brcs:NMDCStudyReference ;
                                             schema1:description "Genome sequencing of Bacillus velezensis EB14, a native endophytic bacterial strain isolated from Populus × jackii with biocontrol potential against Sphaerulina musiva, the causative pathogen of poplar stem canker. Contains gene clusters for antimicrobial compound biosynthesis including iturin A, subtulene A, and fengycin." ;
                                             schema1:name "Bacillus velezensis EB14 Biocontrol Agent Genome" ;
                                             nmdc_sfas_brcs:bioproject_ids "PRJNA681597" ;
