###  https://w3id.org/nmdc/sfas-brcs/SFAType
nmdc_sfas_brcs:SFAType rdf:type owl:Class ;
                       owl:equivalentClass [ rdf:type owl:Class ;
                                             owl:unionOf ( <https://w3id.org/nmdc/sfas-brcs/SFAType#ENVIRONMENTAL_MICROBIOME_SCIENCE>
                                                           <https://w3id.org/nmdc/sfas-brcs/SFAType#ENVIRONMENTAL_SYSTEM_SCIENCE_SFA>
                                                           <https://w3id.org/nmdc/sfas-brcs/SFAType#GENOMIC_SCIENCE_SFA>
                                                           <https://w3id.org/nmdc/sfas-brcs/SFAType#SECURE_BIOSYSTEMS_DESIGN>
                                                         )
                                           ] ;
                       rdfs:subClassOf linkml:EnumDefinition ;
                       rdfs:label "SFAType" ;
                       skos:definition "Types of Scientific Focus Areas by program area" ;
                       skos:inScheme <https://w3id.org/nmdc/sfas-brcs> ;
                       linkml:permissible_values <https://w3id.org/nmdc/sfas-brcs/SFAType#ENVIRONMENTAL_MICROBIOME_SCIENCE> ,
                                                 <https://w3id.org/nmdc/sfas-brcs/SFAType#ENVIRONMENTAL_SYSTEM_SCIENCE_SFA> ,
                                                 <https://w3id.org/nmdc/sfas-brcs/SFAType#GENOMIC_SCIENCE_SFA> ,
                                                 <https://w3id.org/nmdc/sfas-brcs/SFAType#SECURE_BIOSYSTEMS_DESIGN> .


###  https://w3id.org/nmdc/sfas-brcs/ScientificFocusArea
nmdc_sfas_brcs:ScientificFocusArea rdf:type owl:Class ;
                                   rdfs:subClassOf nmdc_sfas_brcs:ResearchProgram ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty nmdc_sfas_brcs:co_investigators ;
                                                     owl:allValuesFrom nmdc_sfas_brcs:Person
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty nmdc_sfas_brcs:sfa_type ;
                                                     owl:allValuesFrom nmdc_sfas_brcs:SFAType
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty nmdc_sfas_brcs:technologies_developed ;
                                                     owl:allValuesFrom nmdc_sfas_brcs:Technology
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty nmdc_sfas_brcs:co_investigators ;
                                                     owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty nmdc_sfas_brcs:program_type ;
                                                     owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty nmdc_sfas_brcs:sfa_type ;
                                                     owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty nmdc_sfas_brcs:technologies_developed ;
                                                     owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty nmdc_sfas_brcs:program_type ;
                                                     owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty nmdc_sfas_brcs:sfa_type ;
                                                     owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty nmdc_sfas_brcs:program_type ;
                                                     owl:allValuesFrom xsd:string
                                                   ] ;
                                   rdfs:label "ScientificFocusArea" ;
                                   skos:definition "A DOE Scientific Focus Area (SFA). SFAs are integrated research programs at DOE national laboratories focused on specific scientific areas within BER's portfolio. SFAs conduct coordinated, team-oriented research taking advantage of national laboratory strengths." ;
                                   skos:inScheme <https://w3id.org/nmdc/sfas-brcs> .


