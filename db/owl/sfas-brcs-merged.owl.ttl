###  https://w3id.org/nmdc/sfas-brcs/actinides_sfa
nmdc_sfas_brcs:actinides_sfa rdf:type owl:NamedIndividual ,
                                      nmdc_sfas_brcs:ScientificFocusArea ;
                             schema1:alternateName "BGC-Interfaces" ;
                             schema1:description "Identifies and quantifies biogeochemical processes and underlying mechanisms controlling actinide mobility to reliably predict and control cycling and migration of actinides in the environment. Focus on plutonium (>2200 metric tons deposited globally) and neptunium behavior, including interactions with lanmodulin and similar compounds." ;
                             schema1:keywords "ACTINIDES" ,
                                              "BIOGEOCHEMISTRY" ,
                                              "COLLOID_TRANSPORT" ,
                                              "CONTAMINANT_TRANSPORT" ,
                                              "ENVIRONMENTAL_SYSTEMS" ,
                                              "INTERFACES" ,
                                              "URANIUM" ;
                             schema1:name "BioGeoChemistry at Interfaces Science Focus Area" ;
                             nmdc_sfas_brcs:data_types "BIOGEOCHEMICAL_DATA" ,
                                                       "STABLE_ISOTOPE_DATA" ;
                             nmdc_sfas_brcs:field_sites [ rdf:type nmdc_sfas_brcs:FieldSite ;
                                                          schema1:description "Field site for actinide biogeochemistry studies" ;
                                                          schema1:name "Savannah River Site - Pond B" ;
                                                          nmdc_sfas_brcs:location "South Carolina"
                                                        ] ;
                             nmdc_sfas_brcs:funding [ rdf:type nmdc_sfas_brcs:FundingInfo ;
                                                      nmdc_sfas_brcs:agency "DOE BER" ;
                                                      nmdc_sfas_brcs:program "Environmental System Science (ESS)" ;
                                                      nmdc_sfas_brcs:subprogram "Subsurface Biogeochemical Research"
                                                    ] ;
                             nmdc_sfas_brcs:lead_institution "Lawrence Livermore National Laboratory" ;
                             nmdc_sfas_brcs:principal_investigators [ rdf:type schema1:Person ;
                                                                      schema1:name "Annie B. Kersting" ;
                                                                      nmdc_sfas_brcs:affiliation "Lawrence Livermore National Laboratory" ;
                                                                      nmdc_sfas_brcs:expertise "Isotope geochemistry, actinide chemistry, colloid-facilitated transport" ;
                                                                      nmdc_sfas_brcs:role "Former PI / Director of University Relations"
                                                                    ] ,
                                                                    [ rdf:type schema1:Person ;
                                                                      schema1:name "Mavrik Zavarin" ;
                                                                      nmdc_sfas_brcs:affiliation "Lawrence Livermore National Laboratory" ;
                                                                      nmdc_sfas_brcs:role "Principal Investigator"
                                                                    ] ;
                             nmdc_sfas_brcs:program_type "SCIENTIFIC_FOCUS_AREA" ;
                             nmdc_sfas_brcs:scientific_questions "How do actinides interact with biological systems?" ,
                                                                 "What biogeochemical processes control actinide mobility?" ,
                                                                 "What is the role of lanmodulin in actinide chemistry?" ,
                                                                 "What mechanisms control plutonium migration in subsurface environments?" ;
                             nmdc_sfas_brcs:sfa_type "ENVIRONMENTAL_SYSTEM_SCIENCE_SFA" ;
                             nmdc_sfas_brcs:websites [ rdf:type nmdc_sfas_brcs:WebResources ;
                                                       nmdc_sfas_brcs:doe_page "https://ess.science.energy.gov/llnl-actinides-sfa/"^^xsd:anyURI
                                                     ] .


###  https://w3id.org/nmdc/sfas-brcs/bfi
nmdc_sfas_brcs:bfi rdf:type owl:NamedIndividual ,
                            nmdc_sfas_brcs:ScientificFocusArea ;
                   schema1:alternateName "BFI" ;
                   schema1:description """The BFI SFA discovers fundamental principles underlying bacterial-fungal interactions to harness their biotechnological potential for steering soil ecosystem functions. Research uses novel bioinformatics and multiomics approaches to understand how bacteria and fungi sense, respond to, and co-evolve with one another.
""" ;
