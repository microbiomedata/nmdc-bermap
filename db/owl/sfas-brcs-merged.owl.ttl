                                                                               schema1:description "Dedicated to mass spectrometry imaging" ;
                                                                               schema1:name "Imaging Mass Spectrometers" ;
                                                                               nmdc_sfas_brcs:count 4 ;
                                                                               nmdc_sfas_brcs:instrument_type "ORBITRAP"
                                                                             ] ,
