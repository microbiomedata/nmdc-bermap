                            nmdc_sfas_brcs:notes """This compilation focuses on DOE BER-funded Bioenergy Research Centers and Scientific Focus Areas. It includes projects from both the Genomic Science Program (Biological Systems Science Division) and the Environmental System Science program. Dataset listings are representative rather than exhaustive. For current datasets, consult project-specific data portals and DOE data repositories (ESS-DIVE, KBase, JGI, NMDC).
""" ;
                            nmdc_sfas_brcs:sources "DOE BER program documentation" ,
                                                   "Individual project websites" ,
                                                   "Peer-reviewed publications" ,
                                                   "https://ess.science.energy.gov" ,
                                                   "https://science.osti.gov/ber" ,
                                                   "https://www.genomicscience.energy.gov"
                          ] ;
  nmdc_sfas_brcs:user_facilities nmdc_sfas_brcs:emsl ,
                                 nmdc_sfas_brcs:ess_dive ,
                                 nmdc_sfas_brcs:jgi ,
                                 nmdc_sfas_brcs:kbase ,
                                 nmdc_sfas_brcs:nmdc
] .

