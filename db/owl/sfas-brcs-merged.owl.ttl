                                                                                     nmdc_sfas_brcs:reference <https://doi.org/10.1094/PHYTO-09-20-0433-A>
                                                                                   ]
                                           ] ,
                                           [ rdf:type nmdc_sfas_brcs:NMDCStudyReference ;
                                             schema1:description "Investigation of plant-derived effector proteins mediating symbiosis between Populus and the ectomycorrhizal fungus Laccaria bicolor. Identifies PtLecRLK1 receptor and small secreted proteins regulating fungal colonization." ;
                                             schema1:name "Populus-Laccaria Symbiosis Effector Discovery" ;
                                             nmdc_sfas_brcs:data_modalities <http://purl.obolibrary.org/obo/OBI_0000366> ,
