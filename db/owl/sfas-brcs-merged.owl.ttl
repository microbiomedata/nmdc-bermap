nmdc_sfas_brcs:ess_dive schema1:alternateName "ESS-DIVE" ;
                        schema1:description """ESS-DIVE is DOE's data archive for Environmental System Science research data. Provides open access to datasets from DOE-funded environmental research including watershed, soil, and ecosystem studies.
""" ;
                        schema1:name "Environmental System Science Data Infrastructure for a Virtual Ecosystem" ;
                        rdfs:label "ess_dive" ;
                        skos:definition "ESS-DIVE data portal URL" ;
                        skos:inScheme <https://w3id.org/nmdc/sfas-brcs> ;
                        nmdc_sfas_brcs:funding [ rdf:type nmdc_sfas_brcs:FundingInfo ;
                                                 nmdc_sfas_brcs:agency "DOE BER" ;
                                                 nmdc_sfas_brcs:program "Environmental System Science"
                                               ] ;
                        nmdc_sfas_brcs:lead_institution "Lawrence Berkeley National Laboratory" ;
                        nmdc_sfas_brcs:program_type "DATA_REPOSITORY" ;
                        nmdc_sfas_brcs:websites [ rdf:type nmdc_sfas_brcs:WebResources ;
                                                  nmdc_sfas_brcs:main "https://ess-dive.lbl.gov"^^xsd:anyURI
                                                ] .


