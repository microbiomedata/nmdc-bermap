###  https://w3id.org/nmdc/sfas-brcs/Person
nmdc_sfas_brcs:Person rdf:type owl:Class ;
                      rdfs:subClassOf linkml:ClassDefinition ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty nmdc_sfas_brcs:affiliation ;
                                        owl:allValuesFrom xsd:string
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty nmdc_sfas_brcs:email ;
                                        owl:allValuesFrom xsd:string
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty nmdc_sfas_brcs:expertise ;
                                        owl:allValuesFrom xsd:string
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty nmdc_sfas_brcs:name ;
                                        owl:allValuesFrom xsd:string
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty nmdc_sfas_brcs:orcid ;
                                        owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                                            owl:intersectionOf ( xsd:anyURI
                                                                                 [ rdf:type rdfs:Datatype ;
                                                                                   owl:onDatatype xsd:string ;
                                                                                   owl:withRestrictions ( [ xsd:pattern "^orcid:\\d{4}-\\d{4}-\\d{4}-\\d{3}[0-9X]$"
                                                                                                          ]
                                                                                                        )
                                                                                 ]
                                                                               )
                                                          ]
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty nmdc_sfas_brcs:role ;
                                        owl:allValuesFrom xsd:string
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty nmdc_sfas_brcs:affiliation ;
                                        owl:minCardinality "0"^^xsd:nonNegativeInteger
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty nmdc_sfas_brcs:email ;
                                        owl:minCardinality "0"^^xsd:nonNegativeInteger
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty nmdc_sfas_brcs:expertise ;
                                        owl:minCardinality "0"^^xsd:nonNegativeInteger
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty nmdc_sfas_brcs:name ;
                                        owl:minCardinality "0"^^xsd:nonNegativeInteger
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty nmdc_sfas_brcs:orcid ;
                                        owl:minCardinality "0"^^xsd:nonNegativeInteger
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty nmdc_sfas_brcs:role ;
                                        owl:minCardinality "0"^^xsd:nonNegativeInteger
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty nmdc_sfas_brcs:affiliation ;
                                        owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty nmdc_sfas_brcs:email ;
                                        owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty nmdc_sfas_brcs:expertise ;
                                        owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty nmdc_sfas_brcs:name ;
                                        owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty nmdc_sfas_brcs:orcid ;
                                        owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty nmdc_sfas_brcs:role ;
                                        owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                      ] ;
                      rdfs:label "Person" ;
                      skos:definition "A person involved in a research program, such as a principal investigator, co-investigator, or other key personnel." ;
                      skos:exactMatch schema1:Person ;
                      skos:inScheme <https://w3id.org/nmdc/sfas-brcs> .


