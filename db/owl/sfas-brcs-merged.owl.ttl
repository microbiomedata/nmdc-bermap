                                                                            <http://purl.obolibrary.org/obo/OBI_0000626> ;
                                             nmdc_sfas_brcs:nmdc_ingest_priority "MEDIUM" ;
                                             nmdc_sfas_brcs:organism "Populus trichocarpa" ;
                                             nmdc_sfas_brcs:pi "Xiaohan Yang" ;
                                             nmdc_sfas_brcs:primary_reference_info [ rdf:type nmdc_sfas_brcs:PrimaryReferenceInfo ;
                                                                                     nmdc_sfas_brcs:reference <https://doi.org/10.1093/hr/uhae232>
                                                                                   ]
                                           ] ,
                                           [ rdf:type nmdc_sfas_brcs:NMDCStudyReference ;
                                             schema1:description "Development of workflow for rapid enhancement of transformation efficiency and genetic part characterization in non-model bacteria for genome-wide CRISPRi screens. Tools being deployed in Bacillus velezensis for rhizosphere studies." ;
                                             schema1:name "CRISPRi High-Throughput Screens in Non-Model Bacteria" ;
                                             nmdc_sfas_brcs:data_modalities <http://purl.obolibrary.org/obo/OBI_0000626> ;
