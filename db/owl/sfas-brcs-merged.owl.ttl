###  https://w3id.org/nmdc/sfas-brcs/BioenergyResearchCenter
nmdc_sfas_brcs:BioenergyResearchCenter rdf:type owl:Class ;
                                       rdfs:subClassOf nmdc_sfas_brcs:ResearchProgram ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty nmdc_sfas_brcs:outputs ;
                                                         owl:allValuesFrom nmdc_sfas_brcs:ProgramOutputs
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty nmdc_sfas_brcs:outputs ;
                                                         owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty nmdc_sfas_brcs:program_type ;
                                                         owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty nmdc_sfas_brcs:outputs ;
                                                         owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty nmdc_sfas_brcs:program_type ;
                                                         owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty nmdc_sfas_brcs:predecessor ;
                                                         owl:allValuesFrom xsd:string
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty nmdc_sfas_brcs:program_type ;
                                                         owl:allValuesFrom xsd:string
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty nmdc_sfas_brcs:predecessor ;
                                                         owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                       ] ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty nmdc_sfas_brcs:predecessor ;
                                                         owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                       ] ;
                                       rdfs:label "BioenergyResearchCenter" ;
                                       skos:definition "A DOE Bioenergy Research Center (BRC). BRCs are large-scale, multi-institutional research centers focused on developing sustainable biofuels and bioproducts from plant biomass. The BRC program is part of the Genomic Science portfolio within DOE's Office of Science Office of Biological and Environmental Research." ;
                                       skos:exactMatch <http://purl.obolibrary.org/obo/OBI_0000835> ;
                                       skos:inScheme <https://w3id.org/nmdc/sfas-brcs> .


###  https://w3id.org/nmdc/sfas-brcs/Capability
nmdc_sfas_brcs:Capability rdf:type owl:Class .


###  https://w3id.org/nmdc/sfas-brcs/CollectionMetadata
nmdc_sfas_brcs:CollectionMetadata rdf:type owl:Class ;
                                  rdfs:subClassOf linkml:ClassDefinition ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty nmdc_sfas_brcs:compiled_date ;
                                                    owl:allValuesFrom xsd:string
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty nmdc_sfas_brcs:notes ;
                                                    owl:allValuesFrom xsd:string
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty nmdc_sfas_brcs:sources ;
                                                    owl:allValuesFrom xsd:string
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty nmdc_sfas_brcs:compiled_date ;
                                                    owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty nmdc_sfas_brcs:notes ;
                                                    owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty nmdc_sfas_brcs:sources ;
                                                    owl:minCardinality "0"^^xsd:nonNegativeInteger
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty nmdc_sfas_brcs:compiled_date ;
                                                    owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty nmdc_sfas_brcs:notes ;
                                                    owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                  ] ;
                                  rdfs:label "CollectionMetadata" ;
                                  skos:definition "Metadata about the research program collection" ;
                                  skos:inScheme <https://w3id.org/nmdc/sfas-brcs> .


###  https://w3id.org/nmdc/sfas-brcs/DataCollectionModality
nmdc_sfas_brcs:DataCollectionModality rdf:type owl:Class ;
                                      owl:equivalentClass [ rdf:type owl:Class ;
                                                            owl:unionOf ( <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#BACTERIAL_ISOLATION>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#BIOIMAGING>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#CHEMICAL_IMAGING>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#COMMON_GARDEN_EXPERIMENTS>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#COMPUTATIONAL_MODELING>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#CRISPR_GENE_EDITING>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#ECOSYSTEM_MODELING>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#FABRICATED_ECOSYSTEMS>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#FERMENTATION_STUDIES>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#FIELD_EXPERIMENTS>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#FIELD_SENSORS>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#FIELD_TRIALS>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#GENOME_SCALE_ENGINEERING>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#GENOME_SEQUENCING>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#GENOME_WIDE_ASSOCIATION>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#GREENHOUSE_STUDIES>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#GROUNDWATER_MONITORING>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#HIGH_THROUGHPUT_PHENOTYPING>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#HIGH_THROUGHPUT_SCREENING>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#HIGH_THROUGHPUT_SEQUENCING>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#IMAGING>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#LABORATORY_EXPERIMENTS>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#LABORATORY_FERMENTATION>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#LIVE_CELL_IMAGING>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#LONG_TERM_ECOLOGICAL_RESEARCH>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#MASS_SPECTROMETRY>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#METABOLIC_FLUX_ANALYSIS>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#METAGENOMICS>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#MULTI_OMICS>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#NANOSIMS>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#NMR_SPECTROSCOPY>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#RADIOISOTOPE_APPROACHES>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#REMOTE_SENSING>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#ROBOTIC_AUTOMATION>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#STABLE_ISOTOPE_PROBING>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#STREAM_SAMPLING>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#SYNCHROTRON_METHODS>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#TARGETED_METAGENOMICS>
                                                                          <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#TECHNO_ECONOMIC_ANALYSIS>
                                                                        )
                                                          ] ;
                                      rdfs:subClassOf linkml:EnumDefinition ;
                                      rdfs:label "DataCollectionModality" ;
                                      skos:definition "Methods and modalities for data collection" ;
                                      skos:inScheme <https://w3id.org/nmdc/sfas-brcs> ;
                                      linkml:permissible_values <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#BACTERIAL_ISOLATION> ,
                                                                <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#BIOIMAGING> ,
                                                                <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#CHEMICAL_IMAGING> ,
                                                                <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#COMMON_GARDEN_EXPERIMENTS> ,
                                                                <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#COMPUTATIONAL_MODELING> ,
                                                                <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#CRISPR_GENE_EDITING> ,
                                                                <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#ECOSYSTEM_MODELING> ,
                                                                <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#FABRICATED_ECOSYSTEMS> ,
                                                                <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#FERMENTATION_STUDIES> ,
                                                                <https://w3id.org/nmdc/sfas-brcs/DataCollectionModality#FIELD_EXPERIMENTS> ,
