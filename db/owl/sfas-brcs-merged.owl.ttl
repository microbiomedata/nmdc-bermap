###  https://w3id.org/nmdc/sfas-brcs/pnnl_soil_microbiome
nmdc_sfas_brcs:pnnl_soil_microbiome rdf:type owl:NamedIndividual ,
                                             nmdc_sfas_brcs:ScientificFocusArea ;
                                    schema1:alternateName "Soil Microbiome SFA" ;
                                    schema1:description """PNNL's Soil Microbiome SFA focuses on understanding how interactions among soil microbial community members lead to emergence of community functions. Research identifies molecular-level metabolic interactions governing decomposition and moisture effects on microbial phenotypes.
""" ;
                                    schema1:keywords "CARBON_USE_EFFICIENCY" ,
                                                     "DECOMPOSITION" ,
                                                     "METAPHENOME" ,
                                                     "MICROBIAL_INTERACTIONS" ,
                                                     "MOISTURE_EFFECTS" ,
                                                     "SOIL_MICROBIOME" ,
