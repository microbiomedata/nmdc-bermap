                                                    nmdc_sfas_brcs:agency "DOE BER" ;
                                                    nmdc_sfas_brcs:program "Environmental System Science (ESS)" ;
                                                    nmdc_sfas_brcs:subprogram "Subsurface Biogeochemical Research"
                                                  ] ;
                           nmdc_sfas_brcs:lead_institution "Argonne National Laboratory" ;
                           nmdc_sfas_brcs:partner_institutions "Bulgarian Academy of Science" ,
                                                               "Illinois Institute of Technology" ,
                                                               "Savannah River National Laboratory" ,
                                                               "University of Georgia (Savannah River Ecology Laboratory)" ;
                           nmdc_sfas_brcs:principal_investigators [ rdf:type schema1:Person ;
                                                                    schema1:name "Ken Kemner" ;
                                                                    nmdc_sfas_brcs:affiliation "Argonne National Laboratory" ;
                                                                    nmdc_sfas_brcs:expertise "Biogeochemistry, Synchrotron Science" ;
                                                                    nmdc_sfas_brcs:role "Principal Investigator"
                                                                  ] ;
                           nmdc_sfas_brcs:program_type "SCIENTIFIC_FOCUS_AREA" ;
                           nmdc_sfas_brcs:scientific_questions "How do contaminants transform in wetland environments?" ,
                                                               "How do wetlands control elemental transformations and transport?" ,
                                                               "What processes regulate carbon and nutrient cycling in wetlands?" ,
                                                               "What role does hydrology play in wetland biogeochemistry?" ;
                           nmdc_sfas_brcs:sfa_type "ENVIRONMENTAL_SYSTEM_SCIENCE_SFA" ;
                           nmdc_sfas_brcs:websites [ rdf:type nmdc_sfas_brcs:WebResources ;
                                                     nmdc_sfas_brcs:anl_page "https://www.anl.gov/bio/subsurface-biogeochemical-research"^^xsd:anyURI ;
                                                     nmdc_sfas_brcs:doe_page "https://ess.science.energy.gov/anl-wetland-sfa/"^^xsd:anyURI
                                                   ] .


[ rdf:type nmdc_sfas_brcs:ResearchProgramCollection ;
  nmdc_sfas_brcs:bioenergy_research_centers nmdc_sfas_brcs:cabbi ,
