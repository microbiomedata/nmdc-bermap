###  https://w3id.org/nmdc/sfas-brcs/Location
nmdc_sfas_brcs:Location rdf:type owl:Class ;
                        rdfs:subClassOf linkml:ClassDefinition ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty nmdc_sfas_brcs:address ;
                                          owl:allValuesFrom xsd:string
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty nmdc_sfas_brcs:city ;
                                          owl:allValuesFrom xsd:string
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty nmdc_sfas_brcs:country ;
                                          owl:allValuesFrom xsd:string
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty nmdc_sfas_brcs:state ;
                                          owl:allValuesFrom xsd:string
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty nmdc_sfas_brcs:address ;
                                          owl:minCardinality "0"^^xsd:nonNegativeInteger
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty nmdc_sfas_brcs:city ;
                                          owl:minCardinality "0"^^xsd:nonNegativeInteger
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty nmdc_sfas_brcs:country ;
                                          owl:minCardinality "0"^^xsd:nonNegativeInteger
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty nmdc_sfas_brcs:state ;
                                          owl:minCardinality "0"^^xsd:nonNegativeInteger
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty nmdc_sfas_brcs:address ;
                                          owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty nmdc_sfas_brcs:city ;
                                          owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty nmdc_sfas_brcs:country ;
                                          owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty nmdc_sfas_brcs:state ;
                                          owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                        ] ;
                        rdfs:label "Location" ;
                        skos:definition "Geographic location information for a research program" ;
                        skos:inScheme <https://w3id.org/nmdc/sfas-brcs> .


