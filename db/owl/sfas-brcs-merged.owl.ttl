                                                                               schema1:description "Gas chromatography-mass spectrometry" ;
                                                                               schema1:name "GC-MS Instruments" ;
                                                                               nmdc_sfas_brcs:count 4 ;
                                                                               nmdc_sfas_brcs:instrument_type "GC"
                                                                             ] ,
                                                                             [ rdf:type nmdc_sfas_brcs:Instrument ;
