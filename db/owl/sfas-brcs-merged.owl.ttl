###  https://w3id.org/nmdc/sfas-brcs/llnl_secure_biosystems
nmdc_sfas_brcs:llnl_secure_biosystems rdf:type owl:NamedIndividual ,
                                               nmdc_sfas_brcs:ScientificFocusArea ;
                                      schema1:description "This SFA engineers plant-benefiting microbes for safe and effective deployment in the rhizosphere as plant-promoting probiotics. Develops multilayered containment strategies including kill-switches and gene overlap for circuit stability. Leverages LLNL Soil Microbiome SFA expertise to test containment designs in soil and rhizosphere environments." ;
                                      schema1:keywords "BIOCONTAINMENT" ,
                                                       "MACHINE_LEARNING" ,
                                                       "PLANT_GROWTH_PROMOTING_BACTERIA" ,
                                                       "RHIZOSPHERE" ,
                                                       "SHEWANELLA" ,
                                                       "SYNTHETIC_BIOLOGY" ;
                                      schema1:name "Secure Biosystems Design Scientific Focus Area" ;
                                      nmdc_sfas_brcs:co_investigators [ rdf:type schema1:Person ;
                                                                        schema1:name "Jonathan Allen" ;
                                                                        nmdc_sfas_brcs:expertise "machine learning for sequence design"
                                                                      ] ,
