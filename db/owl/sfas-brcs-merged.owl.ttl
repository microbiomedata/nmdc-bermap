                                                ] ,
                                                [ rdf:type nmdc_sfas_brcs:Capability ;
                                                  schema1:description "Robust solid- and liquid-state NMR capabilities for structural biology, metabolomics, natural products, and organic matter characterization. Non-destructive with minimal sample preparation." ;
                                                  schema1:name "NMR Spectroscopy" ;
                                                  nmdc_sfas_brcs:applications "Metabolomics" ,
                                                                              "Natural products" ,
                                                                              "Organic matter characterization" ,
                                                                              "Structural biology" ;
