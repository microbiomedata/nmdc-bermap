                                                                             "HIGH_THROUGHPUT_SCREENING" ,
                                                                             "HIGH_THROUGHPUT_SEQUENCING" ;
                                   nmdc_sfas_brcs:data_types <http://purl.obolibrary.org/obo/OBI_0000626> ,
                                                             "CONTAINMENT_EFFICACY_DATA" ,
                                                             "FITNESS_DATA" ;
                                   nmdc_sfas_brcs:funding [ rdf:type nmdc_sfas_brcs:FundingInfo ;
