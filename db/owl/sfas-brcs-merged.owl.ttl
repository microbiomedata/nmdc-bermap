                                                                               schema1:description "Optical density and fluorescence measurements" ;
                                                                               schema1:name "Fluorescence/Absorbance Readers" ;
                                                                               nmdc_sfas_brcs:instrument_type "PLATE_READER"
                                                                             ] ,
