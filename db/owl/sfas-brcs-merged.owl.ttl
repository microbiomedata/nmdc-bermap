                                                                               schema1:description "For structural biology and materials" ;
                                                                               schema1:name "Solid-State NMR" ;
                                                                               nmdc_sfas_brcs:instrument_type "NMR_SPECTROMETER"
                                                                             ] ,
                                                                             [ rdf:type nmdc_sfas_brcs:Instrument ;
                                                                               schema1:description "For metabolomics and natural products" ;
                                                                               schema1:name "Liquid-State NMR" ;
                                                                               nmdc_sfas_brcs:instrument_type "NMR_SPECTROMETER"
                                                                             ] ;
                                                  nmdc_sfas_brcs:status "OPERATIONAL" ;
                                                  nmdc_sfas_brcs:url "https://www.emsl.pnnl.gov/science/instruments-resources/liquid-state-nmr-metabolomics"^^xsd:anyURI
                                                ] ,
                                                [ rdf:type nmdc_sfas_brcs:Capability ;
                                                  schema1:description "Automated phenotyping platform for accelerating anaerobic microbiology research. 18 instruments in anaerobic pods connected by robotic track system enabling high-throughput characterization with minimal operator intervention. Generates reproducible, shareable datasets for predictive model development." ;
                                                  schema1:name "Anaerobic Microbial Phenotyping Platform (AMP2)" ;
                                                  nmdc_sfas_brcs:applications "Anaerobic microbe characterization" ,
