###  https://w3id.org/nmdc/sfas-brcs/ror_id
nmdc_sfas_brcs:ror_id rdf:type owl:DatatypeProperty ;
                      rdfs:range [ rdf:type rdfs:Datatype ;
                                   owl:intersectionOf ( xsd:anyURI
                                                        [ rdf:type rdfs:Datatype ;
                                                          owl:onDatatype xsd:string ;
                                                          owl:withRestrictions ( [ xsd:pattern "^ror:\\d{9}$"
                                                                                 ]
                                                                               )
                                                        ]
                                                      )
                                 ] ;
                      rdfs:label "ror_id" ;
                      skos:definition "Research Organization Registry identifier" ;
                      skos:inScheme <https://w3id.org/nmdc/sfas-brcs> .


