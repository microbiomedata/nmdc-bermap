###  https://w3id.org/nmdc/sfas-brcs/wetland_resilience
nmdc_sfas_brcs:wetland_resilience rdf:type owl:NamedIndividual ,
                                           nmdc_sfas_brcs:ScientificFocusArea ;
                                  schema1:alternateName "Wetland Function SFA" ;
                                  schema1:description "Develops mechanistic understanding of how climatic conditions affect terrestrial wetland ecosystem function, particularly carbon dynamics. Organized around three themes: fine-scale hydro-biogeochemical mechanisms controlling C cycling and GHG emissions, above/belowground processes and interactions, and model integration at fine and intermediate scales." ;
                                  schema1:keywords "CARBON_CYCLING" ,
                                                   "ENVIRONMENTAL_CHANGE" ,
                                                   "NUTRIENT_CYCLING" ,
                                                   "WETLAND_RESILIENCE" ;
                                  schema1:name "Terrestrial Wetland Function and Resilience Science Focus Area" ;
                                  nmdc_sfas_brcs:data_types "BIOGEOCHEMICAL_DATA" ,
                                                            "ENVIRONMENTAL_SENSOR_DATA" ,
                                                            "WATER_CHEMISTRY" ;
                                  nmdc_sfas_brcs:field_sites [ rdf:type nmdc_sfas_brcs:FieldSite ;
                                                               schema1:description "Headwater system within the Upper Colorado River Basin" ;
                                                               schema1:name "Upper Colorado River Basin - East River" ;
                                                               nmdc_sfas_brcs:location "Colorado"
                                                             ] ,
                                                             [ rdf:type nmdc_sfas_brcs:FieldSite ;
                                                               schema1:description "Expansion site within UCRB" ;
                                                               schema1:name "Taylor River Watershed" ;
                                                               nmdc_sfas_brcs:location "Colorado"
                                                             ] ,
                                                             [ rdf:type nmdc_sfas_brcs:FieldSite ;
                                                               schema1:description "Depressional wetland complex in the Prairie Pothole Region" ;
                                                               schema1:name "Cottonwood Lake Study Area" ;
                                                               nmdc_sfas_brcs:location "North Dakota"
                                                             ] ;
                                  nmdc_sfas_brcs:funding [ rdf:type nmdc_sfas_brcs:FundingInfo ;
                                                           nmdc_sfas_brcs:agency "DOE BER" ;
                                                           nmdc_sfas_brcs:program "Environmental System Science (ESS)"
                                                         ] ;
                                  nmdc_sfas_brcs:lead_institution "Argonne National Laboratory" ;
                                  nmdc_sfas_brcs:partner_institutions "Bulgarian Academy of Sciences" ,
                                                                      "Lawrence Livermore National Laboratory" ,
                                                                      "U.S. Geological Survey" ,
                                                                      "University of Minnesota" ,
                                                                      "University of Nevada" ;
                                  nmdc_sfas_brcs:principal_investigators [ rdf:type schema1:Person ;
                                                                           schema1:name "Roser Matamala" ;
                                                                           nmdc_sfas_brcs:affiliation "Argonne National Laboratory" ;
                                                                           nmdc_sfas_brcs:expertise "Terrestrial Ecology" ;
                                                                           nmdc_sfas_brcs:role "Principal Investigator"
                                                                         ] ;
                                  nmdc_sfas_brcs:program_type "SCIENTIFIC_FOCUS_AREA" ;
                                  nmdc_sfas_brcs:scientific_questions "How can we integrate mechanistic understanding into ESM land components?" ,
                                                                      "How do above and belowground processes interact in wetlands?" ,
                                                                      "How do climatic conditions affect wetland ecosystem function?" ,
                                                                      "What mechanisms control carbon cycling and GHG emissions in wetland soils?" ;
                                  nmdc_sfas_brcs:sfa_type "ENVIRONMENTAL_SYSTEM_SCIENCE_SFA" ;
                                  nmdc_sfas_brcs:websites [ rdf:type nmdc_sfas_brcs:WebResources ;
                                                            nmdc_sfas_brcs:doe_page "https://ess.science.energy.gov/wetland-function-and-resilience-sfa/"^^xsd:anyURI
                                                          ] .


