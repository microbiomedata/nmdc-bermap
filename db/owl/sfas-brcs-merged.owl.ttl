                                                                         "COMPETITION_ASSAYS" ,
                                                                         "GROWTH_CURVES" ,
                                                                         "PLANT_COLONIZATION" ;
                                         nmdc_sfas_brcs:principal_investigators [ rdf:type schema1:Person ;
                                                                                  schema1:name "Trent Northen" ;
                                                                                  nmdc_sfas_brcs:affiliation "Lawrence Berkeley National Laboratory" ;
                                                                                  nmdc_sfas_brcs:role "Principal Investigator"
                                                                                ] ;
                                         nmdc_sfas_brcs:program_type "BIOPREPAREDNESS_INITIATIVE" ;
                                         nmdc_sfas_brcs:scientific_questions "How can we engineer disease-resilient bioenergy crops?" ,
                                                                             "How do biocontrol bacteria protect sorghum from anthracnose disease?" ,
                                                                             "What molecular mechanisms underlie sorghum-Colletotrichum pathogenic interactions?" ;
