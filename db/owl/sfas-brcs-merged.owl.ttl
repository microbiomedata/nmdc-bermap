                                                          "FUNGAL_PATHOGENS" ,
                                                          "PLANT_MICROBE_INTERACTIONS" ,
                                                          "SORGHUM" ;
                                         schema1:name "Sorghum-Anthracnose-Biocontrol Interactions" ;
                                         nmdc_sfas_brcs:data_types <http://purl.obolibrary.org/obo/OBI_0000366> ,
                                                                   <http://purl.obolibrary.org/obo/OBI_0000424> ,
                                                                   <http://purl.obolibrary.org/obo/OBI_0002623> ;
                                         nmdc_sfas_brcs:funding [ rdf:type nmdc_sfas_brcs:FundingInfo ;
                                                                  nmdc_sfas_brcs:agency "DOE BER" ;
                                                                  nmdc_sfas_brcs:program "Biopreparedness Research Virtual Environment (BRaVE)"
                                                                ] ;
                                         nmdc_sfas_brcs:funding_period "2023-2026" ;
                                         nmdc_sfas_brcs:initiative_name "BRaVE" ;
                                         nmdc_sfas_brcs:isolate_collections [ rdf:type nmdc_sfas_brcs:IsolateCollection ;
                                                                              schema1:description "Colletotrichum sublineola isolates causing anthracnose disease in sorghum." ;
                                                                              schema1:name "Colletotrichum Pathogen Collection" ;
                                                                              nmdc_sfas_brcs:organism_types <http://purl.obolibrary.org/obo/NCBITaxon_4751> ;
                                                                              nmdc_sfas_brcs:source_environments "Infected sorghum tissue"
                                                                            ] ,
                                                                            [ rdf:type nmdc_sfas_brcs:IsolateCollection ;
                                                                              schema1:description "Bacterial isolates with biocontrol activity against Colletotrichum sublineola, collected from sorghum rhizosphere and phyllosphere." ;
                                                                              schema1:name "Sorghum-Associated Bacterial Collection" ;
                                                                              nmdc_sfas_brcs:host_organisms "Sorghum bicolor" ;
                                                                              nmdc_sfas_brcs:organism_types <http://purl.obolibrary.org/obo/NCBITaxon_2> ;
                                                                              nmdc_sfas_brcs:source_environments "Sorghum phyllosphere" ,
                                                                                                                 "Sorghum rhizosphere"
                                                                            ] ;
