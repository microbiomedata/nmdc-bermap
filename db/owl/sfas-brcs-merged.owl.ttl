###  https://w3id.org/nmdc/sfas-brcs/actinides_sfa
nmdc_sfas_brcs:actinides_sfa rdf:type owl:NamedIndividual ,
                                      nmdc_sfas_brcs:ScientificFocusArea ;
                             schema1:description """This SFA investigates biogeochemistry at interfaces, with particular focus on actinide behavior in environmental systems.
""" ;
                             schema1:keywords "ACTINIDES" ,
                                              "BIOGEOCHEMISTRY" ,
                                              "ENVIRONMENTAL_SYSTEMS" ,
                                              "INTERFACES" ;
                             schema1:name "BioGeoChemistry at Interfaces Science Focus Area" ;
                             nmdc_sfas_brcs:funding [ rdf:type nmdc_sfas_brcs:FundingInfo ;
                                                      nmdc_sfas_brcs:agency "DOE BER" ;
                                                      nmdc_sfas_brcs:program "Environmental System Science (ESS)"
                                                    ] ;
                             nmdc_sfas_brcs:lead_institution "Lawrence Livermore National Laboratory" ;
                             nmdc_sfas_brcs:program_type "SCIENTIFIC_FOCUS_AREA" ;
                             nmdc_sfas_brcs:sfa_type "ENVIRONMENTAL_SYSTEM_SCIENCE_SFA" ;
                             nmdc_sfas_brcs:websites [ rdf:type nmdc_sfas_brcs:WebResources ;
                                                       nmdc_sfas_brcs:doe_page "https://ess.science.energy.gov/llnl-actinides-sfa/"^^xsd:anyURI
                                                     ] .


###  https://w3id.org/nmdc/sfas-brcs/bfi
nmdc_sfas_brcs:bfi rdf:type owl:NamedIndividual ,
                            nmdc_sfas_brcs:ScientificFocusArea ;
                   schema1:alternateName "BFI" ;
                   schema1:description """The BFI SFA discovers fundamental principles underlying bacterial-fungal interactions to harness their biotechnological potential for steering soil ecosystem functions. Research uses novel bioinformatics and multiomics approaches to understand how bacteria and fungi sense, respond to, and co-evolve with one another.
""" ;
                   schema1:keywords "BACTERIAL_FUNGAL_INTERACTIONS" ,
                                    "CARBON_FLUX" ,
                                    "CO_EVOLUTION" ,
                                    "NUTRIENT_CYCLING" ,
                                    "PLANT_PRODUCTIVITY" ,
                                    "SOIL_MICROBIOME" ;
                   schema1:name "Bacterial-Fungal Interactions and Their Role in Soil Functioning" ;
                   nmdc_sfas_brcs:data_collection_modalities "COMPUTATIONAL_MODELING" ,
                                                             "IMAGING" ,
                                                             "MULTI_OMICS" ,
                                                             "TARGETED_METAGENOMICS" ;
                   nmdc_sfas_brcs:data_types <http://purl.obolibrary.org/obo/OBI_0000366> ,
                                             <http://purl.obolibrary.org/obo/OBI_0000424> ,
                                             <http://purl.obolibrary.org/obo/OBI_0002623> ,
                                             "IMAGING_DATA" ;
                   nmdc_sfas_brcs:datasets [ rdf:type nmdc_sfas_brcs:Dataset ;
                                             schema1:description "Database of known bacterial-fungal interactions and participating taxa" ;
                                             schema1:name "BFI Research Portal Database" ;
                                             schema1:url "https://sfa-bfi.edgebioinformatics.org/search"^^xsd:anyURI
                                           ] ;
                   nmdc_sfas_brcs:funding [ rdf:type nmdc_sfas_brcs:FundingInfo ;
                                            nmdc_sfas_brcs:agency "DOE BER" ;
                                            nmdc_sfas_brcs:division "Biological Systems Science Division" ;
                                            nmdc_sfas_brcs:grant "LANLF59T" ;
                                            nmdc_sfas_brcs:program "Genomic Science Program"
                                          ] ;
                   nmdc_sfas_brcs:lead_institution "Los Alamos National Laboratory" ;
                   nmdc_sfas_brcs:principal_investigators [ rdf:type schema1:Person ;
                                                            schema1:name "Patrick Chain" ;
                                                            nmdc_sfas_brcs:affiliation "Los Alamos National Laboratory" ;
                                                            nmdc_sfas_brcs:role "Principal Investigator"
                                                          ] ;
                   nmdc_sfas_brcs:program_type "SCIENTIFIC_FOCUS_AREA" ;
                   nmdc_sfas_brcs:scientific_questions "How can we steer ecosystem functions through BFI manipulation?" ,
                                                       "How do BFI affect carbon flux and nutrient cycling?" ,
                                                       "What molecular mechanisms mediate BFI?" ,
                                                       "What principles drive bacterial-fungal interactions in soil?" ;
                   nmdc_sfas_brcs:sfa_type "GENOMIC_SCIENCE_SFA" ;
                   nmdc_sfas_brcs:websites [ rdf:type nmdc_sfas_brcs:WebResources ;
                                             nmdc_sfas_brcs:bfi_portal "https://sfa-bfi.edgebioinformatics.org/search"^^xsd:anyURI ;
                                             nmdc_sfas_brcs:doe_page "https://www.genomicscience.energy.gov/lanlbfi/"^^xsd:anyURI ;
                                             nmdc_sfas_brcs:kbase "https://www.kbase.us/research/chain-sfa/"^^xsd:anyURI
                                           ] .


###  https://w3id.org/nmdc/sfas-brcs/cabbi
nmdc_sfas_brcs:cabbi rdf:type owl:NamedIndividual ,
                              <http://purl.obolibrary.org/obo/OBI_0000835> ;
                     schema1:alternateName "CABBI" ;
                     schema1:description """CABBI develops fuels and products by integrating feedstock development, conversion science, and sustainability research. Using a \"plants as factories\" approach, CABBI researchers engineer crops to accumulate lipids and specialty chemicals while developing novel conversion technologies.
""" ;
                     schema1:keywords "BIOPRODUCTS" ,
                                      "LIFE_CYCLE_ASSESSMENT" ,
                                      "LIPID_ACCUMULATION" ,
                                      "METABOLIC_ENGINEERING" ,
                                      "MISCANTHUS" ,
                                      "OIL_CROPS" ,
                                      "SORGHUM" ,
                                      "SUGARCANE" ,
                                      "SUSTAINABILITY" ;
                     schema1:name "Center for Advanced Bioenergy and Bioproducts Innovation" ;
                     nmdc_sfas_brcs:data_collection_modalities "ECOSYSTEM_MODELING" ,
                                                               "FIELD_EXPERIMENTS" ,
                                                               "GREENHOUSE_STUDIES" ,
                                                               "METABOLIC_FLUX_ANALYSIS" ,
                                                               "TECHNO_ECONOMIC_ANALYSIS" ;
                     nmdc_sfas_brcs:data_types <http://purl.obolibrary.org/obo/OBI_0000366> ,
                                               <http://purl.obolibrary.org/obo/OBI_0000424> ,
                                               <http://purl.obolibrary.org/obo/OBI_0000626> ,
                                               "ECONOMIC_MODELING_DATA" ,
                                               "FIELD_TRIAL_DATA" ,
