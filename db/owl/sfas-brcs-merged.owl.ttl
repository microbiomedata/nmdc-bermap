                   nmdc_sfas_brcs:isolate_collections [ rdf:type nmdc_sfas_brcs:IsolateCollection ;
                                                        schema1:description "Bacterial isolates from native, field, and greenhouse-grown Populus trees. Includes rhizosphere, endosphere, and phyllosphere isolates characterized by 16S rDNA sequencing with full genome sequences for many strains." ;
