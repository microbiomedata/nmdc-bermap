#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/nmdc/sfas-brcs/bioenergy_research_centers
nmdc_sfas_brcs:bioenergy_research_centers rdf:type owl:ObjectProperty .


###  https://w3id.org/nmdc/sfas-brcs/co_investigators
nmdc_sfas_brcs:co_investigators rdf:type owl:ObjectProperty ;
                                rdfs:range nmdc_sfas_brcs:Person .


###  https://w3id.org/nmdc/sfas-brcs/data_collection_modalities
nmdc_sfas_brcs:data_collection_modalities rdf:type owl:ObjectProperty ;
                                          rdfs:range nmdc_sfas_brcs:DataCollectionModality .


###  https://w3id.org/nmdc/sfas-brcs/data_types
nmdc_sfas_brcs:data_types rdf:type owl:ObjectProperty ;
                          rdfs:range nmdc_sfas_brcs:DataType .


###  https://w3id.org/nmdc/sfas-brcs/datasets
nmdc_sfas_brcs:datasets rdf:type owl:ObjectProperty ;
                        rdfs:range nmdc_sfas_brcs:Dataset .


###  https://w3id.org/nmdc/sfas-brcs/environmental_system_science_sfas
nmdc_sfas_brcs:environmental_system_science_sfas rdf:type owl:ObjectProperty .


###  https://w3id.org/nmdc/sfas-brcs/field_sites
nmdc_sfas_brcs:field_sites rdf:type owl:ObjectProperty ;
                           rdfs:range nmdc_sfas_brcs:FieldSite .


###  https://w3id.org/nmdc/sfas-brcs/flagship_genomes
nmdc_sfas_brcs:flagship_genomes rdf:type owl:ObjectProperty ;
                                rdfs:range nmdc_sfas_brcs:FlagshipGenome .


###  https://w3id.org/nmdc/sfas-brcs/funding
nmdc_sfas_brcs:funding rdf:type owl:ObjectProperty ;
                       rdfs:range nmdc_sfas_brcs:FundingInfo .


###  https://w3id.org/nmdc/sfas-brcs/genomic_science_sfas
nmdc_sfas_brcs:genomic_science_sfas rdf:type owl:ObjectProperty .


###  https://w3id.org/nmdc/sfas-brcs/institution_type
nmdc_sfas_brcs:institution_type rdf:type owl:ObjectProperty ;
                                rdfs:range nmdc_sfas_brcs:InstitutionType ;
                                rdfs:label "institution_type" ;
                                skos:definition "The type of institution" ;
                                skos:inScheme <https://w3id.org/nmdc/sfas-brcs> .


###  https://w3id.org/nmdc/sfas-brcs/key_publications
nmdc_sfas_brcs:key_publications rdf:type owl:ObjectProperty ;
                                rdfs:range nmdc_sfas_brcs:Publication .


###  https://w3id.org/nmdc/sfas-brcs/keywords
nmdc_sfas_brcs:keywords rdf:type owl:ObjectProperty ;
                        rdfs:range nmdc_sfas_brcs:Keyword ;
                        rdfs:label "keywords" ;
                        skos:definition "Keywords describing the research focus" ;
                        skos:inScheme <https://w3id.org/nmdc/sfas-brcs> .


###  https://w3id.org/nmdc/sfas-brcs/location
nmdc_sfas_brcs:location rdf:type owl:ObjectProperty ;
                        rdfs:range nmdc_sfas_brcs:Location .


###  https://w3id.org/nmdc/sfas-brcs/metadata
nmdc_sfas_brcs:metadata rdf:type owl:ObjectProperty .


###  https://w3id.org/nmdc/sfas-brcs/outputs
nmdc_sfas_brcs:outputs rdf:type owl:ObjectProperty ;
                       rdfs:range nmdc_sfas_brcs:ProgramOutputs .


###  https://w3id.org/nmdc/sfas-brcs/principal_investigators
nmdc_sfas_brcs:principal_investigators rdf:type owl:ObjectProperty ;
