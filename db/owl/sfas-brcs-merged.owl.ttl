                                                  nmdc_sfas_brcs:data_products "3D structures" ,
                                                                               "Cellular ultrastructure images" ,
                                                                               "Tomographic reconstructions" ;
                                                  nmdc_sfas_brcs:instruments [ rdf:type nmdc_sfas_brcs:Instrument ;
                                                                               schema1:description "Cryogenic transmission electron microscope for high-resolution imaging" ;
                                                                               schema1:name "Krios G3i" ;
                                                                               nmdc_sfas_brcs:instrument_type "CRYO_TEM" ;
                                                                               nmdc_sfas_brcs:manufacturer "Thermo Scientific"
                                                                             ] ,
