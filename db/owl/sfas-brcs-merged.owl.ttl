###  https://w3id.org/nmdc/sfas-brcs/Institution
nmdc_sfas_brcs:Institution rdf:type owl:Class ;
                           rdfs:subClassOf linkml:ClassDefinition ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty nmdc_sfas_brcs:institution_type ;
                                             owl:allValuesFrom nmdc_sfas_brcs:InstitutionType
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty nmdc_sfas_brcs:institution_type ;
                                             owl:minCardinality "0"^^xsd:nonNegativeInteger
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty nmdc_sfas_brcs:institution_type ;
                                             owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty nmdc_sfas_brcs:description ;
                                             owl:allValuesFrom xsd:string
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty nmdc_sfas_brcs:name ;
                                             owl:allValuesFrom xsd:string
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty nmdc_sfas_brcs:ror_id ;
                                             owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                                                 owl:intersectionOf ( xsd:anyURI
                                                                                      [ rdf:type rdfs:Datatype ;
                                                                                        owl:onDatatype xsd:string ;
                                                                                        owl:withRestrictions ( [ xsd:pattern "^ror:\\d{9}$"
                                                                                                               ]
                                                                                                             )
                                                                                      ]
                                                                                    )
                                                               ]
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty nmdc_sfas_brcs:description ;
                                             owl:minCardinality "0"^^xsd:nonNegativeInteger
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty nmdc_sfas_brcs:name ;
                                             owl:minCardinality "0"^^xsd:nonNegativeInteger
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty nmdc_sfas_brcs:ror_id ;
                                             owl:minCardinality "0"^^xsd:nonNegativeInteger
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty nmdc_sfas_brcs:description ;
                                             owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty nmdc_sfas_brcs:name ;
                                             owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty nmdc_sfas_brcs:ror_id ;
                                             owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                           ] ;
                           rdfs:label "Institution" ;
                           skos:definition "A research institution such as a national laboratory, university, or research institute." ;
                           skos:exactMatch schema1:Organization ;
                           skos:inScheme <https://w3id.org/nmdc/sfas-brcs> .


