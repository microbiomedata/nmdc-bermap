###  https://w3id.org/nmdc/sfas-brcs/name
nmdc_sfas_brcs:name rdf:type owl:DatatypeProperty ;
                    rdfs:range xsd:string ;
                    rdfs:label "name" ;
                    skos:definition "A human-readable name for an entity" ;
                    skos:inScheme <https://w3id.org/nmdc/sfas-brcs> .


###  https://w3id.org/nmdc/sfas-brcs/notes
nmdc_sfas_brcs:notes rdf:type owl:DatatypeProperty .


###  https://w3id.org/nmdc/sfas-brcs/orcid
nmdc_sfas_brcs:orcid rdf:type owl:DatatypeProperty ;
                     rdfs:range [ rdf:type rdfs:Datatype ;
                                  owl:intersectionOf ( xsd:anyURI
                                                       [ rdf:type rdfs:Datatype ;
                                                         owl:onDatatype xsd:string ;
                                                         owl:withRestrictions ( [ xsd:pattern "^orcid:\\d{4}-\\d{4}-\\d{4}-\\d{3}[0-9X]$"
                                                                                ]
                                                                              )
                                                       ]
                                                     )
                                ] ;
                     rdfs:label "orcid" ;
                     skos:definition "ORCID identifier for a person" ;
                     skos:inScheme <https://w3id.org/nmdc/sfas-brcs> .


###  https://w3id.org/nmdc/sfas-brcs/ornl_page
nmdc_sfas_brcs:ornl_page rdf:type owl:DatatypeProperty .


