                                                                               schema1:description "Automated sample preparation in anaerobic environment" ;
                                                                               schema1:name "Liquid Handlers" ;
                                                                               nmdc_sfas_brcs:instrument_type "LIQUID_HANDLER"
                                                                             ] ,
