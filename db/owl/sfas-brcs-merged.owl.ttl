###  https://w3id.org/nmdc/sfas-brcs/seed
nmdc_sfas_brcs:seed rdf:type owl:NamedIndividual ,
                             nmdc_sfas_brcs:ScientificFocusArea ;
                    schema1:alternateName "SEED" ;
                    schema1:description """SEED develops predictive understanding of how microorganisms establish, spread, and influence ecosystems critical to DOE missions. Building on this knowledge, SEED advances biosystems design for ecosystem engineering while providing baseline knowledge for risk assessment and biodefense.
""" ;
                    schema1:keywords "BIODEFENSE" ,
                                     "BIOSECURITY" ,
                                     "BIOSYSTEMS_DESIGN" ,
                                     "ECOSYSTEM_ENGINEERING" ,
                                     "FUNGAL_PATHOGENS" ,
                                     "MICROBIAL_INVASION" ;
                    schema1:name "SEED: Secure Ecosystem Engineering and Design" ;
                    nmdc_sfas_brcs:funding [ rdf:type nmdc_sfas_brcs:FundingInfo ;
                                             nmdc_sfas_brcs:agency "DOE BER" ;
                                             nmdc_sfas_brcs:area "Secure Biosystems Design" ;
                                             nmdc_sfas_brcs:program "Genomic Science Program"
                                           ] ;
                    nmdc_sfas_brcs:lead_institution "Oak Ridge National Laboratory" ;
                    nmdc_sfas_brcs:principal_investigators [ rdf:type schema1:Person ;
                                                             schema1:name "Paul Abraham" ;
                                                             nmdc_sfas_brcs:affiliation "Oak Ridge National Laboratory" ;
                                                             nmdc_sfas_brcs:role "Laboratory Research Manager"
                                                           ] ;
                    nmdc_sfas_brcs:program_type "SCIENTIFIC_FOCUS_AREA" ;
                    nmdc_sfas_brcs:scientific_questions "How can we engineer ecosystems for DOE missions?" ,
                                                        "How do introduced microbes establish and spread in ecosystems?" ,
                                                        "What factors influence microbial invasion success?" ,
                                                        "What risks do engineered organisms pose to ecosystems?" ;
                    nmdc_sfas_brcs:sfa_type "GENOMIC_SCIENCE_SFA" ;
                    nmdc_sfas_brcs:websites [ rdf:type nmdc_sfas_brcs:WebResources ;
                                              nmdc_sfas_brcs:doe_page "https://www.genomicscience.energy.gov/ornlseed/"^^xsd:anyURI ;
                                              nmdc_sfas_brcs:main "https://seed-sfa.ornl.gov"^^xsd:anyURI ;
                                              nmdc_sfas_brcs:ornl_page "https://www.ornl.gov/project/secure-ecosystem-engineering-and-design"^^xsd:anyURI ;
                                              nmdc_sfas_brcs:team "https://seed-sfa.ornl.gov/team/"^^xsd:anyURI
                                            ] .


