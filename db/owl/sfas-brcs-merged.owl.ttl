                                                                             ] ;
                                                  nmdc_sfas_brcs:status "OPERATIONAL" ;
                                                  nmdc_sfas_brcs:url "https://www.emsl.pnnl.gov/science/instruments-resources/metabolomics"^^xsd:anyURI
                                                ] ,
                                                [ rdf:type nmdc_sfas_brcs:Capability ;
                                                  schema1:description "Nanoscale secondary ion mass spectrometry for subcellular-resolution chemical imaging and isotope ratio analysis in biological samples." ;
                                                  schema1:name "NanoSIMS Imaging" ;
                                                  nmdc_sfas_brcs:applications "Element mapping" ,
                                                                              "Isotope probing" ,
                                                                              "Subcellular metabolic imaging" ;
                                                  nmdc_sfas_brcs:capability_type "NANOSIMS_IMAGING" ;
                                                  nmdc_sfas_brcs:status "OPERATIONAL"
                                                ] ;
                    nmdc_sfas_brcs:funding [ rdf:type nmdc_sfas_brcs:FundingInfo ;
