###  https://w3id.org/nmdc/sfas-brcs/ResearchProgramCollection
nmdc_sfas_brcs:ResearchProgramCollection rdf:type owl:Class ;
                                         rdfs:subClassOf linkml:ClassDefinition ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty nmdc_sfas_brcs:bioenergy_research_centers ;
                                                           owl:allValuesFrom nmdc_sfas_brcs:BioenergyResearchCenter
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty nmdc_sfas_brcs:environmental_system_science_sfas ;
                                                           owl:allValuesFrom nmdc_sfas_brcs:ScientificFocusArea
                                                         ] ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty nmdc_sfas_brcs:genomic_science_sfas ;
                                                           owl:allValuesFrom nmdc_sfas_brcs:ScientificFocusArea
