                                nmdc_sfas_brcs:sfa_type "GENOMIC_SCIENCE_SFA" ;
                                nmdc_sfas_brcs:studies [ rdf:type nmdc_sfas_brcs:NMDCStudyReference ;
                                                         schema1:description "Novel method for radiocarbon analysis of soil microbial biomass via direct chloroform extraction. Enables measurement of microbial C turnover." ;
                                                         schema1:name "Radiocarbon Analysis of Soil Microbial Biomass" ;
