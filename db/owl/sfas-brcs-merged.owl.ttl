                                                                             ] ,
                                                                             [ rdf:type nmdc_sfas_brcs:Instrument ;
                                                                               schema1:description "For sensitive targeted quantification and metabolic flux measurements" ;
                                                                               schema1:name "Triple Quadrupole MS" ;
                                                                               nmdc_sfas_brcs:count 9 ;
                                                                               nmdc_sfas_brcs:instrument_type "TRIPLE_QUADRUPOLE"
                                                                             ] ,
