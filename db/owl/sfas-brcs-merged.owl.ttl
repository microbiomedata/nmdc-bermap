nmdc_sfas_brcs:program_type rdf:type owl:ObjectProperty ;
                            rdfs:range nmdc_sfas_brcs:ProgramType .


###  https://w3id.org/nmdc/sfas-brcs/reference_data
nmdc_sfas_brcs:reference_data rdf:type owl:ObjectProperty ;
                              rdfs:range nmdc_sfas_brcs:ReferenceData .


###  https://w3id.org/nmdc/sfas-brcs/sfa_type
nmdc_sfas_brcs:sfa_type rdf:type owl:ObjectProperty ;
                        rdfs:range nmdc_sfas_brcs:SFAType .


###  https://w3id.org/nmdc/sfas-brcs/technologies_developed
nmdc_sfas_brcs:technologies_developed rdf:type owl:ObjectProperty ;
                                      rdfs:range nmdc_sfas_brcs:Technology .


###  https://w3id.org/nmdc/sfas-brcs/user_facilities
nmdc_sfas_brcs:user_facilities rdf:type owl:ObjectProperty .


###  https://w3id.org/nmdc/sfas-brcs/websites
nmdc_sfas_brcs:websites rdf:type owl:ObjectProperty ;
                        rdfs:range nmdc_sfas_brcs:WebResources .


