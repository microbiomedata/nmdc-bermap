@prefix : <https://w3id.org/nmdc/sfas-brcs#> .
@prefix OBI: <http://purl.obolibrary.org/obo/OBI_> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix schema1: <http://schema.org/> .
@prefix nmdc_sfas_brcs: <https://w3id.org/nmdc/sfas-brcs/> .
@base <https://w3id.org/nmdc/sfas-brcs> .

<https://w3id.org/nmdc/sfas-brcs> rdf:type owl:Ontology ;
                                   dcterms:license "MIT" ;
                                   dcterms:title "NMDC SFAs and BRCs Schema" ;
                                   rdfs:label "nmdc-sfas-brcs" ;
                                   rdfs:seeAlso <https://ess.science.energy.gov> ,
                                                <https://www.genomicscience.energy.gov> ,
                                                <https://science.osti.gov/ber> ;
                                   skos:definition """A LinkML schema for representing DOE BER (Biological and Environmental Research)
funded Scientific Focus Areas (SFAs) and Bioenergy Research Centers (BRCs),
including their metadata, datasets, publications, and organizational structure.""" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty .


###  http://schema.org/alternateName
schema1:alternateName rdf:type owl:AnnotationProperty .


###  http://schema.org/description
schema1:description rdf:type owl:AnnotationProperty .


###  http://schema.org/email
schema1:email rdf:type owl:AnnotationProperty .


###  http://schema.org/keywords
schema1:keywords rdf:type owl:AnnotationProperty .


###  http://schema.org/name
schema1:name rdf:type owl:AnnotationProperty .


###  http://schema.org/url
schema1:url rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#exactMatch
skos:exactMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#inScheme
skos:inScheme rdf:type owl:AnnotationProperty .


###  https://w3id.org/linkml/permissible_values
linkml:permissible_values rdf:type owl:AnnotationProperty .


###  https://w3id.org/nmdc/sfas-brcs/applications
nmdc_sfas_brcs:applications rdf:type owl:AnnotationProperty .


###  https://w3id.org/nmdc/sfas-brcs/capabilities
nmdc_sfas_brcs:capabilities rdf:type owl:AnnotationProperty .


###  https://w3id.org/nmdc/sfas-brcs/capability_type
nmdc_sfas_brcs:capability_type rdf:type owl:AnnotationProperty .


###  https://w3id.org/nmdc/sfas-brcs/data_products
nmdc_sfas_brcs:data_products rdf:type owl:AnnotationProperty .


###  https://w3id.org/nmdc/sfas-brcs/instrument_type
nmdc_sfas_brcs:instrument_type rdf:type owl:AnnotationProperty .


###  https://w3id.org/nmdc/sfas-brcs/instruments
nmdc_sfas_brcs:instruments rdf:type owl:AnnotationProperty .


###  https://w3id.org/nmdc/sfas-brcs/manufacturer
nmdc_sfas_brcs:manufacturer rdf:type owl:AnnotationProperty .


###  https://w3id.org/nmdc/sfas-brcs/specifications
nmdc_sfas_brcs:specifications rdf:type owl:AnnotationProperty .


###  https://w3id.org/nmdc/sfas-brcs/status
nmdc_sfas_brcs:status rdf:type owl:AnnotationProperty .


###  https://w3id.org/nmdc/sfas-brcs/throughput
nmdc_sfas_brcs:throughput rdf:type owl:AnnotationProperty .


###  https://w3id.org/nmdc/sfas-brcs/year_established
nmdc_sfas_brcs:year_established rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/nmdc/sfas-brcs/bioenergy_research_centers
nmdc_sfas_brcs:bioenergy_research_centers rdf:type owl:ObjectProperty .


###  https://w3id.org/nmdc/sfas-brcs/co_investigators
nmdc_sfas_brcs:co_investigators rdf:type owl:ObjectProperty ;
                                rdfs:range nmdc_sfas_brcs:Person .


###  https://w3id.org/nmdc/sfas-brcs/data_collection_modalities
nmdc_sfas_brcs:data_collection_modalities rdf:type owl:ObjectProperty ;
                                          rdfs:range nmdc_sfas_brcs:DataCollectionModality .


###  https://w3id.org/nmdc/sfas-brcs/data_types
nmdc_sfas_brcs:data_types rdf:type owl:ObjectProperty ;
                          rdfs:range nmdc_sfas_brcs:DataType .


###  https://w3id.org/nmdc/sfas-brcs/datasets
nmdc_sfas_brcs:datasets rdf:type owl:ObjectProperty ;
                        rdfs:range nmdc_sfas_brcs:Dataset .


###  https://w3id.org/nmdc/sfas-brcs/environmental_system_science_sfas
nmdc_sfas_brcs:environmental_system_science_sfas rdf:type owl:ObjectProperty .


###  https://w3id.org/nmdc/sfas-brcs/field_sites
nmdc_sfas_brcs:field_sites rdf:type owl:ObjectProperty ;
                           rdfs:range nmdc_sfas_brcs:FieldSite .


###  https://w3id.org/nmdc/sfas-brcs/flagship_genomes
nmdc_sfas_brcs:flagship_genomes rdf:type owl:ObjectProperty ;
                                rdfs:range nmdc_sfas_brcs:FlagshipGenome .


###  https://w3id.org/nmdc/sfas-brcs/funding
nmdc_sfas_brcs:funding rdf:type owl:ObjectProperty ;
                       rdfs:range nmdc_sfas_brcs:FundingInfo .


###  https://w3id.org/nmdc/sfas-brcs/genomic_science_sfas
nmdc_sfas_brcs:genomic_science_sfas rdf:type owl:ObjectProperty .


###  https://w3id.org/nmdc/sfas-brcs/institution_type
nmdc_sfas_brcs:institution_type rdf:type owl:ObjectProperty ;
                                rdfs:range nmdc_sfas_brcs:InstitutionType ;
                                rdfs:label "institution_type" ;
                                skos:definition "The type of institution" ;
                                skos:inScheme <https://w3id.org/nmdc/sfas-brcs> .


###  https://w3id.org/nmdc/sfas-brcs/key_publications
nmdc_sfas_brcs:key_publications rdf:type owl:ObjectProperty ;
                                rdfs:range nmdc_sfas_brcs:Publication .


###  https://w3id.org/nmdc/sfas-brcs/keywords
nmdc_sfas_brcs:keywords rdf:type owl:ObjectProperty ;
                        rdfs:range nmdc_sfas_brcs:Keyword ;
                        rdfs:label "keywords" ;
                        skos:definition "Keywords describing the research focus" ;
                        skos:inScheme <https://w3id.org/nmdc/sfas-brcs> .


###  https://w3id.org/nmdc/sfas-brcs/location
nmdc_sfas_brcs:location rdf:type owl:ObjectProperty ;
                        rdfs:range nmdc_sfas_brcs:Location .


###  https://w3id.org/nmdc/sfas-brcs/metadata
nmdc_sfas_brcs:metadata rdf:type owl:ObjectProperty .


###  https://w3id.org/nmdc/sfas-brcs/outputs
nmdc_sfas_brcs:outputs rdf:type owl:ObjectProperty ;
                       rdfs:range nmdc_sfas_brcs:ProgramOutputs .


###  https://w3id.org/nmdc/sfas-brcs/principal_investigators
nmdc_sfas_brcs:principal_investigators rdf:type owl:ObjectProperty ;
