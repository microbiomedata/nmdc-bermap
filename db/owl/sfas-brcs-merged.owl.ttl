###  https://w3id.org/nmdc/sfas-brcs/wade
nmdc_sfas_brcs:wade rdf:type owl:NamedIndividual ,
                             nmdc_sfas_brcs:ScientificFocusArea ;
                    schema1:alternateName "WaDE" ;
                    schema1:description "WaDE advances predictive understanding of how dominant processes controlling watershed hydro-biogeochemical function operate under different hydrologic regimes and vary along stream networks draining heterogeneous land covers. Organized around Dynamic Headwaters, Stream Corridor Processes, Network Function, and Virtual Watershed themes." ;
                    schema1:keywords "HYDRO_BIOGEOCHEMISTRY" ,
                                     "LAND_COVER" ,
                                     "MERCURY" ,
                                     "STREAM_NETWORKS" ,
                                     "TENNESSEE_RIVER_BASIN" ,
                                     "WATERSHED_DYNAMICS" ;
                    schema1:name "Watershed Dynamics and Evolution (WaDE) Science Focus Area" ;
                    nmdc_sfas_brcs:data_types "BIOGEOCHEMICAL_DATA" ,
                                              "ENVIRONMENTAL_SENSOR_DATA" ,
                                              "HYDROLOGICAL_DATA" ,
                                              "WATER_CHEMISTRY" ;
                    nmdc_sfas_brcs:field_sites [ rdf:type nmdc_sfas_brcs:FieldSite ;
                                                 schema1:description "Three mid-order watersheds broadly representative of the Tennessee River Basin, studied successively over 9-year plan. Most intensively used freshwater resource region in contiguous US, supporting ~4.5 million people with >280,000 gallons/day/sq mi withdrawals." ;
                                                 schema1:name "Tennessee River Basin Watersheds"
                                               ] ;
                    nmdc_sfas_brcs:funding [ rdf:type nmdc_sfas_brcs:FundingInfo ;
                                             nmdc_sfas_brcs:agency "DOE BER" ;
                                             nmdc_sfas_brcs:program "Environmental System Science (ESS)"
                                           ] ;
                    nmdc_sfas_brcs:key_publications <https://doi.org/10.1029/2023WR036706> ,
                                                    <https://doi.org/10.5194/bg-22-995-2025> ;
                    nmdc_sfas_brcs:lead_institution "Oak Ridge National Laboratory" ;
                    nmdc_sfas_brcs:partner_institutions "Colorado School of Mines" ,
                                                        "Kansas State University" ,
                                                        "Oregon State University" ,
                                                        "University of Colorado at Boulder" ,
                                                        "University of Florida" ,
                                                        "Virginia Tech" ;
                    nmdc_sfas_brcs:program_type "SCIENTIFIC_FOCUS_AREA" ;
                    nmdc_sfas_brcs:scientific_questions "How do biogeochemical processes respond to variable saturation in non-perennial channels?" ,
                                                        "How do dominant processes vary under different hydrologic regimes?" ,
                                                        "How does land cover heterogeneity affect watershed function?" ,
                                                        "What controls hydro-biogeochemical function along stream networks?" ;
                    nmdc_sfas_brcs:sfa_type "ENVIRONMENTAL_SYSTEM_SCIENCE_SFA" ;
                    nmdc_sfas_brcs:websites [ rdf:type nmdc_sfas_brcs:WebResources ;
