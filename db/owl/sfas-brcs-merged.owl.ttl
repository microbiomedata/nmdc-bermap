nmdc_sfas_brcs:kbase schema1:alternateName "KBase" ;
                     schema1:description """KBase is an open-source software and data platform enabling data sharing, integration, and analysis of microbes, plants, and their communities. Provides genomic, metabolic modeling, and multi-omics analysis capabilities.
""" ;
                     schema1:name "DOE Systems Biology Knowledgebase" ;
                     rdfs:label "kbase" ;
                     skos:definition "KBase collaboration page URL" ;
                     skos:inScheme <https://w3id.org/nmdc/sfas-brcs> ;
                     nmdc_sfas_brcs:capabilities [ rdf:type nmdc_sfas_brcs:Capability ;
                                                   schema1:description "Functional annotation tools including RAST and KEGG-based annotation, plus DRAM for metabolic profiling. Machine learning classifiers predict growth phenotypes from functional annotations." ;
                                                   schema1:name "Genome Annotation Services" ;
                                                   nmdc_sfas_brcs:applications "Genome functional annotation" ,
                                                                               "MAG annotation" ,
                                                                               "Phenotype prediction" ,
                                                                               "Viral genome annotation (DRAM-v)" ;
                                                   nmdc_sfas_brcs:capability_type "GENOME_ANNOTATION" ;
                                                   nmdc_sfas_brcs:data_products "Annotated genomes" ,
                                                                                "Functional summaries" ,
                                                                                "KEGG mappings" ;
                                                   nmdc_sfas_brcs:status "OPERATIONAL" ;
                                                   nmdc_sfas_brcs:url "https://docs.kbase.us/apps/analysis"^^xsd:anyURI
                                                 ] ,
                                                 [ rdf:type nmdc_sfas_brcs:Capability ;
                                                   schema1:description "Metagenome assembly, binning, and annotation workflows. Applied to build models for over 2,000 MAGs from the GROW (Genome Resolved Open Watersheds) project." ;
                                                   schema1:name "Metagenome Analysis" ;
                                                   nmdc_sfas_brcs:applications "Community metabolic modeling" ,
                                                                               "Genome binning" ,
                                                                               "Metagenome assembly" ;
                                                   nmdc_sfas_brcs:capability_type "METAGENOME_ANALYSIS" ;
                                                   nmdc_sfas_brcs:data_products "Assembled metagenomes" ,
                                                                                "Community models" ,
                                                                                "MAGs" ;
                                                   nmdc_sfas_brcs:status "OPERATIONAL"
                                                 ] ,
                                                 [ rdf:type nmdc_sfas_brcs:Capability ;
                                                   schema1:description "Suite of apps for genome-scale metabolic model reconstruction, analysis, and prediction. Uses OMEGGA for omics-enabled global gapfilling. Over 500 media formulations available. Recent improvements achieve 72% model accuracy." ;
                                                   schema1:name "Metabolic Modeling Pipeline" ;
                                                   nmdc_sfas_brcs:applications "Essential gene prediction" ,
                                                                               "Flux balance analysis" ,
                                                                               "Genome-scale model reconstruction" ,
                                                                               "Growth media optimization" ,
                                                                               "Pathway analysis" ;
                                                   nmdc_sfas_brcs:capability_type "METABOLIC_MODELING" ;
                                                   nmdc_sfas_brcs:data_products "FBA solutions" ,
                                                                                "Growth predictions" ,
                                                                                "Metabolic models" ;
                                                   nmdc_sfas_brcs:status "OPERATIONAL" ;
                                                   nmdc_sfas_brcs:url "https://docs.kbase.us/apps/analysis/metabolic-modeling"^^xsd:anyURI
                                                 ] ;
                     nmdc_sfas_brcs:funding [ rdf:type nmdc_sfas_brcs:FundingInfo ;
                                              nmdc_sfas_brcs:agency "DOE BER" ;
                                              nmdc_sfas_brcs:program "Genomic Science Program"
                                            ] ;
                     nmdc_sfas_brcs:lead_institutions "Argonne National Laboratory" ,
                                                      "Brookhaven National Laboratory" ,
                                                      "Lawrence Berkeley National Laboratory" ,
                                                      "Oak Ridge National Laboratory" ;
                     nmdc_sfas_brcs:program_type "USER_FACILITY" ;
                     nmdc_sfas_brcs:reference_data [ rdf:type nmdc_sfas_brcs:ReferenceData ;
                                                     nmdc_sfas_brcs:biolog_media ">300 formulations" ;
                                                     nmdc_sfas_brcs:microbial_genomes ">90,000 from RefSeq" ;
                                                     nmdc_sfas_brcs:plant_genomes ">50 from Phytozome" ;
                                                     nmdc_sfas_brcs:reactions_compounds ">30,000 from KEGG, BIGG, MetaCyc"
                                                   ] ;
                     nmdc_sfas_brcs:supported_data_types "RNA-seq" ,
                                                         "contigs" ,
                                                         "expression data" ,
                                                         "flux balance analysis solutions" ,
                                                         "genomes" ,
                                                         "growth media" ,
                                                         "growth phenotype data" ,
                                                         "metabolic models" ,
                                                         "reads" ;
                     nmdc_sfas_brcs:websites [ rdf:type nmdc_sfas_brcs:WebResources ;
                                               nmdc_sfas_brcs:documentation "https://docs.kbase.us"^^xsd:anyURI ;
                                               nmdc_sfas_brcs:doe_page "https://www.genomicscience.energy.gov/kbase/"^^xsd:anyURI ;
                                               nmdc_sfas_brcs:main "https://www.kbase.us"^^xsd:anyURI
                                             ] .


